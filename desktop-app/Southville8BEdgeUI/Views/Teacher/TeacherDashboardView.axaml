<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Southville8BEdgeUI.ViewModels.Teacher"
             xmlns:converters="using:Southville8BEdgeUI.Converters"
             xmlns:ic="using:FluentIcons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="1400" d:DesignHeight="900"
             x:Class="Southville8BEdgeUI.Views.Teacher.TeacherDashboardView"
             x:DataType="vm:TeacherDashboardViewModel"
             Background="{DynamicResource PageBackgroundBrush}">

    <UserControl.Resources>
        <converters:BoolToArrowConverter x:Key="BoolToArrowConverter"/>
        <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
    </UserControl.Resources>

    <UserControl.Styles>
        <!-- RESPONSIVE CARD STYLES -->
        <Style Selector="Border.card">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="BoxShadow" Value="0 2 8 0 #10000000"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.2"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.card:pointerover">
            <Setter Property="BoxShadow" Value="0 4 12 0 #20000000"/>
            <Setter Property="RenderTransform" Value="translate(-2px)"/>
        </Style>
        <Style Selector="Border.card.tablet">
            <Setter Property="Padding" Value="16"/>
        </Style>
        <Style Selector="Border.card.mobile">
            <Setter Property="Padding" Value="12"/>
        </Style>

        <!-- RESPONSIVE TEXT STYLES -->
        <Style Selector="TextBlock.main-header">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>
        <Style Selector="TextBlock.main-header.tablet">
            <Setter Property="FontSize" Value="24"/>
        </Style>
        <Style Selector="TextBlock.main-header.mobile">
            <Setter Property="FontSize" Value="20"/>
        </Style>

        <Style Selector="TextBlock.subtitle">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
        </Style>
        <Style Selector="TextBlock.subtitle.tablet">
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="TextBlock.subtitle.mobile">
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style Selector="TextBlock.stat-title">
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
        </Style>
        <Style Selector="TextBlock.stat-title.tablet">
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="TextBlock.stat-title.mobile">
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style Selector="TextBlock.stat-value">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style Selector="TextBlock.stat-value.tablet">
            <Setter Property="FontSize" Value="24"/>
        </Style>
        <Style Selector="TextBlock.stat-value.mobile">
            <Setter Property="FontSize" Value="20"/>
        </Style>

        <Style Selector="TextBlock.section-header">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>
        <Style Selector="TextBlock.section-header.tablet">
            <Setter Property="FontSize" Value="16"/>
        </Style>
        <Style Selector="TextBlock.section-header.mobile">
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <!-- RESPONSIVE BUTTON STYLES -->
        <Style Selector="Button.quick-action">
            <Setter Property="Foreground" Value="{DynamicResource AccentTextOnAccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.quick-action:pointerover">
            <Setter Property="RenderTransform" Value="scale(1.02)"/>
        </Style>
        <Style Selector="Button.quick-action.tablet">
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="Button.quick-action.mobile">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- RESPONSIVE PROGRESS BAR STYLES -->
        <Style Selector="ProgressBar.responsive-progress">
            <Setter Property="Height" Value="4"/>
            <Setter Property="CornerRadius" Value="2"/>
        </Style>
        <Style Selector="ProgressBar.responsive-progress.tablet">
            <Setter Property="Height" Value="3"/>
        </Style>
        <Style Selector="ProgressBar.responsive-progress.mobile">
            <Setter Property="Height" Value="2"/>
        </Style>

        <!-- CLASS CARD STYLES -->
        <Style Selector="Border.class-card">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style Selector="Border.class-card.tablet">
            <Setter Property="Padding" Value="10"/>
        </Style>
        <Style Selector="Border.class-card.mobile">
            <Setter Property="Padding" Value="8"/>
        </Style>

        <!-- RESPONSIVE LAYOUT STYLES -->
        <Style Selector="StackPanel.main-content">
            <Setter Property="Margin" Value="40"/>
            <Setter Property="Spacing" Value="24"/>
        </Style>
        <Style Selector="StackPanel.main-content.tablet">
            <Setter Property="Margin" Value="20"/>
            <Setter Property="Spacing" Value="16"/>
        </Style>
        <Style Selector="StackPanel.main-content.mobile">
            <Setter Property="Margin" Value="12"/>
            <Setter Property="Spacing" Value="12"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer>
        <StackPanel x:Name="MainStackPanel" Classes="main-content">
            <!-- Header with Welcome Message -->
            <Grid x:Name="HeaderGrid" ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="MainHeaderText" Text="Teacher Dashboard" Classes="main-header"/>
                    <TextBlock x:Name="SubtitleText" Text="{Binding WelcomeMessage}" Classes="subtitle"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <TextBlock Text="Online" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource SuccessBrush}" VerticalAlignment="Center"/>
                    <Ellipse Fill="{DynamicResource SuccessBrush}" Width="10" Height="10" VerticalAlignment="Center"/>
                    <Button x:Name="RefreshButton" Classes="quick-action" Background="{DynamicResource TextSecondaryBrush}" Command="{Binding RefreshDashboardCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                            <ic:FluentIcon Icon="ArrowClockwise" IconSize="Size20"/>
                            <TextBlock Text="Refresh"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Key Performance Indicators -->
            <Grid x:Name="KpiGrid" ColumnDefinitions="*,*,*,*,*">
                <Border x:Name="KpiCard1" Grid.Column="0" Classes="card" Margin="0,0,12,0">
                    <StackPanel Spacing="12">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="My Students" Classes="stat-title"/>
                            <Border Grid.Column="1" CornerRadius="6" Padding="4" Background="{DynamicResource SuccessBrush}">
                                <ic:FluentIcon Icon="PeopleTeam" IconSize="Size20" Foreground="{DynamicResource AccentTextOnAccentBrush}"/>
                            </Border>
                        </Grid>
                        <TextBlock x:Name="MyStudentsText" Text="{Binding MyStudents}" Classes="stat-value"/>
                        <TextBlock Text="Across all classes" FontSize="12" Foreground="{DynamicResource SuccessBrush}"/>
                    </StackPanel>
                </Border>
                <Border x:Name="KpiCard2" Grid.Column="1" Classes="card" Margin="12,0">
                    <StackPanel Spacing="12">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Active Classes" Classes="stat-title"/>
                            <Border Grid.Column="1" CornerRadius="6" Padding="4" Background="{DynamicResource InfoBrush}">
                                <ic:FluentIcon Icon="BookOpen" IconSize="Size20" Foreground="{DynamicResource AccentTextOnAccentBrush}"/>
                            </Border>
                        </Grid>
                        <TextBlock x:Name="ActiveClassesText" Text="{Binding ActiveClasses}" Classes="stat-value"/>
                        <TextBlock Text="This semester" FontSize="12" Foreground="{DynamicResource InfoBrush}"/>
                    </StackPanel>
                </Border>
                <Border x:Name="KpiCard3" Grid.Column="2" Classes="card" Margin="12,0">
                    <StackPanel Spacing="12">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Pending Grading" Classes="stat-title"/>
                            <Border Grid.Column="1" CornerRadius="6" Padding="4" Background="{DynamicResource WarningBrush}">
                                <ic:FluentIcon Icon="Edit" IconSize="Size20" Foreground="{DynamicResource AccentTextOnAccentBrush}"/>
                            </Border>
                        </Grid>
                        <TextBlock x:Name="PendingAssignmentsText" Text="{Binding PendingAssignments}" Classes="stat-value"/>
                        <ProgressBar Value="{Binding GradingProgress}" Minimum="0" Maximum="100" Classes="responsive-progress" Foreground="{DynamicResource WarningBrush}"/>
                    </StackPanel>
                </Border>
                <Border x:Name="KpiCard4" Grid.Column="3" Classes="card" Margin="12,0">
                    <StackPanel Spacing="12">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Average Grade" Classes="stat-title"/>
                            <Border Grid.Column="1" CornerRadius="6" Padding="4" Background="{DynamicResource AccentBrush}">
                                <ic:FluentIcon Icon="DataBarVertical" IconSize="Size20" Foreground="{DynamicResource AccentTextOnAccentBrush}"/>
                            </Border>
                        </Grid>
                        <TextBlock x:Name="AverageGradeText" Text="{Binding AverageGrade, StringFormat={}{0:F1}%}" Classes="stat-value"/>
                        <TextBlock Text="Class performance" FontSize="12" Foreground="{DynamicResource AccentBrush}"/>
                    </StackPanel>
                </Border>
                <Border x:Name="KpiCard5" Grid.Column="4" Classes="card" Margin="12,0,0,0">
                    <StackPanel Spacing="12">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Attendance Rate" Classes="stat-title"/>
                            <Border Grid.Column="1" CornerRadius="6" Padding="4" Background="{DynamicResource SuccessBrush}">
                                <ic:FluentIcon Icon="CheckmarkCircle" IconSize="Size20" Foreground="{DynamicResource AccentTextOnAccentBrush}"/>
                            </Border>
                        </Grid>
                        <TextBlock x:Name="AttendanceRateText" Text="{Binding ClassAttendanceRate, StringFormat={}{0:F1}%}" Classes="stat-value"/>
                        <TextBlock Text="Overall attendance" FontSize="12" Foreground="{DynamicResource SuccessBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Performance Metrics & Today's Schedule -->
            <Grid x:Name="TwoColumnGrid1" ColumnDefinitions="2*,*">
                <!-- Student Performance Metrics -->
                <Border Grid.Column="0" Classes="card" Margin="0,0,12,0">
                    <StackPanel Spacing="16">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Subject Performance" Classes="section-header"/>
                            <Button x:Name="DetailedReportsButton" Grid.Column="1" Classes="quick-action" Background="{DynamicResource TextSecondaryBrush}"
                                    Command="{Binding ViewDetailedReportsCommand}" Padding="12,8" FontSize="12">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <ic:FluentIcon Icon="DataPie" IconSize="Size20"/>
                                    <TextBlock Text="Detailed Reports"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                        <ItemsControl ItemsSource="{Binding StudentPerformance}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:StudentPerformanceViewModel">
                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" Margin="0,0,0,12">
                                        <Border Grid.Column="0" CornerRadius="8" Padding="8" Margin="0,0,12,0" Background="{DynamicResource BorderBrush}">
                                            <ic:FluentIcon Icon="BookOpen" IconSize="Size20"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Subject}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding AverageGrade, StringFormat={}{0:F1}%}" FontSize="20" FontWeight="Bold"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{Binding StudentsCount}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Grid.Column="3" Text="{Binding ImprovementText}" Foreground="{Binding ImprovementBrush}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <Path Grid.Column="4" Data="{Binding IsImproving, Converter={StaticResource BoolToArrowConverter}}" Fill="{Binding ImprovementBrush}" Width="10" Height="5" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Today's Schedule -->
                <Border Grid.Column="1" Classes="card" Margin="12,0,0,0">
                    <StackPanel Spacing="16">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Today's Schedule" Classes="section-header"/>
                            <TextBlock x:Name="TodayClassesText" Grid.Column="1" Text="{Binding TodayClasses}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource SuccessBrush}"/>
                        </Grid>
                        <ScrollViewer MaxHeight="280" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding TodaySchedule}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="vm:DashboardClassViewModel">
                                        <Border Classes="class-card">
                                            <Grid ColumnDefinitions="Auto,*,Auto">
                                                <Border Grid.Column="0" Background="{Binding StatusColor}" Width="4" Height="50" CornerRadius="2" VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="1" Margin="12,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Subject}" FontWeight="SemiBold" FontSize="12"/>
                                                    <TextBlock Text="{Binding Grade}" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                                                    <TextBlock Text="{Binding Time}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                                    <TextBlock Text="{Binding Room}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                    <Border Background="{Binding StatusColor}" CornerRadius="12" Padding="6,2" Margin="0,0,0,4">
                                                        <TextBlock Text="{Binding Status}" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource AccentTextOnAccentBrush}"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding StudentsCount}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Quick Actions & Class Statistics -->
            <Grid x:Name="TwoColumnGrid2" ColumnDefinitions="*,*">
                <!-- Quick Actions -->
                <Border Grid.Column="0" Classes="card" Margin="0,0,12,0">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Quick Actions" Classes="section-header"/>
                        <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto">
                            <Button x:Name="ScheduleButton" Grid.Column="0" Grid.Row="0" Classes="quick-action" Background="{DynamicResource SuccessBrush}" Command="{Binding NavigateToSchedulePlannerCommand}" Margin="0,0,8,8">
                                <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                    <ic:FluentIcon Icon="Calendar" IconSize="Size20"/>
                                    <TextBlock Text="Schedule"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="GradesButton" Grid.Column="1" Grid.Row="0" Classes="quick-action" Background="{DynamicResource InfoBrush}" Command="{Binding NavigateToGradeEntryCommand}" Margin="8,0,8,8">
                                <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                    <ic:FluentIcon Icon="DataBarVertical" IconSize="Size20"/>
                                    <TextBlock Text="Grades"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="StudentsButton" Grid.Column="2" Grid.Row="0" Classes="quick-action" Background="{DynamicResource AccentBrush}" Command="{Binding NavigateToStudentManagementCommand}" Margin="8,0,0,8">
                                <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                    <ic:FluentIcon Icon="PeopleTeam" IconSize="Size20"/>
                                    <TextBlock Text="Students"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="AnnounceButton" Grid.Column="0" Grid.Row="1" Classes="quick-action" Background="{DynamicResource WarningBrush}" Command="{Binding NavigateToMyAnnouncementsCommand}" Margin="0,8,8,0">
                                <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                    <ic:FluentIcon Icon="MegaphoneLoud" IconSize="Size20"/>
                                    <TextBlock Text="Announce"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="MessagesButton" Grid.Column="1" Grid.Row="1" Classes="quick-action" Background="{DynamicResource AccentBrush}" Command="{Binding NavigateToMessagingCommand}" Margin="8,8,8,0">
                                <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                    <ic:FluentIcon Icon="ChatMultiple" IconSize="Size20"/>
                                    <TextBlock Text="Messages"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="ReportsButton" Grid.Column="2" Grid.Row="1" Classes="quick-action" Background="{DynamicResource TextSecondaryBrush}" Command="{Binding ViewDetailedReportsCommand}" Margin="8,8,0,0">
                                <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                    <ic:FluentIcon Icon="DataLine" IconSize="Size20"/>
                                    <TextBlock Text="Reports"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Class Statistics Overview -->
                <Border Grid.Column="1" Classes="card" Margin="12,0,0,0">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Class Overview" Classes="section-header"/>
                        <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding ClassStatistics}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="vm:ClassStatViewModel">
                                        <Border Background="{DynamicResource PageBackgroundBrush}" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding ClassName}" FontWeight="SemiBold" FontSize="12"/>
                                                <Grid ColumnDefinitions="*,*,*">
                                                    <StackPanel Grid.Column="0" Spacing="2">
                                                        <TextBlock Text="Students" FontSize="9" Foreground="{DynamicResource TextMutedBrush}"/>
                                                        <TextBlock Text="{Binding StudentsCount}" FontSize="14" FontWeight="Bold"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Spacing="2">
                                                        <TextBlock Text="Attendance" FontSize="9" Foreground="{DynamicResource TextMutedBrush}"/>
                                                        <TextBlock Text="{Binding AttendanceRate, StringFormat={}{0:F1}%}" FontSize="14" FontWeight="Bold"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2" Spacing="2">
                                                        <TextBlock Text="Avg Grade" FontSize="9" Foreground="{DynamicResource TextMutedBrush}"/>
                                                        <TextBlock Text="{Binding AverageGrade, StringFormat={}{0:F1}%}" FontSize="14" FontWeight="Bold"/>
                                                    </StackPanel>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Subject Distribution & Recent Activity -->
            <Grid x:Name="TwoColumnGrid3" ColumnDefinitions="*,2*">
                <!-- Subject Distribution -->
                <Border Grid.Column="0" Classes="card" Margin="0,0,12,0">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Subject Distribution" Classes="section-header"/>
                        <ItemsControl ItemsSource="{Binding SubjectDistribution}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:SubjectDistributionViewModel">
                                    <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,12">
                                        <Border Grid.Column="0" Background="{Binding Color}" Width="12" Height="12" CornerRadius="6" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Subject}" FontWeight="SemiBold"/>
                                            <ProgressBar Value="{Binding Percentage}" Minimum="0" Maximum="40" Classes="responsive-progress" Foreground="{Binding Color}"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{Binding StudentsCount}" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Recent Activity -->
                <Border Grid.Column="1" Classes="card" Margin="12,0,0,0">
                    <StackPanel Spacing="16">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Recent Student Activity" Classes="section-header"/>
                            <Button x:Name="ViewAllButton" Grid.Column="1" Classes="quick-action" Background="{DynamicResource SuccessBrush}"
                                    Command="{Binding ViewAllActivitiesCommand}" Padding="8,6" FontSize="10">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <ic:FluentIcon Icon="List" IconSize="Size16"/>
                                    <TextBlock Text="View All"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                        <ScrollViewer MaxHeight="300" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding RecentActivities}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="vm:TeacherActivityViewModel">
                                        <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,12">
                                            <Grid Grid.Column="0" Width="32" Height="32" Margin="0,0,12,0">
                                                <Border Background="{Binding TypeColor}" CornerRadius="16" Opacity="0.15"/>
                                                <ic:FluentIcon Icon="{Binding IconName}" IconSize="Size16" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" Text="{Binding Description}"/>
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="{Binding Subject}" FontSize="10" Foreground="{DynamicResource SuccessBrush}"/>
                                                    <TextBlock Text="•" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                                    <TextBlock Text="{Binding Timestamp}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Weekly Schedule Overview -->
            <Border Classes="card">
                <StackPanel Spacing="16">
                    <TextBlock Text="Weekly Schedule Overview" Classes="section-header"/>
                    <Grid x:Name="WeeklyGrid" ColumnDefinitions="*,*,*,*,*,*,*">
                        <!-- Monday -->
                        <Border Grid.Column="0" CornerRadius="8" Padding="12" Margin="0,0,4,0"
                                DataContext="{Binding WeeklySchedule[0]}"
                                Background="{Binding BackgroundBrush}">
                            <StackPanel HorizontalAlignment="Center" Spacing="4">
                                <TextBlock Text="{Binding Day}" FontSize="12" HorizontalAlignment="Center" Foreground="{Binding TextBrush}"/>
                                <!-- Classes Panel -->
                                <StackPanel Spacing="4" IsVisible="{Binding HasClasses}">
                                    <TextBlock Text="{Binding ClassCount}" FontWeight="Bold" HorizontalAlignment="Center" FontSize="20" Foreground="{Binding TextBrush}"/>
                                    <TextBlock Text="classes" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding Students, StringFormat={}{0} students}" FontSize="9" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <!-- Rest Day Panel -->
                                <StackPanel Spacing="2" IsVisible="{Binding HasClasses, Converter={StaticResource InverseBoolConverter}}" HorizontalAlignment="Center">
                                    <TextBlock Text="Rest" FontWeight="Bold" HorizontalAlignment="Center" FontSize="16"/>
                                    <TextBlock Text="day" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Enjoy!" FontSize="9" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <!-- Tuesday -->
                        <Border Grid.Column="1" CornerRadius="8" Padding="12" Margin="4,0"
                                DataContext="{Binding WeeklySchedule[1]}"
                                Background="{Binding BackgroundBrush}">
                            <StackPanel HorizontalAlignment="Center" Spacing="4">
                                <TextBlock Text="{Binding Day}" FontSize="12" HorizontalAlignment="Center" Foreground="{Binding TextBrush}"/>
                                <StackPanel Spacing="4" IsVisible="{Binding HasClasses}">
                                    <TextBlock Text="{Binding ClassCount}" FontWeight="Bold" HorizontalAlignment="Center" FontSize="20" Foreground="{Binding TextBrush}"/>
                                    <TextBlock Text="classes" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding Students, StringFormat={}{0} students}" FontSize="9" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Spacing="2" IsVisible="{Binding HasClasses, Converter={StaticResource InverseBoolConverter}}">
                                    <TextBlock Text="Rest" FontWeight="Bold" HorizontalAlignment="Center" FontSize="16"/>
                                    <TextBlock Text="day" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Enjoy!" FontSize="9" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <!-- Wednesday -->
                        <Border Grid.Column="2" CornerRadius="8" Padding="12" Margin="4,0"
                                DataContext="{Binding WeeklySchedule[2]}"
                                Background="{Binding BackgroundBrush}">
                            <StackPanel HorizontalAlignment="Center" Spacing="4">
                                <TextBlock Text="{Binding Day}" FontSize="12" HorizontalAlignment="Center" Foreground="{Binding TextBrush}"/>
                                <StackPanel Spacing="4" IsVisible="{Binding HasClasses}">
                                    <TextBlock Text="{Binding ClassCount}" FontWeight="Bold" HorizontalAlignment="Center" FontSize="20" Foreground="{Binding TextBrush}"/>
                                    <TextBlock Text="classes" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding Students, StringFormat={}{0} students}" FontSize="9" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Spacing="2" IsVisible="{Binding HasClasses, Converter={StaticResource InverseBoolConverter}}">
                                    <TextBlock Text="Rest" FontWeight="Bold" HorizontalAlignment="Center" FontSize="16"/>
                                    <TextBlock Text="day" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Enjoy!" FontSize="9" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <!-- Thursday -->
                        <Border Grid.Column="3" CornerRadius="8" Padding="12" Margin="4,0"
                                DataContext="{Binding WeeklySchedule[3]}"
                                Background="{Binding BackgroundBrush}">
                            <StackPanel HorizontalAlignment="Center" Spacing="4">
                                <TextBlock Text="{Binding Day}" FontSize="12" HorizontalAlignment="Center" Foreground="{Binding TextBrush}"/>
                                <StackPanel Spacing="4" IsVisible="{Binding HasClasses}">
                                    <TextBlock Text="{Binding ClassCount}" FontWeight="Bold" HorizontalAlignment="Center" FontSize="20" Foreground="{Binding TextBrush}"/>
                                    <TextBlock Text="classes" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding Students, StringFormat={}{0} students}" FontSize="9" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Spacing="2" IsVisible="{Binding HasClasses, Converter={StaticResource InverseBoolConverter}}">
                                    <TextBlock Text="Rest" FontWeight="Bold" HorizontalAlignment="Center" FontSize="16"/>
                                    <TextBlock Text="day" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Enjoy!" FontSize="9" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <!-- Friday -->
                        <Border Grid.Column="4" CornerRadius="8" Padding="12" Margin="4,0"
                                DataContext="{Binding WeeklySchedule[4]}"
                                Background="{Binding BackgroundBrush}">
                            <StackPanel HorizontalAlignment="Center" Spacing="4">
                                <TextBlock Text="{Binding Day}" FontSize="12" HorizontalAlignment="Center" Foreground="{Binding TextBrush}"/>
                                <StackPanel Spacing="4" IsVisible="{Binding HasClasses}">
                                    <TextBlock Text="{Binding ClassCount}" FontWeight="Bold" HorizontalAlignment="Center" FontSize="20" Foreground="{Binding TextBrush}"/>
                                    <TextBlock Text="classes" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding Students, StringFormat={}{0} students}" FontSize="9" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Spacing="2" IsVisible="{Binding HasClasses, Converter={StaticResource InverseBoolConverter}}">
                                    <TextBlock Text="Rest" FontWeight="Bold" HorizontalAlignment="Center" FontSize="16"/>
                                    <TextBlock Text="day" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Enjoy!" FontSize="9" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <!-- Saturday -->
                        <Border Grid.Column="5" CornerRadius="8" Padding="12" Margin="4,0"
                                DataContext="{Binding WeeklySchedule[5]}"
                                Background="{Binding BackgroundBrush}">
                            <StackPanel HorizontalAlignment="Center" Spacing="4">
                                <TextBlock Text="{Binding Day}" FontSize="12" HorizontalAlignment="Center" Foreground="{Binding TextBrush}"/>
                                <StackPanel Spacing="4" IsVisible="{Binding HasClasses}">
                                    <TextBlock Text="{Binding ClassCount}" FontWeight="Bold" HorizontalAlignment="Center" FontSize="20" Foreground="{Binding TextBrush}"/>
                                    <TextBlock Text="classes" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding Students, StringFormat={}{0} students}" FontSize="9" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Spacing="2" IsVisible="{Binding HasClasses, Converter={StaticResource InverseBoolConverter}}">
                                    <TextBlock Text="Rest" FontWeight="Bold" HorizontalAlignment="Center" FontSize="16"/>
                                    <TextBlock Text="day" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Enjoy!" FontSize="9" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <!-- Sunday -->
                        <Border Grid.Column="6" CornerRadius="8" Padding="12" Margin="4,0,0,0"
                                DataContext="{Binding WeeklySchedule[6]}"
                                Background="{Binding BackgroundBrush}">
                            <StackPanel HorizontalAlignment="Center" Spacing="4">
                                <TextBlock Text="{Binding Day}" FontSize="12" HorizontalAlignment="Center" Foreground="{Binding TextBrush}"/>
                                <StackPanel Spacing="4" IsVisible="{Binding HasClasses}">
                                    <TextBlock Text="{Binding ClassCount}" FontWeight="Bold" HorizontalAlignment="Center" FontSize="20" Foreground="{Binding TextBrush}"/>
                                    <TextBlock Text="classes" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding Students, StringFormat={}{0} students}" FontSize="9" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Spacing="2" IsVisible="{Binding HasClasses, Converter={StaticResource InverseBoolConverter}}">
                                    <TextBlock Text="Rest" FontWeight="Bold" HorizontalAlignment="Center" FontSize="16"/>
                                    <TextBlock Text="day" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Enjoy!" FontSize="9" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>