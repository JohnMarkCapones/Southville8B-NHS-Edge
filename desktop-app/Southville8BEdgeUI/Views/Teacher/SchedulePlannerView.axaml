<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Southville8BEdgeUI.ViewModels.Teacher"
             mc:Ignorable="d" d:DesignWidth="1400" d:DesignHeight="900"
             x:Class="Southville8BEdgeUI.Views.Teacher.SchedulePlannerView"
             x:DataType="vm:SchedulePlannerViewModel"
             Background="{DynamicResource PageBackgroundBrush}">

    <UserControl.Styles>
        <!-- Base Card Style -->
        <Style Selector="Border.card">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="BoxShadow" Value="0 2 8 0 #10000000"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>

        <!-- Responsive Card Styles -->
        <Style Selector="Border.card.mobile">
            <Setter Property="Padding" Value="16"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style Selector="Border.card.tablet">
            <Setter Property="Padding" Value="18"/>
            <Setter Property="CornerRadius" Value="10"/>
        </Style>

        <!-- Action Button Styles -->
        <Style Selector="Button.action-btn">
            <Setter Property="Background" Value="{DynamicResource SuccessBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentTextOnAccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1"/>
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Button.action-btn:pointerover">
            <Setter Property="RenderTransform" Value="scale(1.02)"/>
        </Style>

        <Style Selector="Button.action-btn.mobile">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- Secondary Button Styles -->
        <Style Selector="Button.secondary-btn">
            <Setter Property="Background" Value="{DynamicResource InfoBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentTextOnAccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style Selector="Button.secondary-btn:pointerover">
            <Setter Property="BorderBrush" Value="{DynamicResource InfoBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- Tertiary Button Styles -->
        <Style Selector="Button.tertiary-btn">
            <Setter Property="Background" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentTextOnAccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style Selector="Button.tertiary-btn:pointerover">
            <Setter Property="BorderBrush" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- Schedule Slot Styles -->
        <Style Selector="Border.schedule-slot">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="MinHeight" Value="60"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Border.schedule-slot:pointerover">
            <Setter Property="Background" Value="{DynamicResource PageBackgroundBrush}"/>
        </Style>

        <Style Selector="Border.schedule-slot.occupied">
            <!-- No Opacity: emphasize with colored border strip -->
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InfoBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>

        <Style Selector="Border.schedule-slot.occupied:pointerover">
            <Setter Property="Background" Value="{DynamicResource PageBackgroundBrush}"/>
        </Style>

        <Style Selector="Border.schedule-slot.mobile">
            <Setter Property="MinHeight" Value="50"/>
            <Setter Property="Padding" Value="6"/>
        </Style>

        <!-- Time Header Styles -->
        <Style Selector="Border.time-header">
            <Setter Property="Background" Value="{DynamicResource PageBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="MinHeight" Value="60"/>
        </Style>

        <Style Selector="Border.time-header.mobile">
            <Setter Property="MinHeight" Value="50"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <!-- Typography Styles -->
        <Style Selector="TextBlock.header">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>

        <Style Selector="TextBlock.header.mobile">
            <Setter Property="FontSize" Value="22"/>
        </Style>

        <Style Selector="TextBlock.header.tablet">
            <Setter Property="FontSize" Value="24"/>
        </Style>

        <Style Selector="TextBlock.subtitle">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
        </Style>

        <Style Selector="TextBlock.subtitle.mobile">
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style Selector="TextBlock.kpi-value">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>

        <Style Selector="TextBlock.kpi-value.mobile">
            <Setter Property="FontSize" Value="20"/>
        </Style>

        <Style Selector="TextBlock.kpi-value.tablet">
            <Setter Property="FontSize" Value="22"/>
        </Style>

        <!-- Input Styles -->
        <Style Selector="ComboBox, TextBox, TimePicker">
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>

        <Style Selector="ComboBox:focus-within, TextBox:focus-within, TimePicker:focus-within">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>

        <!-- Responsive Layout Classes -->
        <Style Selector="StackPanel.main-content">
            <Setter Property="Margin" Value="40"/>
            <Setter Property="Spacing" Value="24"/>
        </Style>

        <Style Selector="StackPanel.main-content.tablet">
            <Setter Property="Margin" Value="24"/>
            <Setter Property="Spacing" Value="20"/>
        </Style>

        <Style Selector="StackPanel.main-content.mobile">
            <Setter Property="Margin" Value="16"/>
            <Setter Property="Spacing" Value="16"/>
        </Style>

        <!-- Upcoming Class Card Styles -->
        <Style Selector="Border.upcoming-class-card">
            <Setter Property="Background" Value="{DynamicResource PageBackgroundBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style Selector="Border.upcoming-class-card:pointerover">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="-1"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style Selector="Border.upcoming-class-card.mobile">
            <Setter Property="Padding" Value="12"/>
        </Style>

        <!-- Conflict Card Styles -->
        <Style Selector="Border.conflict-card">
            <Setter Property="Background" Value="{DynamicResource PageBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style Selector="Border.conflict-card.mobile">
            <Setter Property="Padding" Value="6"/>
        </Style>
    </UserControl.Styles>

    <UserControl.Resources>
        <!-- Schedule Slot Template -->
        <DataTemplate x:Key="ScheduleSlotTemplate" DataType="vm:ScheduleSlotViewModel">
            <StackPanel IsVisible="{Binding IsOccupied}" VerticalAlignment="Center">
                <TextBlock Text="{Binding Subject}" FontWeight="SemiBold" FontSize="11" HorizontalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                <TextBlock Text="{Binding Grade}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding Room}" FontSize="9" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
            </StackPanel>
        </DataTemplate>

        <!-- Upcoming Class Template -->
        <DataTemplate x:Key="UpcomingClassTemplate" DataType="vm:UpcomingClassViewModel">
            <Border Classes="upcoming-class-card">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <Border Grid.Column="0" Background="{Binding SubjectColor}" Width="4" Height="40" CornerRadius="2" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Margin="12,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Subject}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="{Binding Grade}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{Binding Time}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                            <TextBlock Text="•" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                            <TextBlock Text="{Binding Room}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                        <Button Content="✏️" Classes="tertiary-btn" Padding="6" ToolTip.Tip="Edit Class" Command="{Binding $parent[UserControl].((vm:SchedulePlannerViewModel)DataContext).EditClassCommand}" CommandParameter="{Binding}"/>
                        <Button Content="📝" Classes="action-btn" Padding="6" ToolTip.Tip="Add Notes" Command="{Binding $parent[UserControl].((vm:SchedulePlannerViewModel)DataContext).AddNotesCommand}" CommandParameter="{Binding}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- Conflict Template -->
        <DataTemplate x:Key="ConflictTemplate" DataType="vm:ScheduleConflictViewModel">
            <Border Classes="conflict-card">
                <StackPanel Spacing="2">
                    <TextBlock Text="{Binding ConflictDescription}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource DangerBrush}" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding Time}" FontSize="10" Foreground="{DynamicResource DangerBrush}"/>
                    <Button Content="Resolve" Background="{DynamicResource DangerBrush}" Foreground="{DynamicResource AccentTextOnAccentBrush}" BorderThickness="0" CornerRadius="4" Padding="6,2" FontSize="10" HorizontalAlignment="Left" Command="{Binding ResolveCommand}"/>
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <ScrollViewer x:Name="MainScrollViewer" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel x:Name="MainStackPanel" Classes="main-content">
            <!-- Header Section -->
            <Grid x:Name="HeaderGrid" ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Schedule Planner" Classes="header"/>
                    <TextBlock Text="Plan and manage your weekly class schedule" Classes="subtitle"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <ComboBox SelectedItem="{Binding SelectedWeek}" ItemsSource="{Binding AvailableWeeks}" MinWidth="150" PlaceholderText="Select Week"/>
                    <Button x:Name="AddClassButton" Content="📅 Add Class" Classes="action-btn" Command="{Binding AddClassCommand}"/>
                    <Button x:Name="ExportButton" Content="📊 Export Schedule" Classes="secondary-btn" Command="{Binding ExportScheduleCommand}"/>
                </StackPanel>
            </Grid>

            <!-- KPI Cards Section -->
            <Grid x:Name="KpiGrid" ColumnDefinitions="*,*,*,*">
                <Border x:Name="KpiCard1" Grid.Column="0" Classes="card" Margin="0,0,12,0">
                    <StackPanel Spacing="8">
                        <TextBlock Text="This Week Classes" FontSize="14" Foreground="{DynamicResource TextMutedBrush}"/>
                        <TextBlock Text="{Binding WeeklyClassesCount}" Classes="kpi-value" Foreground="{DynamicResource InfoBrush}"/>
                        <TextBlock Text="Scheduled sessions" FontSize="12" Foreground="{DynamicResource InfoBrush}"/>
                    </StackPanel>
                </Border>
                <Border x:Name="KpiCard2" Grid.Column="1" Classes="card" Margin="12,0">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Teaching Hours" FontSize="14" Foreground="{DynamicResource TextMutedBrush}"/>
                        <TextBlock Text="{Binding WeeklyHours}" Classes="kpi-value" Foreground="{DynamicResource SuccessBrush}"/>
                        <TextBlock Text="Total this week" FontSize="12" Foreground="{DynamicResource SuccessBrush}"/>
                    </StackPanel>
                </Border>
                <Border x:Name="KpiCard3" Grid.Column="2" Classes="card" Margin="12,0">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Free Periods" FontSize="14" Foreground="{DynamicResource TextMutedBrush}"/>
                        <TextBlock Text="{Binding FreePeriodsCount}" Classes="kpi-value" Foreground="{DynamicResource WarningBrush}"/>
                        <TextBlock Text="Available slots" FontSize="12" Foreground="{DynamicResource WarningBrush}"/>
                    </StackPanel>
                </Border>
                <Border x:Name="KpiCard4" Grid.Column="3" Classes="card" Margin="12,0,0,0">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Conflicts" FontSize="14" Foreground="{DynamicResource TextMutedBrush}"/>
                        <TextBlock Text="{Binding ConflictsCount}" Classes="kpi-value" Foreground="{DynamicResource DangerBrush}"/>
                        <TextBlock Text="Need attention" FontSize="12" Foreground="{DynamicResource DangerBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Schedule Section -->
            <Border Classes="card">
                <StackPanel Spacing="16">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="Weekly Schedule" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                            <Button x:Name="RefreshButton" Content="🔄 Refresh" Classes="tertiary-btn" Command="{Binding RefreshScheduleCommand}"/>
                            <Button x:Name="TemplatesButton" Content="📋 Templates" Background="{DynamicResource AccentBrush}" Foreground="{DynamicResource AccentTextOnAccentBrush}" BorderThickness="0" CornerRadius="6" Padding="8,6" Command="{Binding ManageTemplatesCommand}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Schedule Grid -->
                    <Grid x:Name="ScheduleGrid">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Schedule Header -->
                        <Grid Grid.Row="0" x:Name="DayColumnsGrid" ColumnDefinitions="100,*,*,*,*,*,*,*">
                            <Border Grid.Column="0" Background="{DynamicResource PageBackgroundBrush}" Padding="12,8" CornerRadius="6,0,0,6">
                                <TextBlock Text="Time" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </Border>
                            <Border Grid.Column="1" Background="{DynamicResource PageBackgroundBrush}" Padding="12,8">
                                <TextBlock Text="Monday" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </Border>
                            <Border Grid.Column="2" Background="{DynamicResource PageBackgroundBrush}" Padding="12,8">
                                <TextBlock Text="Tuesday" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </Border>
                            <Border Grid.Column="3" Background="{DynamicResource PageBackgroundBrush}" Padding="12,8">
                                <TextBlock Text="Wednesday" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </Border>
                            <Border Grid.Column="4" Background="{DynamicResource PageBackgroundBrush}" Padding="12,8">
                                <TextBlock Text="Thursday" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </Border>
                            <Border Grid.Column="5" Background="{DynamicResource PageBackgroundBrush}" Padding="12,8">
                                <TextBlock Text="Friday" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </Border>
                            <Border Grid.Column="6" Background="{DynamicResource PageBackgroundBrush}" Padding="12,8">
                                <TextBlock Text="Saturday" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </Border>
                            <Border Grid.Column="7" Background="{DynamicResource PageBackgroundBrush}" Padding="12,8" CornerRadius="0,6,6,0">
                                <TextBlock Text="Sunday" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </Border>
                        </Grid>

                        <!-- Schedule Content -->
                        <ScrollViewer Grid.Row="1" MaxHeight="600" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding TimeSlots}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="vm:TimeSlotViewModel">
                                        <Grid ColumnDefinitions="100,*,*,*,*,*,*,*">
                                            <!-- Time Column -->
                                            <Border x:Name="TimeColumn" Grid.Column="0" Classes="time-header">
                                                <TextBlock Text="{Binding TimeRange}" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            </Border>

                                            <!-- Day Columns -->
                                            <Border Grid.Column="1" Classes="schedule-slot" Classes.occupied="{Binding Monday.IsOccupied}">
                                                <ContentControl Content="{Binding Monday}" ContentTemplate="{StaticResource ScheduleSlotTemplate}"/>
                                            </Border>

                                            <Border Grid.Column="2" Classes="schedule-slot" Classes.occupied="{Binding Tuesday.IsOccupied}">
                                                <ContentControl Content="{Binding Tuesday}" ContentTemplate="{StaticResource ScheduleSlotTemplate}"/>
                                            </Border>

                                            <Border Grid.Column="3" Classes="schedule-slot" Classes.occupied="{Binding Wednesday.IsOccupied}">
                                                <ContentControl Content="{Binding Wednesday}" ContentTemplate="{StaticResource ScheduleSlotTemplate}"/>
                                            </Border>

                                            <Border Grid.Column="4" Classes="schedule-slot" Classes.occupied="{Binding Thursday.IsOccupied}">
                                                <ContentControl Content="{Binding Thursday}" ContentTemplate="{StaticResource ScheduleSlotTemplate}"/>
                                            </Border>

                                            <Border Grid.Column="5" Classes="schedule-slot" Classes.occupied="{Binding Friday.IsOccupied}">
                                                <ContentControl Content="{Binding Friday}" ContentTemplate="{StaticResource ScheduleSlotTemplate}"/>
                                            </Border>

                                            <Border Grid.Column="6" Classes="schedule-slot" Classes.occupied="{Binding Saturday.IsOccupied}">
                                                <ContentControl Content="{Binding Saturday}" ContentTemplate="{StaticResource ScheduleSlotTemplate}"/>
                                            </Border>

                                            <Border Grid.Column="7" Classes="schedule-slot" Classes.occupied="{Binding Sunday.IsOccupied}">
                                                <ContentControl Content="{Binding Sunday}" ContentTemplate="{StaticResource ScheduleSlotTemplate}"/>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Bottom Section: Upcoming Classes and Quick Actions -->
            <Grid x:Name="ContentGrid" ColumnDefinitions="2*,*">
                <!-- Upcoming Classes Panel -->
                <Border Grid.Column="0" Classes="card" Margin="0,0,12,0">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Upcoming Classes" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <ScrollViewer MaxHeight="300" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="UpcomingClassesList" ItemsSource="{Binding UpcomingClasses}" ItemTemplate="{StaticResource UpcomingClassTemplate}"/>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <!-- Side Panel: Quick Actions -->
                <Border x:Name="SidePanel" Grid.Column="1" Classes="card" Margin="12,0,0,0">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Quick Actions" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        
                        <!-- Quick Add Form -->
                        <StackPanel x:Name="QuickAddPanel" Spacing="16">
                            <TextBlock Text="Quick Add Class" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            

                            <StackPanel x:Name="QuickAddForm" Spacing="12">
                                <ComboBox SelectedItem="{Binding NewClassSubject}" 
                                         ItemsSource="{Binding AvailableSubjects}" 
                                         PlaceholderText="Select Subject" 
                                         HorizontalAlignment="Stretch"/>
                                <ComboBox SelectedItem="{Binding NewClassGrade}" 
                                         ItemsSource="{Binding AvailableGrades}" 
                                         PlaceholderText="Select Grade" 
                                         HorizontalAlignment="Stretch"/>
                                <ComboBox SelectedItem="{Binding NewClassDay}" 
                                         ItemsSource="{Binding AvailableDays}" 
                                         PlaceholderText="Select Day" 
                                         HorizontalAlignment="Stretch"/>
                                <TimePicker SelectedTime="{Binding NewClassStartTime}" 
                                           HorizontalAlignment="Stretch"/>
                                <ComboBox SelectedItem="{Binding NewClassDuration}" 
                                         ItemsSource="{Binding AvailableDurations}" 
                                         PlaceholderText="Duration" 
                                         HorizontalAlignment="Stretch"/>
                                <TextBox Text="{Binding NewClassRoom}" 
                                        Watermark="Room Number" 
                                        HorizontalAlignment="Stretch"/>
                                <Button Content="➕ Add Class" 
                                       Classes="action-btn" 
                                       HorizontalAlignment="Stretch" 
                                       Command="{Binding QuickAddClassCommand}"/>
                            </StackPanel>
                        </StackPanel>
        
                        <!-- Schedule Templates -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="Schedule Templates" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <Button Content="📋 Load Template" 
                                   Background="{DynamicResource AccentBrush}" 
                                   Foreground="{DynamicResource AccentTextOnAccentBrush}" 
                                   BorderThickness="0" 
                                   CornerRadius="8" 
                                   Padding="12,8" 
                                   FontWeight="SemiBold" 
                                   HorizontalAlignment="Stretch" 
                                   Command="{Binding LoadTemplateCommand}"/>
                            <Button Content="💾 Save as Template" 
                                   Background="{DynamicResource WarningBrush}" 
                                   Foreground="{DynamicResource AccentTextOnAccentBrush}" 
                                   BorderThickness="0" 
                                   CornerRadius="8" 
                                   Padding="12,8" 
                                   FontWeight="SemiBold" 
                                   HorizontalAlignment="Stretch" 
                                   Command="{Binding SaveTemplateCommand}"/>
                        </StackPanel>

                        <!-- Schedule Conflicts -->
                        <StackPanel Spacing="8" IsVisible="{Binding HasConflicts}">
                            <TextBlock Text="Schedule Conflicts" 
                                      FontSize="14" 
                                      FontWeight="SemiBold" 
                                      Foreground="{DynamicResource DangerBrush}"/>
                            <ScrollViewer MaxHeight="150" VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="ConflictsList" 
                                             ItemsSource="{Binding Conflicts}"
                                             ItemTemplate="{StaticResource ConflictTemplate}"/>
                            </ScrollViewer>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
