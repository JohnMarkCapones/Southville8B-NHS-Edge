<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Southville8BEdgeUI.ViewModels.Teacher"
             mc:Ignorable="d" d:DesignWidth="1400" d:DesignHeight="900"
             x:Class="Southville8BEdgeUI.Views.Teacher.SchedulePlannerView"
             x:DataType="vm:SchedulePlannerViewModel"
             Background="#F9FAFB">

    <UserControl.Styles>
        <Style Selector="Border.card">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="BoxShadow" Value="0 2 8 0 #10000000"/>
        </Style>
        <Style Selector="Button.action-btn">
            <Setter Property="Background" Value="#10B981"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Border.schedule-slot">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="MinHeight" Value="60"/>
        </Style>
        <Style Selector="Border.schedule-slot.occupied">
            <Setter Property="Background" Value="#EEF2FF"/>
            <Setter Property="BorderBrush" Value="#3B82F6"/>
        </Style>
        <Style Selector="Border.time-header">
            <Setter Property="Background" Value="#F9FAFB"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="MinHeight" Value="60"/>
        </Style>
    </UserControl.Styles>

    <UserControl.Resources>
        <DataTemplate x:Key="ScheduleSlotTemplate" DataType="vm:ScheduleSlotViewModel">
            <StackPanel IsVisible="{Binding IsOccupied}" VerticalAlignment="Center">
                <TextBlock Text="{Binding Subject}" FontWeight="SemiBold" FontSize="11" HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding Grade}" FontSize="10" Foreground="#6B7280" HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding Room}" FontSize="9" Foreground="#9CA3AF" HorizontalAlignment="Center"/>
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <ScrollViewer>
        <StackPanel Margin="40" Spacing="24">
            <!-- Header -->
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Schedule Planner" FontSize="28" FontWeight="Bold"/>
                    <TextBlock Text="Plan and manage your weekly class schedule" FontSize="14" Foreground="#6B7280"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <ComboBox SelectedItem="{Binding SelectedWeek}" ItemsSource="{Binding AvailableWeeks}" MinWidth="150" PlaceholderText="Select Week"/>
                    <Button Content="📅 Add Class" Classes="action-btn" Command="{Binding AddClassCommand}"/>
                    <Button Content="📊 Export Schedule" Background="#3B82F6" Foreground="White" BorderThickness="0" CornerRadius="8" Padding="12,8" FontWeight="SemiBold" Command="{Binding ExportScheduleCommand}"/>
                </StackPanel>
            </Grid>

            <!-- Schedule Statistics -->
            <Grid ColumnDefinitions="*,*,*,*">
                <Border Grid.Column="0" Classes="card" Margin="0,0,12,0">
                    <StackPanel Spacing="8">
                        <TextBlock Text="This Week Classes" FontSize="14" Foreground="#6B7280"/>
                        <TextBlock Text="{Binding WeeklyClassesCount}" FontSize="24" FontWeight="Bold" Foreground="#3B82F6"/>
                        <TextBlock Text="Scheduled sessions" FontSize="12" Foreground="#3B82F6"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Classes="card" Margin="12,0">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Teaching Hours" FontSize="14" Foreground="#6B7280"/>
                        <TextBlock Text="{Binding WeeklyHours}" FontSize="24" FontWeight="Bold" Foreground="#10B981"/>
                        <TextBlock Text="Total this week" FontSize="12" Foreground="#10B981"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Classes="card" Margin="12,0">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Free Periods" FontSize="14" Foreground="#6B7280"/>
                        <TextBlock Text="{Binding FreePeriodsCount}" FontSize="24" FontWeight="Bold" Foreground="#F59E0B"/>
                        <TextBlock Text="Available slots" FontSize="12" Foreground="#F59E0B"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="3" Classes="card" Margin="12,0,0,0">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Conflicts" FontSize="14" Foreground="#6B7280"/>
                        <TextBlock Text="{Binding ConflictsCount}" FontSize="24" FontWeight="Bold" Foreground="#EF4444"/>
                        <TextBlock Text="Need attention" FontSize="12" Foreground="#EF4444"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Weekly Schedule Grid -->
            <Border Classes="card">
                <StackPanel Spacing="16">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="Weekly Schedule" FontSize="18" FontWeight="SemiBold"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                            <Button Content="🔄 Refresh" Background="#6B7280" Foreground="White" BorderThickness="0" CornerRadius="6" Padding="8,6" Command="{Binding RefreshScheduleCommand}"/>
                            <Button Content="📋 Templates" Background="#8B5CF6" Foreground="White" BorderThickness="0" CornerRadius="6" Padding="8,6" Command="{Binding ManageTemplatesCommand}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Schedule Grid Header -->
                    <Grid ColumnDefinitions="100,*,*,*,*,*,*,*">
                        <Border Grid.Column="0" Background="#F9FAFB" Padding="12,8" CornerRadius="6,0,0,6">
                            <TextBlock Text="Time" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="1" Background="#F9FAFB" Padding="12,8">
                            <TextBlock Text="Monday" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="2" Background="#F9FAFB" Padding="12,8">
                            <TextBlock Text="Tuesday" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="3" Background="#F9FAFB" Padding="12,8">
                            <TextBlock Text="Wednesday" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="4" Background="#F9FAFB" Padding="12,8">
                            <TextBlock Text="Thursday" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="5" Background="#F9FAFB" Padding="12,8">
                            <TextBlock Text="Friday" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="6" Background="#F9FAFB" Padding="12,8">
                            <TextBlock Text="Saturday" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="7" Background="#F9FAFB" Padding="12,8" CornerRadius="0,6,6,0">
                            <TextBlock Text="Sunday" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        </Border>
                    </Grid>

                    <!-- Schedule Grid Content -->
                    <ScrollViewer MaxHeight="600" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding TimeSlots}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:TimeSlotViewModel">
                                    <Grid ColumnDefinitions="100,*,*,*,*,*,*,*">
                                        <!-- Time Column -->
                                        <Border Grid.Column="0" Classes="time-header">
                                            <TextBlock Text="{Binding TimeRange}" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- Monday -->
                                        <Border Grid.Column="1" Classes="schedule-slot" Classes.occupied="{Binding Monday.IsOccupied}">
                                            <ContentControl Content="{Binding Monday}" ContentTemplate="{StaticResource ScheduleSlotTemplate}"/>
                                        </Border>

                                        <!-- Tuesday -->
                                        <Border Grid.Column="2" Classes="schedule-slot" Classes.occupied="{Binding Tuesday.IsOccupied}">
                                            <ContentControl Content="{Binding Tuesday}" ContentTemplate="{StaticResource ScheduleSlotTemplate}"/>
                                        </Border>

                                        <!-- Wednesday -->
                                        <Border Grid.Column="3" Classes="schedule-slot" Classes.occupied="{Binding Wednesday.IsOccupied}">
                                            <ContentControl Content="{Binding Wednesday}" ContentTemplate="{StaticResource ScheduleSlotTemplate}"/>
                                        </Border>

                                        <!-- Thursday -->
                                        <Border Grid.Column="4" Classes="schedule-slot" Classes.occupied="{Binding Thursday.IsOccupied}">
                                            <ContentControl Content="{Binding Thursday}" ContentTemplate="{StaticResource ScheduleSlotTemplate}"/>
                                        </Border>

                                        <!-- Friday -->
                                        <Border Grid.Column="5" Classes="schedule-slot" Classes.occupied="{Binding Friday.IsOccupied}">
                                            <ContentControl Content="{Binding Friday}" ContentTemplate="{StaticResource ScheduleSlotTemplate}"/>
                                        </Border>

                                        <!-- Saturday -->
                                        <Border Grid.Column="6" Classes="schedule-slot" Classes.occupied="{Binding Saturday.IsOccupied}">
                                            <ContentControl Content="{Binding Saturday}" ContentTemplate="{StaticResource ScheduleSlotTemplate}"/>
                                        </Border>

                                        <!-- Sunday -->
                                        <Border Grid.Column="7" Classes="schedule-slot" Classes.occupied="{Binding Sunday.IsOccupied}">
                                            <ContentControl Content="{Binding Sunday}" ContentTemplate="{StaticResource ScheduleSlotTemplate}"/>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <!-- Upcoming Classes and Quick Actions -->
            <Grid ColumnDefinitions="2*,*">
                <!-- Upcoming Classes -->
                <Border Grid.Column="0" Classes="card" Margin="0,0,12,0">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Upcoming Classes" FontSize="18" FontWeight="SemiBold"/>
                        <ScrollViewer MaxHeight="300" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding UpcomingClasses}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="vm:UpcomingClassViewModel">
                                        <Border Background="#F9FAFB" CornerRadius="8" Padding="16" Margin="0,0,0,8">
                                            <Grid ColumnDefinitions="Auto,*,Auto">
                                                <Border Grid.Column="0" Background="{Binding SubjectColor}" Width="4" Height="40" CornerRadius="2" VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="1" Margin="12,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Subject}" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding Grade}" FontSize="12" Foreground="#6B7280"/>
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <TextBlock Text="{Binding Time}" FontSize="12" Foreground="#6B7280"/>
                                                        <TextBlock Text="•" FontSize="12" Foreground="#6B7280"/>
                                                        <TextBlock Text="{Binding Room}" FontSize="12" Foreground="#6B7280"/>
                                                    </StackPanel>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                                                    <Button Content="✏️" Background="#3B82F6" Foreground="White" Padding="6" BorderThickness="0" CornerRadius="4" 
                                                            Command="{Binding $parent[UserControl].((vm:SchedulePlannerViewModel)DataContext).EditClassCommand}" 
                                                            CommandParameter="{Binding}"/>
                                                    <Button Content="📝" Background="#10B981" Foreground="White" Padding="6" BorderThickness="0" CornerRadius="4"
                                                            Command="{Binding $parent[UserControl].((vm:SchedulePlannerViewModel)DataContext).AddNotesCommand}" 
                                                            CommandParameter="{Binding}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <!-- Quick Schedule Actions -->
                <Border Grid.Column="1" Classes="card" Margin="12,0,0,0">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Quick Actions" FontSize="18" FontWeight="SemiBold"/>
                        
                        <!-- Add New Class Form -->
                        <StackPanel Spacing="12">
                            <TextBlock Text="Quick Add Class" FontSize="14" FontWeight="SemiBold"/>
                            <ComboBox SelectedItem="{Binding NewClassSubject}" ItemsSource="{Binding AvailableSubjects}" PlaceholderText="Select Subject" HorizontalAlignment="Stretch"/>
                            <ComboBox SelectedItem="{Binding NewClassGrade}" ItemsSource="{Binding AvailableGrades}" PlaceholderText="Select Grade" HorizontalAlignment="Stretch"/>
                            <ComboBox SelectedItem="{Binding NewClassDay}" ItemsSource="{Binding AvailableDays}" PlaceholderText="Select Day" HorizontalAlignment="Stretch"/>
                            <TimePicker SelectedTime="{Binding NewClassStartTime}" HorizontalAlignment="Stretch"/>
                            <ComboBox SelectedItem="{Binding NewClassDuration}" ItemsSource="{Binding AvailableDurations}" PlaceholderText="Duration" HorizontalAlignment="Stretch"/>
                            <TextBox Text="{Binding NewClassRoom}" Watermark="Room Number" HorizontalAlignment="Stretch"/>
                            <Button Content="➕ Add Class" Classes="action-btn" HorizontalAlignment="Stretch" Command="{Binding QuickAddClassCommand}"/>
                        </StackPanel>

                        <!-- Schedule Templates -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="Schedule Templates" FontSize="14" FontWeight="SemiBold"/>
                            <Button Content="📋 Load Template" Background="#8B5CF6" Foreground="White" BorderThickness="0" CornerRadius="8" Padding="12,8" FontWeight="SemiBold" HorizontalAlignment="Stretch" Command="{Binding LoadTemplateCommand}"/>
                            <Button Content="💾 Save as Template" Background="#F59E0B" Foreground="White" BorderThickness="0" CornerRadius="8" Padding="12,8" FontWeight="SemiBold" HorizontalAlignment="Stretch" Command="{Binding SaveTemplateCommand}"/>
                        </StackPanel>

                        <!-- Schedule Conflicts -->
                        <StackPanel Spacing="8" IsVisible="{Binding HasConflicts}">
                            <TextBlock Text="Schedule Conflicts" FontSize="14" FontWeight="SemiBold" Foreground="#EF4444"/>
                            <ScrollViewer MaxHeight="150" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Conflicts}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="vm:ScheduleConflictViewModel">
                                            <Border Background="#FEF2F2" BorderBrush="#FCA5A5" BorderThickness="1" CornerRadius="6" Padding="8" Margin="0,0,0,4">
                                                <StackPanel Spacing="2">
                                                    <TextBlock Text="{Binding ConflictDescription}" FontSize="11" FontWeight="SemiBold" Foreground="#DC2626"/>
                                                    <TextBlock Text="{Binding Time}" FontSize="10" Foreground="#7F1D1D"/>
                                                    <Button Content="Resolve" Background="#EF4444" Foreground="White" BorderThickness="0" CornerRadius="4" Padding="6,2" FontSize="10" HorizontalAlignment="Left" Command="{Binding ResolveCommand}"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
