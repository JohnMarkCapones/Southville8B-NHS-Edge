<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Southville8BEdgeUI.ViewModels.Teacher"
             xmlns:converters="using:Southville8BEdgeUI.Converters"
             xmlns:ic="using:FluentIcons.Avalonia"
             x:Class="Southville8BEdgeUI.Views.Teacher.NotificationsView"
             x:DataType="vm:NotificationsViewModel"
             Background="{DynamicResource PageBackgroundBrush}">
    <UserControl.Resources>
        <converters:SeverityToBrushConverter x:Key="SeverityToBrush" />
        <converters:CollectionIsEmptyConverter x:Key="CollectionIsEmpty" />
        <converters:CollectionHasItemsConverter x:Key="CollectionHasItems" />
    </UserControl.Resources>

    <UserControl.Styles>
        <!-- Card container -->
        <Style Selector="Border.card">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style Selector="Border.card-header">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
        </Style>
        <Style Selector="TextBlock.title">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>
        <Style Selector="TextBlock.subtitle">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
        </Style>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="{DynamicResource SuccessBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentTextOnAccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style Selector="Button.outline">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <!-- Accessible badge styles -->
        <Style Selector="Border.badge-muted">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="Border.badge-accent">
            <Setter Property="Background" Value="{DynamicResource SuccessBrush}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="TextBlock.badge-text-muted">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        </Style>
        <Style Selector="TextBlock.badge-text-accent">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentTextOnAccentBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Border.severity-icon">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Background" Value="{DynamicResource PageBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="Button.icon-btn">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        <Style Selector="Button.icon-btn:pointerover">
            <Setter Property="Background" Value="{DynamicResource PageBackgroundBrush}"/>
        </Style>
        <!-- Icon color transitions -->
        <Style Selector="Button.icon-btn ic|FluentIcon">
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
        </Style>
        <Style Selector="Button.icon-btn:pointerover ic|FluentIcon">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>
    </UserControl.Styles>

    <Grid>
        <!-- Loading Indicator -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12" IsVisible="{Binding IsLoading}">
            <ProgressBar IsIndeterminate="True" Width="200" Height="4"/>
            <TextBlock Text="Loading notifications..." Classes="subtitle" HorizontalAlignment="Center"/>
        </StackPanel>

        <StackPanel Spacing="16" Margin="16">
            <!-- Error Message -->
            <Border Classes="card" IsVisible="{Binding ErrorMessage, Converter={x:Static converters:StringConverters.IsNotNullOrEmpty}}" Background="{DynamicResource WarningBrush}" Padding="12" Margin="0,0,0,8">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <ic:FluentIcon Icon="ErrorCircle" IconSize="Size16" Foreground="{DynamicResource AccentTextOnAccentBrush}"/>
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource AccentTextOnAccentBrush}" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Page Header -->
            <Border Classes="card-header">
                <Grid ColumnDefinitions="Auto,*,Auto" >
                    <Border Width="32" Height="32" Background="{DynamicResource SuccessBrush}" CornerRadius="6" VerticalAlignment="Center">
                        <ic:FluentIcon Icon="Alert" IconSize="Size16" Foreground="{DynamicResource AccentTextOnAccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center" Margin="12,0,0,0">
                        <TextBlock Text="Notifications" Classes="title"/>
                        <TextBlock Text="Stay updated with your latest activities and alerts" Classes="subtitle"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Margin="12,0,0,0">
                        <Button Content="Refresh" Classes="outline" Command="{Binding RefreshCommand}"/>
                        <Button Content="Mark All Read" Classes="primary" Command="{Binding MarkAllReadCommand}"/>
                        <Button Content="Settings" Classes="outline" Command="{Binding OpenSettingsCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Notifications List -->
            <Border Classes="card" IsVisible="{Binding ShowNotifications}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="600" Padding="0">
                    <ItemsControl ItemsSource="{Binding Items}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16,12">
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <!-- Severity Indicator -->
                                        <Border Classes="severity-icon" Background="{DynamicResource PageBackgroundBrush}" VerticalAlignment="Top">
                                            <Ellipse Width="10" Height="10" Fill="{Binding Severity, Converter={StaticResource SeverityToBrush}}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- Content -->
                                        <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Top" Margin="12,0,0,0">
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding Description}" Foreground="{DynamicResource TextMutedBrush}" FontSize="12" TextWrapping="Wrap"/>
                                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                                <Border Classes="badge-muted">
                                                    <TextBlock Text="{Binding TimeAgo}" Classes="badge-text-muted"/>
                                                </Border>
                                                <Border Classes="badge-accent" IsVisible="{Binding IsNew}">
                                                    <TextBlock Text="New" Classes="badge-text-accent"/>
                                                </Border>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Actions -->
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Top" Margin="12,0,0,0">
                                            <Button Classes="icon-btn" ToolTip.Tip="Mark as read" Command="{Binding $parent[UserControl].((vm:NotificationsViewModel)DataContext).MarkReadCommand}" CommandParameter="{Binding}">
                                                <ic:FluentIcon Icon="Checkmark" IconSize="Size16"/>
                                            </Button>
                                            <Button Classes="icon-btn" ToolTip.Tip="Delete" Command="{Binding $parent[UserControl].((vm:NotificationsViewModel)DataContext).DeleteCommand}" CommandParameter="{Binding}">
                                                <ic:FluentIcon Icon="Delete" IconSize="Size16"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <!-- Empty State -->
            <Border Classes="card" IsVisible="{Binding ShowEmptyState}">
                <StackPanel Spacing="12" Margin="32" HorizontalAlignment="Center">
                    <Border Width="64" Height="64" Background="{DynamicResource PageBackgroundBrush}" CornerRadius="32" HorizontalAlignment="Center" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                        <ic:FluentIcon Icon="Alert" IconSize="Size32" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="No notifications yet" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="When you receive notifications, they'll appear here" FontSize="12" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
