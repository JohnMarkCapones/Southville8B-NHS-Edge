<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Southville8BEdgeUI.ViewModels.Teacher"
             xmlns:converters="using:Southville8BEdgeUI.Converters"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="480"
             x:Class="Southville8BEdgeUI.Views.Teacher.NewChatView"
             x:DataType="vm:NewChatViewModel"
             Background="{DynamicResource PageBackgroundBrush}">
  <UserControl.Resources>
    <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
  </UserControl.Resources>
  <UserControl.Styles>
    <Style Selector="Border.form-card">
      <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="Padding" Value="28"/>
      <Setter Property="Margin" Value="24"/>
    </Style>
    <Style Selector="TextBlock.title">
      <Setter Property="FontSize" Value="24"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    </Style>
    <Style Selector="TextBlock.label">
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
      <Setter Property="Margin" Value="0,14,0,4"/>
    </Style>
    <!-- Input styles (exclude CheckBox because it doesn't support CornerRadius) -->
    <Style Selector="TextBox, ComboBox, ListBox">
      <Setter Property="Margin" Value="0,4,0,8"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="8"/>
      <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    </Style>
    <Style Selector="CheckBox">
      <Setter Property="Margin" Value="0,4,0,8"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="8"/>
      <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    </Style>
    <Style Selector="TextBox:focus-within, ComboBox:focus-within, ListBox:focus-within">
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
      <Setter Property="BorderThickness" Value="2"/>
    </Style>
    <Style Selector="Button.primary">
      <Setter Property="Background" Value="{DynamicResource SuccessBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource AccentTextOnAccentBrush}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="12,8"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <Style Selector="Button.secondary">
      <Setter Property="Background" Value="{DynamicResource TextSecondaryBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource AccentTextOnAccentBrush}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="12,8"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
  </UserControl.Styles>
  <ScrollViewer>
    <Border Classes="form-card">
      <StackPanel>
        <TextBlock Text="Start New Conversation" Classes="title"/>
        <TextBlock Text="Select a teacher or admin to start a conversation." Foreground="{DynamicResource TextMutedBrush}" Margin="0,4,0,16"/>

        <TextBlock Text="Select User" Classes="label"/>
        <TextBox Text="{Binding UserSearch}" Watermark="Search teachers or admins..."/>

        <!-- Loading Indicator -->
        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" Margin="0,8" IsVisible="{Binding IsLoadingUsers}">
          <TextBlock Text="Loading users..." Foreground="{DynamicResource TextMutedBrush}"/>
        </StackPanel>

        <!-- User Selection List -->
        <ListBox ItemsSource="{Binding FilteredUsers}" SelectedItem="{Binding SelectedUser}" Height="200" Margin="0,4,0,8" IsVisible="{Binding IsLoadingUsers, Converter={StaticResource InverseBoolConverter}}">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <StackPanel Orientation="Horizontal" Spacing="8" Margin="8">
                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="{Binding Role}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
              </StackPanel>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>

        <TextBlock Text="First Message (optional)" Classes="label"/>
        <TextBox Text="{Binding FirstMessage}" AcceptsReturn="True" Height="140" TextWrapping="Wrap" Watermark="Type a greeting or leave empty"/>

        <CheckBox Content="Mark as important" IsChecked="{Binding MarkAsImportant}"/>

        <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,24,0,0" HorizontalAlignment="Left">
          <Button Content="Create Chat" Classes="primary" Command="{Binding CreateCommand}"/>
          <Button Content="Cancel" Classes="secondary" Command="{Binding CancelCommand}"/>
        </StackPanel>
      </StackPanel>
    </Border>
  </ScrollViewer>
</UserControl>
