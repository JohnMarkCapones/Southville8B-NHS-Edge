<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Southville8BEdgeUI.ViewModels.Teacher"
             xmlns:converters="using:Southville8BEdgeUI.Converters"
             mc:Ignorable="d" d:DesignWidth="1400" d:DesignHeight="900"
             x:Class="Southville8BEdgeUI.Views.Teacher.MessagingView"
             x:DataType="vm:MessagingViewModel"
             Background="#F9FAFB">

    <UserControl.Resources>
        <converters:BoolToStringConverter x:Key="BoolToStringConverter"/>
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="Border.card">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BoxShadow" Value="0 2 8 0 #10000000"/>
        </Style>
        <Style Selector="Border.chat-item">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0"/>
        </Style>
        <Style Selector="Border.chat-item:pointerover">
            <Setter Property="Background" Value="#F9FAFB"/>
        </Style>
        <Style Selector="Border.chat-item.selected">
            <Setter Property="Background" Value="#EEF2FF"/>
        </Style>
        <Style Selector="Border.message-bubble">
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="MaxWidth" Value="300"/>
        </Style>
        <Style Selector="Border.message-bubble.sent">
            <Setter Property="Background" Value="#10B981"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>
        <Style Selector="Border.message-bubble.received">
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>
    </UserControl.Styles>

    <Grid ColumnDefinitions="320,*,280">
        <!-- Contacts/Conversations List -->
        <Border Grid.Column="0" Classes="card" Margin="20,20,10,20">
            <StackPanel>
                <!-- Header -->
                <Border Padding="20,16" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="Messages" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="✏️" Background="#10B981" Foreground="White" BorderThickness="0" CornerRadius="6" Padding="8" Command="{Binding NewMessageCommand}"/>
                    </Grid>
                </Border>

                <!-- Search -->
                <Border Padding="16,12">
                    <TextBox Text="{Binding SearchText}" Watermark="Search conversations..." CornerRadius="8"/>
                </Border>

                <!-- Conversation List -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Conversations}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:ConversationViewModel">
                                <Border Classes="chat-item" Classes.selected="{Binding IsSelected}">
                                    <Grid ColumnDefinitions="48,*,Auto" RowDefinitions="Auto,Auto">
                                        <!-- Avatar -->
                                        <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="2" Width="40" Height="40" CornerRadius="20" Background="#E5E7EB" Margin="0,0,12,0">
                                            <TextBlock Text="{Binding ContactInitials}" FontSize="14" FontWeight="Bold" Foreground="#6B7280" 
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- Contact Name -->
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ContactName}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Top"/>
                                        
                                        <!-- Last Message -->
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding LastMessage}" FontSize="12" Foreground="#6B7280" TextTrimming="CharacterEllipsis"/>

                                        <!-- Time and Badge -->
                                        <StackPanel Grid.Row="0" Grid.Column="2" Spacing="4" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding LastMessageTime}" FontSize="11" Foreground="#9CA3AF"/>
                                            <Border Background="#EF4444" CornerRadius="10" Padding="6,2" IsVisible="{Binding HasUnreadMessages}">
                                                <TextBlock Text="{Binding UnreadCount}" FontSize="10" Foreground="White" FontWeight="Bold"/>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>
        </Border>

        <!-- Chat Area -->
        <Border Grid.Column="1" Classes="card" Margin="10,20">
            <Grid RowDefinitions="Auto,*,Auto">
                <!-- Chat Header -->
                <Border Grid.Row="0" Padding="20,16" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="48,*,Auto" IsVisible="{Binding SelectedConversation, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20" Background="#E5E7EB" Margin="0,0,12,0">
                            <TextBlock Text="{Binding SelectedConversation.ContactInitials}" FontSize="14" FontWeight="Bold" Foreground="#6B7280" 
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding SelectedConversation.ContactName}" FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding SelectedConversation.ContactRole}" FontSize="12" Foreground="#6B7280"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                            <Button Content="📞" Background="#10B981" Foreground="White" BorderThickness="0" CornerRadius="6" Padding="8" Command="{Binding StartCallCommand}"/>
                            <Button Content="📹" Background="#3B82F6" Foreground="White" BorderThickness="0" CornerRadius="6" Padding="8" Command="{Binding StartVideoCallCommand}"/>
                            <Button Content="ℹ️" Background="#6B7280" Foreground="White" BorderThickness="0" CornerRadius="6" Padding="8" Command="{Binding ShowContactInfoCommand}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Messages Area -->
                <Grid Grid.Row="1">
                    <!-- Messages List when conversation is selected -->
                    <ScrollViewer Padding="20" VerticalScrollBarVisibility="Auto" Name="MessagesScrollViewer" 
                                  IsVisible="{Binding SelectedConversation, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <ItemsControl ItemsSource="{Binding SelectedConversation.Messages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:MessageViewModel">
                                    <StackPanel Margin="0,4">
                                        <!-- Message Date Separator -->
                                        <TextBlock Text="{Binding DateSeparator}" FontSize="12" Foreground="#9CA3AF" HorizontalAlignment="Center" 
                                                   Margin="0,8,0,4" IsVisible="{Binding ShowDateSeparator}"/>
                                        
                                        <!-- Message Bubble -->
                                        <Border Classes="message-bubble" Classes.sent="{Binding IsSent}" Classes.received="{Binding !IsSent}">
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="{Binding Content}" FontSize="14" 
                                                           Foreground="{Binding IsSent, Converter={StaticResource BoolToStringConverter}, ConverterParameter='White|Black'}" 
                                                           TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding Timestamp}" FontSize="11" 
                                                           Foreground="{Binding IsSent, Converter={StaticResource BoolToStringConverter}, ConverterParameter='#E5E7EB|#9CA3AF'}" 
                                                           HorizontalAlignment="Right"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- No Conversation Selected -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16" 
                                IsVisible="{Binding SelectedConversation, Converter={x:Static ObjectConverters.IsNull}}">
                        <TextBlock Text="💬" FontSize="64" HorizontalAlignment="Center" Opacity="0.3"/>
                        <TextBlock Text="Select a conversation to start messaging" FontSize="16" Foreground="#6B7280" HorizontalAlignment="Center"/>
                        <Button Content="Start New Conversation" Background="#10B981" Foreground="White" BorderThickness="0" CornerRadius="8" Padding="12,8" FontWeight="SemiBold" Command="{Binding NewMessageCommand}"/>
                    </StackPanel>
                </Grid>

                <!-- Message Input -->
                <Border Grid.Row="2" Padding="20,16" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" IsVisible="{Binding SelectedConversation, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <Grid ColumnDefinitions="*,Auto,Auto">
                        <TextBox Grid.Column="0" Text="{Binding NewMessageText}" Watermark="Type a message..." AcceptsReturn="True" MaxLines="4" CornerRadius="8"/>
                        <Button Grid.Column="1" Content="📎" Background="#6B7280" Foreground="White" BorderThickness="0" CornerRadius="6" Padding="8" Margin="8,0" Command="{Binding AttachFileCommand}"/>
                        <Button Grid.Column="2" Content="Send" Background="#10B981" Foreground="White" BorderThickness="0" CornerRadius="6" Padding="16,8" FontWeight="SemiBold" Command="{Binding SendMessageCommand}"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Contact Info/Actions Panel -->
        <Border Grid.Column="2" Classes="card" Margin="10,20,20,20">
            <Border Padding="20">
                <StackPanel Spacing="20">
                    <TextBlock Text="Quick Actions" FontSize="18" FontWeight="SemiBold"/>

                    <!-- Quick Message Templates -->
                    <StackPanel Spacing="12">
                        <TextBlock Text="Quick Messages" FontSize="14" FontWeight="SemiBold"/>
                        <Button Content="📋 Attendance Reminder" Background="#3B82F6" Foreground="White" BorderThickness="0" CornerRadius="8" Padding="12,8" FontWeight="SemiBold" HorizontalAlignment="Stretch" Command="{Binding SendAttendanceReminderCommand}"/>
                        <Button Content="📚 Assignment Due" Background="#F59E0B" Foreground="White" BorderThickness="0" CornerRadius="8" Padding="12,8" FontWeight="SemiBold" HorizontalAlignment="Stretch" Command="{Binding SendAssignmentReminderCommand}"/>
                        <Button Content="🎉 Good Job!" Background="#10B981" Foreground="White" BorderThickness="0" CornerRadius="8" Padding="12,8" FontWeight="SemiBold" HorizontalAlignment="Stretch" Command="{Binding SendPraiseMessageCommand}"/>
                        <Button Content="📞 Parent Contact" Background="#8B5CF6" Foreground="White" BorderThickness="0" CornerRadius="8" Padding="12,8" FontWeight="SemiBold" HorizontalAlignment="Stretch" Command="{Binding ContactParentCommand}"/>
                    </StackPanel>

                    <!-- Recent Contacts -->
                    <StackPanel Spacing="8">
                        <TextBlock Text="Recent Contacts" FontSize="14" FontWeight="SemiBold"/>
                        <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding RecentContacts}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="vm:ContactViewModel">
                                        <Border Padding="8" CornerRadius="6" Margin="0,0,0,4">
                                            <Grid ColumnDefinitions="32,*,Auto">
                                                <Border Grid.Column="0" Width="28" Height="28" CornerRadius="14" Background="#E5E7EB" Margin="0,0,8,0">
                                                    <TextBlock Text="{Binding Initials}" FontSize="10" FontWeight="Bold" Foreground="#6B7280" 
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding Role}" FontSize="10" Foreground="#6B7280"/>
                                                </StackPanel>
                                                <Button Grid.Column="2" Content="💬" Background="#10B981" Foreground="White" BorderThickness="0" CornerRadius="4" Padding="4" 
                                                        Command="{Binding $parent[UserControl].((vm:MessagingViewModel)DataContext).StartConversationCommand}" 
                                                        CommandParameter="{Binding}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>

                    <!-- Message Statistics -->
                    <StackPanel Spacing="8">
                        <TextBlock Text="Message Stats" FontSize="14" FontWeight="SemiBold"/>
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Today:" FontSize="12"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding TodayMessagesCount}" FontSize="12" FontWeight="Bold"/>
                            
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="This Week:" FontSize="12"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding WeekMessagesCount}" FontSize="12" FontWeight="Bold"/>
                            
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Unread:" FontSize="12"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding UnreadMessagesCount}" FontSize="12" FontWeight="Bold" Foreground="#EF4444"/>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
