<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Southville8BEdgeUI.ViewModels.Teacher"
             mc:Ignorable="d" d:DesignWidth="1400" d:DesignHeight="900"
             x:Class="Southville8BEdgeUI.Views.Teacher.GradeEntryView"
             x:DataType="vm:GradeEntryViewModel"
             Background="#F9FAFB">

    <UserControl.Styles>
        <Style Selector="Border.card">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="BoxShadow" Value="0 2 8 0 #10000000"/>
        </Style>
        <Style Selector="Button.action-btn">
            <Setter Property="Background" Value="#10B981"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.secondary-btn">
            <Setter Property="Background" Value="#6B7280"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer>
        <StackPanel Margin="40" Spacing="24">
            <!-- Header -->
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Grade Entry System" FontSize="28" FontWeight="Bold"/>
                    <TextBlock Text="Manage student grades and assessments" FontSize="14" Foreground="#6B7280"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Button Content="📊 Export Grades" Classes="secondary-btn" Command="{Binding ExportGradesCommand}"/>
                    <Button Content="💾 Save All" Classes="action-btn" Command="{Binding SaveAllGradesCommand}"/>
                </StackPanel>
            </Grid>

            <!-- Quick Stats -->
            <Grid ColumnDefinitions="*,*,*,*">
                <Border Grid.Column="0" Classes="card" Margin="0,0,12,0">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Pending Grades" FontSize="14" Foreground="#6B7280"/>
                        <TextBlock Text="{Binding PendingGradesCount}" FontSize="24" FontWeight="Bold" Foreground="#EF4444"/>
                        <TextBlock Text="Require attention" FontSize="12" Foreground="#EF4444"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Classes="card" Margin="12,0">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Completed Today" FontSize="14" Foreground="#6B7280"/>
                        <TextBlock Text="{Binding CompletedTodayCount}" FontSize="24" FontWeight="Bold" Foreground="#10B981"/>
                        <TextBlock Text="Grades entered" FontSize="12" Foreground="#10B981"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Classes="card" Margin="12,0">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Class Average" FontSize="14" Foreground="#6B7280"/>
                        <TextBlock Text="{Binding ClassAverageGrade, StringFormat={}{0:F1}%}" FontSize="24" FontWeight="Bold" Foreground="#3B82F6"/>
                        <TextBlock Text="Overall performance" FontSize="12" Foreground="#3B82F6"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="3" Classes="card" Margin="12,0,0,0">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Assignments Due" FontSize="14" Foreground="#6B7280"/>
                        <TextBlock Text="{Binding AssignmentsDueCount}" FontSize="24" FontWeight="Bold" Foreground="#F59E0B"/>
                        <TextBlock Text="This week" FontSize="12" Foreground="#F59E0B"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Grade Entry Section -->
            <Grid ColumnDefinitions="*,300">
                <!-- Grade Entry Table -->
                <Border Grid.Column="0" Classes="card" Margin="0,0,12,0">
                    <StackPanel Spacing="16">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Grade Entry" FontSize="18" FontWeight="SemiBold"/>
                            <ComboBox Grid.Column="1" SelectedItem="{Binding SelectedClass}" ItemsSource="{Binding Classes}" MinWidth="200"/>
                        </Grid>
                        
                        <!-- Grade Entry Header -->
                        <Border Background="#F9FAFB" CornerRadius="8,8,0,0" Padding="12,8">
                            <Grid ColumnDefinitions="200,100,100,100,100,*">
                                <TextBlock Grid.Column="0" Text="Student Name" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="1" Text="Quiz" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="Assignment" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="Exam" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="4" Text="Final" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="5" Text="Actions" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Grade Entry Rows -->
                        <ScrollViewer MaxHeight="400" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding StudentGrades}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="vm:StudentGradeViewModel">
                                        <Grid ColumnDefinitions="200,100,100,100,100,*" Margin="0,0,0,8" MinHeight="40">
                                            <Border Grid.Column="0" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="4" Padding="8">
                                                <TextBlock Text="{Binding StudentName}" VerticalAlignment="Center"/>
                                            </Border>
                                            <Border Grid.Column="1" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="4" Padding="4" Margin="4,0">
                                                <TextBox Text="{Binding QuizGrade}" HorizontalAlignment="Center" BorderThickness="0" Background="Transparent"/>
                                            </Border>
                                            <Border Grid.Column="2" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="4" Padding="4" Margin="4,0">
                                                <TextBox Text="{Binding AssignmentGrade}" HorizontalAlignment="Center" BorderThickness="0" Background="Transparent"/>
                                            </Border>
                                            <Border Grid.Column="3" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="4" Padding="4" Margin="4,0">
                                                <TextBox Text="{Binding ExamGrade}" HorizontalAlignment="Center" BorderThickness="0" Background="Transparent"/>
                                            </Border>
                                            <Border Grid.Column="4" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="4" Padding="4" Margin="4,0">
                                                <TextBlock Text="{Binding FinalGrade, StringFormat={}{0:F1}}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="{Binding GradeColor}"/>
                                            </Border>
                                            <StackPanel Grid.Column="5" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="4">
                                                <Button Content="💾" Background="#10B981" Foreground="White" Padding="4" BorderThickness="0" CornerRadius="4" Command="{Binding SaveGradeCommand}"/>
                                                <Button Content="📝" Background="#3B82F6" Foreground="White" Padding="4" BorderThickness="0" CornerRadius="4" Command="{Binding EditNotesCommand}"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <!-- Grade Summary Panel -->
                <Border Grid.Column="1" Classes="card" Margin="12,0,0,0">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Grade Summary" FontSize="18" FontWeight="SemiBold"/>
                        
                        <!-- Grade Distribution Chart -->
                        <StackPanel Spacing="12">
                            <TextBlock Text="Grade Distribution" FontSize="14" FontWeight="SemiBold"/>
                            <ItemsControl ItemsSource="{Binding GradeDistribution}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="vm:GradeDistributionItemViewModel">
                                        <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,8">
                                            <TextBlock Grid.Column="0" Text="{Binding Grade}" FontWeight="SemiBold" MinWidth="30"/>
                                            <ProgressBar Grid.Column="1" Value="{Binding Percentage}" Maximum="100" Height="20" CornerRadius="10" Foreground="{Binding Color}" Margin="8,0"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Count}" FontWeight="SemiBold" MinWidth="30" HorizontalAlignment="Right"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- Recent Grade Entries -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="Recent Entries" FontSize="14" FontWeight="SemiBold"/>
                            <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding RecentGradeEntries}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="vm:RecentGradeEntryViewModel">
                                            <Border Background="#F9FAFB" CornerRadius="8" Padding="8" Margin="0,0,0,4">
                                                <StackPanel Spacing="2">
                                                    <TextBlock Text="{Binding StudentName}" FontWeight="SemiBold" FontSize="12"/>
                                                    <TextBlock Text="{Binding AssignmentName}" FontSize="11" Foreground="#6B7280"/>
                                                    <Grid ColumnDefinitions="*,Auto">
                                                        <TextBlock Grid.Column="0" Text="{Binding Grade}" FontSize="14" FontWeight="Bold" Foreground="{Binding GradeColor}"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding Timestamp}" FontSize="10" Foreground="#9CA3AF"/>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>