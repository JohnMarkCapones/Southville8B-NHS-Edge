<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Southville8BEdgeUI.ViewModels.Teacher"
             xmlns:ic="using:FluentIcons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="1400" d:DesignHeight="900"
             x:Class="Southville8BEdgeUI.Views.Teacher.GradeEntryView"
             x:DataType="vm:GradeEntryViewModel"
             Background="{DynamicResource PageBackgroundBrush}">

    <UserControl.Styles>
        <!-- Base Card Style -->
        <Style Selector="Border.card">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="BoxShadow" Value="0 2 8 0 #10000000"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>

        <!-- Responsive Card Styles -->
        <Style Selector="Border.card.mobile">
            <Setter Property="Padding" Value="16"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style Selector="Border.card.tablet">
            <Setter Property="Padding" Value="18"/>
            <Setter Property="CornerRadius" Value="10"/>
        </Style>

        <!-- Action Button Styles (Primary) -->
        <Style Selector="Button.action-btn">
            <Setter Property="Background" Value="{DynamicResource SuccessBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentTextOnAccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.action-btn:pointerover">
            <Setter Property="RenderTransform" Value="scale(1.02)"/>
        </Style>
        <Style Selector="Button.action-btn:pressed">
            <Setter Property="RenderTransform" Value="scale(0.97)"/>
        </Style>

        <!-- Secondary Button Styles -->
        <Style Selector="Button.secondary-btn">
            <Setter Property="Background" Value="{DynamicResource InfoBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentTextOnAccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.secondary-btn:pointerover">
            <Setter Property="RenderTransform" Value="scale(1.02)"/>
        </Style>
        <Style Selector="Button.secondary-btn:pressed">
            <Setter Property="RenderTransform" Value="scale(0.97)"/>
        </Style>

        <Style Selector="Button.tertiary-btn">
            <Setter Property="Background" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentTextOnAccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.tertiary-btn:pointerover">
            <Setter Property="RenderTransform" Value="scale(1.02)"/>
        </Style>
        <Style Selector="Button.tertiary-btn:pressed">
            <Setter Property="RenderTransform" Value="scale(0.97)"/>
        </Style>

        <!-- Typography Styles -->
        <Style Selector="TextBlock.header">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>
        <Style Selector="TextBlock.subtitle">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
        </Style>

        <Style Selector="TextBlock.header.mobile">
            <Setter Property="FontSize" Value="22"/>
        </Style>

        <Style Selector="TextBlock.header.tablet">
            <Setter Property="FontSize" Value="24"/>
        </Style>

        <Style Selector="TextBlock.subtitle.mobile">
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- Input Styles -->
        <Style Selector="ComboBox, TextBox">
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>
        <Style Selector="ComboBox:focus-within, TextBox:focus-within">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>

        <!-- Grade Table Styles -->
        <Style Selector="Border.table-cell">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="8"/>
        </Style>

        <!-- Header row background -->
        <Style Selector="Border.grade-header">
            <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>

        <!-- Loading indicator -->
        <Style Selector="Border.loading">
            <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
        </Style>

        <!-- Enhanced Responsive Layout Classes -->
        <Style Selector="StackPanel.main-content">
            <Setter Property="Margin" Value="40"/>
            <Setter Property="Spacing" Value="24"/>
            <Setter Property="Transitions">
                <Transitions>
                    <ThicknessTransition Property="Margin" Duration="0:0:0.3"/>
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="StackPanel.main-content.tablet">
            <Setter Property="Margin" Value="24"/>
            <Setter Property="Spacing" Value="20"/>
        </Style>

        <Style Selector="StackPanel.main-content.mobile">
            <Setter Property="Margin" Value="16"/>
            <Setter Property="Spacing" Value="16"/>
        </Style>
        
        <!-- Enhanced Card Transitions -->
        <Style Selector="Border.card">
            <Setter Property="Transitions">
                <Transitions>
                    <ThicknessTransition Property="Margin" Duration="0:0:0.3"/>
                    <ThicknessTransition Property="Padding" Duration="0:0:0.3"/>
                </Transitions>
            </Setter>
        </Style>

        <!-- Responsive Input Fields -->
        <Style Selector="Grid.responsive-inputs">
            <!-- ColumnDefinitions and RowDefinitions cannot be set in styles in Avalonia -->
        </Style>
        
        <!-- Mobile responsive - stack fields vertically -->
        <Style Selector="Grid.responsive-inputs.mobile">
            <!-- ColumnDefinitions and RowDefinitions cannot be set in styles in Avalonia -->
        </Style>
        
        <!-- Mobile: GWA field takes full width -->
        <Style Selector="Grid.responsive-inputs.mobile StackPanel:first-child">
            <Setter Property="Grid.Column" Value="0"/>
            <Setter Property="Grid.Row" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        
        <!-- Mobile: Honor Status field takes full width -->
        <Style Selector="Grid.responsive-inputs.mobile StackPanel:nth-child(2)">
            <Setter Property="Grid.Column" Value="0"/>
            <Setter Property="Grid.Row" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        
        <!-- Mobile: Remarks field takes full width -->
        <Style Selector="Grid.responsive-inputs.mobile StackPanel:nth-child(3)">
            <Setter Property="Grid.Column" Value="0"/>
            <Setter Property="Grid.Row" Value="2"/>
            <Setter Property="Margin" Value="0"/>
        </Style>

        <!-- Filter Grid Responsive Styles -->
        <Style Selector="Grid.filter-grid">
            <!-- ColumnDefinitions cannot be set in styles in Avalonia -->
        </Style>
        
        <!-- Mobile: Stack filter elements vertically -->
        <Style Selector="Grid.filter-grid.mobile">
            <!-- ColumnDefinitions and RowDefinitions cannot be set in styles in Avalonia -->
        </Style>
        
        <!-- Mobile: Grading Period Row -->
        <Style Selector="Grid.filter-grid.mobile TextBlock:first-child">
            <Setter Property="Grid.Column" Value="0"/>
            <Setter Property="Grid.Row" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style Selector="Grid.filter-grid.mobile ComboBox:first-child">
            <Setter Property="Grid.Column" Value="0"/>
            <Setter Property="Grid.Row" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>
        
        <!-- Mobile: School Year Row -->
        <Style Selector="Grid.filter-grid.mobile TextBlock:nth-child(3)">
            <Setter Property="Grid.Column" Value="0"/>
            <Setter Property="Grid.Row" Value="2"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style Selector="Grid.filter-grid.mobile ComboBox:nth-child(4)">
            <Setter Property="Grid.Column" Value="0"/>
            <Setter Property="Grid.Row" Value="3"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>
        
        <!-- Mobile: Section Info Row -->
        <Style Selector="Grid.filter-grid.mobile StackPanel">
            <Setter Property="Grid.Column" Value="0"/>
            <Setter Property="Grid.Row" Value="4"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Margin" Value="0"/>
        </Style>

        <!-- Header Grid Responsive Styles -->
        <Style Selector="Grid.header-grid">
            <!-- ColumnDefinitions cannot be set in styles in Avalonia -->
        </Style>
        
        <!-- Mobile: Stack header elements vertically -->
        <Style Selector="Grid.header-grid.mobile">
            <!-- ColumnDefinitions and RowDefinitions cannot be set in styles in Avalonia -->
        </Style>
        
        <!-- Mobile: Student info takes full width -->
        <Style Selector="Grid.header-grid.mobile StackPanel:first-child">
            <Setter Property="Grid.Column" Value="0"/>
            <Setter Property="Grid.Row" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        
        <!-- Mobile: Action buttons take full width -->
        <Style Selector="Grid.header-grid.mobile StackPanel.action-buttons">
            <Setter Property="Grid.Column" Value="0"/>
            <Setter Property="Grid.Row" Value="1"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Margin" Value="0"/>
        </Style>
        
        <!-- Mobile: Buttons stack horizontally with equal width -->
        <Style Selector="Grid.header-grid.mobile Button.save-btn">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        
        <Style Selector="Grid.header-grid.mobile Button.delete-btn">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer x:Name="MainScrollViewer" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel x:Name="MainStackPanel" Classes="main-content">
            <!-- Header -->
            <Grid x:Name="HeaderGrid" ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="GWA Entry System" Classes="header"/>
                    <TextBlock Text="Enter final GWA for students in your advisory section" Classes="subtitle"/>
                </StackPanel>
                <Button Grid.Column="1" Classes="action-btn" Command="{Binding SaveAllGradesCommand}" IsEnabled="{Binding HasUnsavedChanges}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <ic:FluentIcon Icon="Save" IconSize="Size16"/>
                        <TextBlock Text="Save All Changes"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Filters -->
            <Border Classes="card">
                <Grid x:Name="FilterGrid" ColumnDefinitions="Auto,*,Auto,*,*,Auto" Classes="filter-grid">
                    <TextBlock Grid.Column="0" Text="Grading Period:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox Grid.Column="1" ItemsSource="{Binding GradingPeriods}" SelectedItem="{Binding SelectedGradingPeriod}" MinWidth="120"/>
                    <TextBlock Grid.Column="2" Text="School Year:" VerticalAlignment="Center" Margin="16,0,8,0"/>
                    <ComboBox Grid.Column="3" ItemsSource="{Binding SchoolYears}" SelectedItem="{Binding SelectedSchoolYear}" MinWidth="120"/>
                    <StackPanel Grid.Column="5" VerticalAlignment="Center" HorizontalAlignment="Right">
                        <TextBlock Text="{Binding SectionName}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" TextAlignment="Right"/>
                        <TextBlock Text="{Binding GradeLevel}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}" TextAlignment="Right"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Loading Indicator -->
            <Border Classes="loading" IsVisible="{Binding IsLoading}">
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                    <ic:FluentIcon Icon="ArrowClockwise" IconSize="Size16" Foreground="{DynamicResource AccentBrush}"/>
                    <TextBlock Text="Loading students..." Foreground="{DynamicResource TextPrimaryBrush}"/>
                </StackPanel>
            </Border>

            <!-- Grade Entry Table -->
            <Border Classes="card" IsVisible="{Binding !IsLoading}">
                <StackPanel Spacing="16">
                    <TextBlock Text="Student GWA Entry" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    
                    <!-- Grade Entry Rows -->
                    <ScrollViewer x:Name="GradeEntriesContainer" MaxHeight="600" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding StudentGrades}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Spacing="12"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:StudentGradeViewModel">
                                    <Border Classes="card" Padding="16">
                                        <StackPanel Spacing="12">
                                            <!-- Header Row -->
                                            <Grid ColumnDefinitions="Auto,*,Auto" Classes="header-grid">
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding StudentNumber}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                                                    <TextBlock Text="{Binding StudentName}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                </StackPanel>
                                                
                                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" Classes="action-buttons">
                                                    <Button Background="{DynamicResource SuccessBrush}" Foreground="{DynamicResource AccentTextOnAccentBrush}" 
                                                            Padding="8,4" BorderThickness="0" CornerRadius="4" ToolTip.Tip="Save Grade" 
                                                            Command="{Binding SaveGradeCommand}" IsVisible="{Binding IsDirty}" Classes="save-btn">
                                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                                            <ic:FluentIcon Icon="Save" IconSize="Size16"/>
                                                            <TextBlock Text="Save"/>
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Background="{DynamicResource DangerBrush}" Foreground="{DynamicResource AccentTextOnAccentBrush}" 
                                                            Padding="8,4" BorderThickness="0" CornerRadius="4" ToolTip.Tip="Delete Entry" 
                                                            Command="{Binding DeleteGradeCommand}" IsVisible="{Binding GwaId, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" Classes="delete-btn">
                                                        <ic:FluentIcon Icon="Delete" IconSize="Size16"/>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                            
                                            <!-- Responsive Input Fields -->
                                            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" Classes="responsive-inputs">
                                                <!-- GWA Field -->
                                                <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,8,0">
                                                    <TextBlock Text="GWA" FontSize="12" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,4"/>
                                                    <TextBox Text="{Binding Gwa}" Watermark="50.00-100.00" TextAlignment="Center"/>
                                                </StackPanel>
                                                
                                                <!-- Honor Status Field -->
                                                <StackPanel Grid.Column="1" Grid.Row="0" Margin="8,0,0,0">
                                                    <TextBlock Text="Honor Status" FontSize="12" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,4"/>
                                                    <ComboBox SelectedItem="{Binding HonorStatus}" ItemsSource="{Binding HonorStatusOptions}"/>
                                                </StackPanel>
                                                
                                                <!-- Remarks Field - Full Width -->
                                                <StackPanel Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1" Margin="0,12,0,0">
                                                    <TextBlock Text="Remarks" FontSize="12" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,4"/>
                                                    <TextBox Text="{Binding Remarks}" Watermark="Optional remarks"/>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>