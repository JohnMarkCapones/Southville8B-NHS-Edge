<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Southville8BEdgeUI.ViewModels.Teacher"
             x:Class="Southville8BEdgeUI.Views.Teacher.ProfileView"
             x:DataType="vm:ProfileViewModel"
             Background="{DynamicResource PageBackgroundBrush}"
             SizeChanged="OnSizeChanged">
    <UserControl.Styles>
        <!-- TYPOGRAPHY -->
        <Style Selector="TextBlock.page-title">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>
        <Style Selector="TextBlock.subtle">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
        </Style>
        <Style Selector="TextBlock.meta">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        </Style>
        <Style Selector="TextBlock.section-header">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>
        <Style Selector="TextBlock.section-header.tablet">
            <Setter Property="FontSize" Value="16"/>
        </Style>
        <Style Selector="TextBlock.section-header.mobile">
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style Selector="TextBlock.label">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
        </Style>

        <!-- CARDS -->
        <Style Selector="Border.card">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="BoxShadow" Value="0 2 8 0 #10000000"/>
        </Style>
        <Style Selector="Border.card.tablet">
            <Setter Property="Padding" Value="16"/>
        </Style>
        <Style Selector="Border.card.mobile">
            <Setter Property="Padding" Value="12"/>
        </Style>

        <!-- AVATAR -->
        <Style Selector="Border.avatar">
            <Setter Property="Background" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Width" Value="64"/>
            <Setter Property="Height" Value="64"/>
            <Setter Property="CornerRadius" Value="32"/>
        </Style>
        <Style Selector="TextBlock.avatar-initials">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
        </Style>

        <!-- BADGES -->
        <Style Selector="Border.badge-success">
            <Setter Property="Background" Value="{DynamicResource SuccessBrush}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="6,2"/>
        </Style>
        <Style Selector="Border.badge-warning">
            <Setter Property="Background" Value="{DynamicResource WarningBrush}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="6,2"/>
        </Style>
        <Style Selector="TextBlock.badge-text">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentTextOnAccentBrush}"/>
        </Style>

        <!-- INPUTS -->
        <Style Selector="TextBox, ComboBox">
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>
        <Style Selector="TextBox:focus, ComboBox:focus">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
        </Style>
        <!-- Read-only TextBox styling -->
        <Style Selector="TextBox[IsReadOnly=True]">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="IsEnabled" Value="True"/>
            <Setter Property="Cursor" Value="Arrow"/>
        </Style>
        <Style Selector="TextBox[IsReadOnly=True]:pointerover">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="TextBox[IsReadOnly=True]:focus">
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>

        <!-- BUTTONS -->
        <Style Selector="Button.outline">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,8"/>
        </Style>
        <Style Selector="Button.outline:pointerover">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="{DynamicResource SuccessBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentTextOnAccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.primary:pointerover">
            <Setter Property="Background" Value="{DynamicResource SuccessBrush}"/>
        </Style>
        <Style Selector="Button.danger">
            <Setter Property="Background" Value="{DynamicResource DangerBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentTextOnAccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.danger:pointerover">
            <Setter Property="Background" Value="{DynamicResource DangerBrush}"/>
        </Style>

        <!-- LAYOUT -->
        <Style Selector="StackPanel.main-content">
            <Setter Property="Spacing" Value="24"/>
        </Style>
        <Style Selector="StackPanel.main-content.tablet">
            <Setter Property="Spacing" Value="16"/>
        </Style>
        <Style Selector="StackPanel.main-content.mobile">
            <Setter Property="Spacing" Value="12"/>
        </Style>
    </UserControl.Styles>

    <Grid>
        <!-- Loading Indicator -->
        <Border IsVisible="{Binding IsLoading}" Background="#80000000" ZIndex="999">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200"/>
                <TextBlock Text="Loading profile..." Margin="0,8,0,0" Foreground="White"/>
            </StackPanel>
        </Border>
        
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="16" Margin="16" Classes="main-content">
                <!-- Page Header -->
                <Border Classes="card">
                    <Grid ColumnDefinitions="Auto,*">
                        <!-- Profile Avatar -->
                        <Border Classes="avatar" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Initials}" Classes="avatar-initials" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <!-- Profile Info -->
                        <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center" Margin="16,0,0,0">
                            <TextBlock Text="{Binding FullName}" Classes="page-title"/>
                            <TextBlock Text="{Binding SubjectSpecialization}" Classes="subtle"/>
                            <TextBlock Text="{Binding Email}" Classes="meta"/>
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                <Border Classes="badge-success">
                                    <TextBlock Text="Active" Classes="badge-text"/>
                                </Border>
                                <Border Classes="badge-warning">
                                    <TextBlock Text="Verified" Classes="badge-text"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Content Grid -->
                <Grid ColumnDefinitions="*,*">
                    <!-- Left Column -->
                    <StackPanel Grid.Column="0" Spacing="16">
                        <!-- Personal Information -->
                        <Border Classes="card">
                            <StackPanel Spacing="16">
                                <TextBlock Text="Personal Information" Classes="section-header"/>
                                <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="120,*">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Full Name" Classes="label" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding FullName}" IsReadOnly="True" Margin="12,0,0,12"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Email" Classes="label" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Email}" IsReadOnly="True" Margin="12,0,0,12"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Phone" Classes="label" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding PhoneNumber}" IsReadOnly="True" Margin="12,0,0,12"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Department" Classes="label" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding DepartmentName}" IsReadOnly="True" Margin="12,0,0,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Contact Information -->
                        <Border Classes="card">
                            <StackPanel Spacing="16">
                                <TextBlock Text="Contact and Address" Classes="section-header"/>
                                <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="Auto,*">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Address" Classes="label" MinWidth="120" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Address}" IsReadOnly="True" Margin="12,0,0,12" AutomationProperties.Name="Address"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Birthday" Classes="label" MinWidth="120" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Birthday}" IsReadOnly="True" Margin="12,0,0,12" AutomationProperties.Name="Birthday"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Age" Classes="label" MinWidth="120" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Age}" IsReadOnly="True" Margin="12,0,0,0" AutomationProperties.Name="Age"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Right Column -->
                    <StackPanel Grid.Column="1" Spacing="16" Margin="16,0,0,0">
                        <!-- Security Settings - Commented Out
                        <Border Classes="card">
                            <StackPanel Spacing="16">
                                <TextBlock Text="Security" Classes="section-header"/>
                                <StackPanel Spacing="12">
                                    <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="12" CornerRadius="6" Classes="outline">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <Ellipse Width="8" Height="8" Fill="{DynamicResource SuccessBrush}"/>
                                            <TextBlock Grid.Column="1" Text="Change Password" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                            <Path Grid.Column="2" Width="16" Height="16" Data="M9 18L15 12L9 6" Stroke="{DynamicResource TextMutedBrush}" StrokeThickness="2" Margin="12,0,0,0"/>
                                        </Grid>
                                    </Button>

                                    <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="12" CornerRadius="6" Classes="outline">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <Ellipse Width="8" Height="8" Fill="{DynamicResource WarningBrush}"/>
                                            <TextBlock Grid.Column="1" Text="Two-Factor Authentication" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                            <Path Grid.Column="2" Width="16" Height="16" Data="M9 18L15 12L9 6" Stroke="{DynamicResource TextMutedBrush}" StrokeThickness="2" Margin="12,0,0,0"/>
                                        </Grid>
                                    </Button>

                                    <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="12" CornerRadius="6" Classes="outline">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <Ellipse Width="8" Height="8" Fill="{DynamicResource TextMutedBrush}"/>
                                            <TextBlock Grid.Column="1" Text="Login History" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                            <Path Grid.Column="2" Width="16" Height="16" Data="M9 18L15 12L9 6" Stroke="{DynamicResource TextMutedBrush}" StrokeThickness="2" Margin="12,0,0,0"/>
                                        </Grid>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        -->

                        <!-- Account Actions - Commented Out
                        <Border Classes="card">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Account Actions" Classes="section-header"/>
                                <StackPanel Spacing="8">
                                    <Button Content="Save Changes" Classes="primary" HorizontalAlignment="Stretch"/>
                                    <Button Content="Reset to Default" Classes="outline" HorizontalAlignment="Stretch"/>
                                    <Button Content="Delete Account" Classes="danger" HorizontalAlignment="Stretch"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        -->
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
