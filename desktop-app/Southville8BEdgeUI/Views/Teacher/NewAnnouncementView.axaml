<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Southville8BEdgeUI.ViewModels.Teacher"
             xmlns:conv="using:Southville8BEdgeUI.Converters"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="650"
             x:Class="Southville8BEdgeUI.Views.Teacher.NewAnnouncementView"
             x:DataType="vm:NewAnnouncementViewModel"
             Background="{DynamicResource PageBackgroundBrush}">
  <UserControl.Resources>
    <conv:BooleanNegationConverter x:Key="Negate" />
  </UserControl.Resources>
  <UserControl.Styles>
    <Style Selector="Border.form-card">
      <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="Padding" Value="32"/>
      <Setter Property="Margin" Value="24"/>
    </Style>
    <Style Selector="TextBlock.title">
      <Setter Property="FontSize" Value="26"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    </Style>
    <Style Selector="TextBlock.section">
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
      <Setter Property="Margin" Value="0,16,0,4"/>
    </Style>
    <Style Selector="ComboBox, TextBox, DatePicker, ToggleSwitch">
      <Setter Property="Margin" Value="0,4,0,16"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="8"/>
      <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    </Style>
    <Style Selector="ComboBox:focus-within, TextBox:focus-within, DatePicker:focus-within">
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
      <Setter Property="BorderThickness" Value="2"/>
    </Style>
    <Style Selector="Button.primary">
      <Setter Property="Background" Value="{DynamicResource SuccessBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource AccentTextOnAccentBrush}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="12,8"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <Style Selector="Button.secondary">
      <Setter Property="Background" Value="{DynamicResource TextSecondaryBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource AccentTextOnAccentBrush}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="12,8"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
  </UserControl.Styles>
  <ScrollViewer>
    <Border Classes="form-card">
      <StackPanel>
        <TextBlock Text="Create Announcement" Classes="title"/>
        <TextBlock Text="Compose and schedule a new class announcement" Foreground="{DynamicResource TextMutedBrush}" Margin="0,4,0,20"/>

        <TextBlock Text="Title" Classes="section"/>
        <TextBox Text="{Binding Title}" Watermark="Announcement title"/>

        <Grid ColumnDefinitions="*,*">
          <StackPanel Grid.Column="0" Margin="0,0,8,0">
            <TextBlock Text="Target Class" Classes="section" Margin="0,8,0,4"/>
            <ComboBox SelectedItem="{Binding TargetClass}" ItemsSource="{Binding AvailableClasses}" PlaceholderText="Select class"/>
          </StackPanel>
          <StackPanel Grid.Column="1" Margin="8,0,0,0">
            <TextBlock Text="Priority" Classes="section" Margin="0,8,0,4"/>
            <ComboBox SelectedItem="{Binding Priority}" ItemsSource="{Binding PriorityOptions}" PlaceholderText="Select priority"/>
          </StackPanel>
        </Grid>

        <TextBlock Text="Content" Classes="section"/>
        <TextBox Text="{Binding Content}" Watermark="Write announcement details..." AcceptsReturn="True" Height="180" TextWrapping="Wrap"/>

        <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center" Margin="0,8,0,0">
          <ToggleSwitch IsChecked="{Binding PostImmediately}" Content="Post Immediately"/>
          <StackPanel IsEnabled="{Binding PostImmediately, Converter={StaticResource Negate}}" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <TextBlock Text="Schedule Date:" VerticalAlignment="Center"/>
            <DatePicker SelectedDate="{Binding ScheduledDate}"/>
          </StackPanel>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,24,0,0" HorizontalAlignment="Left">
          <Button Content="Create" Classes="primary" Command="{Binding CreateCommand}" IsDefault="True"/>
          <Button Content="Cancel" Classes="secondary" Command="{Binding CancelCommand}" IsCancel="True"/>
        </StackPanel>
      </StackPanel>
    </Border>
  </ScrollViewer>
</UserControl>
