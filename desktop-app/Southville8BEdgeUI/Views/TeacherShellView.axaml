<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Southville8BEdgeUI.ViewModels"
             xmlns:converters="using:Southville8BEdgeUI.Converters"
             xmlns:ic="using:FluentIcons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="1440" d:DesignHeight="900"
             x:Class="Southville8BEdgeUI.Views.TeacherShellView"
             x:DataType="vm:TeacherShellViewModel">

    <UserControl.Resources>
        <converters:BoolToValueConverter x:Key="BoolToValueConverter"/>
        <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
    </UserControl.Resources>

    <UserControl.Styles>
        <!-- Navigation Button Style -->
        <Style Selector="Button.nav-item">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="12,0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                    <BrushTransition Property="Foreground" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.nav-item:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}"/>
            <Setter Property="TextBlock.Foreground" Value="{DynamicResource AccentTextOnAccentBrush}"/>
        </Style>
        <Style Selector="Button.nav-item.active /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="TextBlock.Foreground" Value="{DynamicResource AccentTextOnAccentBrush}"/>
            <Setter Property="TextBlock.FontWeight" Value="SemiBold"/>
        </Style>
        <!-- FluentIcon styling inside nav items -->
        <Style Selector="Button.nav-item ic|FluentIcon">
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Foreground" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.nav-item:pointerover ic|FluentIcon">
            <Setter Property="Foreground" Value="{DynamicResource AccentTextOnAccentBrush}"/>
        </Style>
        <Style Selector="Button.nav-item.active ic|FluentIcon">
            <Setter Property="Foreground" Value="{DynamicResource AccentTextOnAccentBrush}"/>
        </Style>
        
        <!-- Section Header Style -->
        <Style Selector="TextBlock.section-header">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
            <Setter Property="Margin" Value="24,16,12,8"/>
        </Style>

        <!-- Toggle Button Style -->
        <Style Selector="Button.sidebar-toggle">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentTextOnAccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.sidebar-toggle:pointerover">
            <Setter Property="RenderTransform" Value="scale(1.05)"/>
        </Style>

        <!-- Close button over left sidebar -->
        <Style Selector="Button.sidebar-close-middle">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentTextOnAccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.sidebar-close-middle:pointerover">
            <Setter Property="RenderTransform" Value="scale(1.1)"/>
            <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}"/>
        </Style>

        <!-- Close button over right sidebar -->
        <Style Selector="Button.sidebar-close-middle-left">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentTextOnAccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.sidebar-close-middle-left:pointerover">
            <Setter Property="RenderTransform" Value="scale(1.1)"/>
            <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}"/>
        </Style>

        <!-- Dropdown Styles -->
        <Style Selector="Border.dropdown-menu">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BoxShadow" Value="0 4 12 0 #15000000"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="MinWidth" Value="220"/>
        </Style>

        <Style Selector="Button.dropdown-item">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="Button.dropdown-item:pointerover">
            <Setter Property="Background" Value="{DynamicResource PageBackgroundBrush}"/>
        </Style>
        <Style Selector="Button.dropdown-item.logout">
            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
        </Style>
        <Style Selector="Button.dropdown-item.logout:pointerover">
            <Setter Property="Background" Value="{DynamicResource PageBackgroundBrush}"/>
        </Style>

        <!-- Sidebar Transition Styles -->
        <Style Selector="Border.sidebar">
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Width" Duration="0:0:0.3"/>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.3"/>
                </Transitions>
            </Setter>
        </Style>
        
        <!-- Overlay dismiss button -->
        <Style Selector="Button.overlay-dismiss">
          <Setter Property="Background" Value="Transparent"/>
          <Setter Property="BorderThickness" Value="0"/>
          <Setter Property="Focusable" Value="False"/>
        </Style>
        <Style Selector="Button.overlay-dismiss /template/ ContentPresenter">
          <Setter Property="Background" Value="Transparent"/>
        </Style>
    </UserControl.Styles>

    <Grid Background="{DynamicResource PageBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{Binding LeftColumnWidth}"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="{Binding RightColumnWidth}"/>
        </Grid.ColumnDefinitions>

        <!-- Left Navigation Pane -->
        <Border Grid.Column="0" Classes="sidebar"
                Background="{DynamicResource SidebarBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,1,0"
                IsVisible="{Binding IsLeftSidebarVisible}">
            <Grid>
                <DockPanel>
                    <!-- Header Section -->
                    <Border DockPanel.Dock="Top" Padding="16,20,16,20" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Image Source="avares://Southville8BEdgeUI/Assets/Images/southville-8b-logo.png"
                                   Width="80"
                                   Height="80"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Southville 8B NHIS" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="Teacher Portal" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Footer Section -->
                    <Border DockPanel.Dock="Bottom" Padding="20" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
                        <StackPanel>
                            <TextBlock Text="ACADEMIC YEAR" Classes="section-header" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Ellipse Fill="{DynamicResource AccentBrush}" Width="10" Height="10" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding AcademicYear}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Navigation Buttons -->
                    <ScrollViewer>
                        <StackPanel Spacing="4">
                            <TextBlock Text="OVERVIEW" Classes="section-header"/>
                            <Button Classes="nav-item" Command="{Binding NavigateToDashboardCommand}" Classes.active="{Binding IsDashboardActive}">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <ic:FluentIcon Icon="DataBarVertical" IconSize="Size16"/>
                                    <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <TextBlock Text="CLASSROOM" Classes="section-header"/>
                            <Button Classes="nav-item" Command="{Binding NavigateToSchedulePlannerCommand}" Classes.active="{Binding IsSchedulePlannerActive}">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <ic:FluentIcon Icon="Calendar" IconSize="Size16"/>
                                    <TextBlock Text="Schedule Planner" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="nav-item" Command="{Binding NavigateToGradeEntryCommand}" Classes.active="{Binding IsGradeEntryActive}">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <ic:FluentIcon Icon="Edit" IconSize="Size16"/>
                                    <TextBlock Text="Grade Entry" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <!-- Student Management button hidden
                            <Button Classes="nav-item" Command="{Binding NavigateToStudentManagementCommand}" Classes.active="{Binding IsStudentManagementActive}">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <ic:FluentIcon Icon="Person" IconSize="Size16"/>
                                    <TextBlock Text="Student Management" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            -->

                            <TextBlock Text="CONTENT" Classes="section-header"/>
                            <Button Classes="nav-item" Command="{Binding NavigateToMyAnnouncementsCommand}" Classes.active="{Binding IsMyAnnouncementsActive}">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <ic:FluentIcon Icon="Notepad" IconSize="Size16"/>
                                    <TextBlock Text="My Announcements" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- COMMUNICATION section hidden
                            <TextBlock Text="COMMUNICATION" Classes="section-header"/>
                            <Button Classes="nav-item" Command="{Binding NavigateToMessagingCommand}" Classes.active="{Binding IsMessagingActive}">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <ic:FluentIcon Icon="Chat" IconSize="Size16"/>
                                    <TextBlock Text="Messaging" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            -->
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>

                <!-- Overlay close button on right edge of left sidebar -->
                <Button Classes="sidebar-close-middle"
                        Command="{Binding ToggleLeftSidebarCommand}"
                        ToolTip.Tip="Close sidebar"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        CornerRadius="4,0,0,4"
                        Margin="0"
                        ZIndex="1000">
                    <ic:FluentIcon Icon="ChevronLeft" IconSize="Size16"/>
                </Button>
            </Grid>
        </Border>

        <!-- Content Area -->
        <Grid Grid.Column="1">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Margin="0"
                        Spacing="4"
                        ZIndex="100">
                <Button Classes="sidebar-toggle"
                        Command="{Binding ToggleLeftSidebarCommand}"
                        IsVisible="{Binding ShowLeftSidebarToggle}"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Margin="0,0,0,0"
                        ZIndex="200"
                        ToolTip.Tip="Open navigation">
                    <ic:FluentIcon Icon="ChevronRight" IconSize="Size16"/>
                </Button>
            </StackPanel>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0"
                        Spacing="4"
                        ZIndex="100">
                <Button Classes="sidebar-toggle"
                        Command="{Binding ToggleRightSidebarCommand}"
                        IsVisible="{Binding ShowRightSidebarToggle}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,0,0"
                        ToolTip.Tip="Open sidebar">
                    <ic:FluentIcon Icon="ChevronLeft" IconSize="Size16"/>
                </Button>
            </StackPanel>

            <ContentControl Content="{Binding CurrentContent}"/>
        </Grid>

        <!-- Right Sidebar -->
        <Border Grid.Column="2" Classes="sidebar"
                Background="{DynamicResource SidebarBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1,0,0,0"
                IsVisible="{Binding IsRightSidebarVisible}">
            <Grid>
                <Button Classes="sidebar-close-middle-left"
                        Command="{Binding ToggleRightSidebarCommand}"
                        ToolTip.Tip="Close sidebar"
                        CornerRadius="0,4,4,0"
                        Margin="0"
                        ZIndex="1000">
                    <ic:FluentIcon Icon="ChevronRight" IconSize="Size16"/>
                </Button>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="0" Margin="0">
                        <!-- User Profile Header with Dropdown -->
                        <Border Background="{DynamicResource CardBackgroundBrush}" Padding="16,8,16,16">
                            <StackPanel>
                                <Grid>
                                    <Button x:Name="ProfileButton" Background="Transparent" BorderThickness="0" Padding="0"
                                            Command="{Binding ToggleUserDropdownCommand}"
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                                        <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,12">
                                            <Border Width="40" Height="40" Background="{DynamicResource BorderBrush}" CornerRadius="20">
                                                <TextBlock Text="{Binding UserInitials}" FontSize="14" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center" MaxWidth="140">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <TextBlock Text="{Binding UserName}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" 
                                                               TextTrimming="CharacterEllipsis" MaxWidth="120"/>
                                                    <ic:FluentIcon Icon="ChevronDown" IconSize="Size16" Foreground="{DynamicResource TextMutedBrush}"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding UserRole}" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" 
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Button>

                                    <Popup IsOpen="{Binding IsUserDropdownVisible, Mode=TwoWay}"
                                           PlacementTarget="{Binding #ProfileButton}"
                                           Placement="Bottom"
                                           HorizontalOffset="0"
                                           VerticalOffset="8"
                                           IsLightDismissEnabled="True">
                                        <Border Classes="dropdown-menu" ZIndex="1001" IsHitTestVisible="True">
                                            <StackPanel Spacing="4">
                                                <Border Padding="12,8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Margin="0,0,0,8">
                                                    <StackPanel Spacing="2">
                                                        <TextBlock Text="Signed in as:" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                                                        <TextBlock Text="{Binding UserEmail}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                    </StackPanel>
                                                </Border>

                                                <Button Classes="dropdown-item" Command="{Binding NavigateToProfileCommand}">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <ic:FluentIcon Icon="Person" IconSize="Size16"/>
                                                        <TextBlock Text="Profile" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>

                                                <Button Classes="dropdown-item" Command="{Binding NavigateToSettingsCommand}">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <ic:FluentIcon Icon="Settings" IconSize="Size16"/>
                                                        <TextBlock Text="Settings" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>

                                                <Button Classes="dropdown-item" Command="{Binding NavigateToNotificationsCommand}">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <ic:FluentIcon Icon="Info" IconSize="Size16"/>
                                                        <TextBlock Text="Notifications" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>

                                                <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,8"/>

                                                <Button Classes="dropdown-item" Command="{Binding ToggleDarkModeCommand}">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <ic:FluentIcon Icon="Info" IconSize="Size16"/>
                                                        <TextBlock VerticalAlignment="Center">
                                                            <TextBlock.Text>
                                                                <Binding Path="IsDarkMode">
                                                                    <Binding.Converter>
                                                                        <converters:BoolToStringConverter TrueValue="Light Mode" FalseValue="Dark Mode"/>
                                                                    </Binding.Converter>
                                                                </Binding>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Button>

                                                <Button Classes="dropdown-item logout" Command="{Binding LogoutCommand}">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <ic:FluentIcon Icon="Delete" IconSize="Size16" Foreground="{DynamicResource DangerBrush}"/>
                                                        <TextBlock Text="Logout" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                        </Border>
                                    </Popup>
                                </Grid>

                                <!-- Current Page Indicator -->
                                <Border Background="{DynamicResource PageBackgroundBrush}" Padding="8,6" CornerRadius="4" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}" Margin="0,0,0,8">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <ic:FluentIcon Icon="Checkmark" IconSize="Size12" Foreground="{DynamicResource DangerBrush}"/>
                                        <TextBlock Text="{Binding CurrentPage}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>

                                <!-- Date and Time -->
                                <StackPanel Orientation="Horizontal" Spacing="20">
                                    <Border Background="{DynamicResource PageBackgroundBrush}" Padding="8,6" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}" CornerRadius="4">
                                        <TextBlock Text="{Binding CurrentDate}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    </Border>
                                    <Border Background="{DynamicResource PageBackgroundBrush}" Padding="8,6" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}" CornerRadius="4">
                                        <TextBlock Text="{Binding CurrentTime}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Statistics Cards Grid -->
                        <Border Padding="16,8">
                            <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,*">
                                <!-- My Classes Card -->
                                <Border Grid.Row="0" Grid.Column="0" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,4,4">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,4">
                                            <Border Width="16" Height="16" Background="{DynamicResource SuccessBrush}" CornerRadius="3">
                                                <Path Data="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z"
                                                      Fill="{DynamicResource AccentTextOnAccentBrush}"
                                                      Width="10" Height="10"
                                                      Stretch="Uniform"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="Classes" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding TotalClasses}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,2"/>
                                        <TextBlock Text="Active Classes" FontSize="9" Foreground="{DynamicResource TextMutedBrush}"/>
                                    </StackPanel>
                                </Border>

                                <!-- Announcements Card -->
                                <Border Grid.Row="0" Grid.Column="1" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="4,0,0,4">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,4">
                                            <Border Width="16" Height="16" Background="{DynamicResource WarningBrush}" CornerRadius="3">
                                                <ic:FluentIcon Icon="Megaphone" IconSize="Size12" Foreground="{DynamicResource AccentTextOnAccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="Announce." FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding TotalAnnouncements}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,2"/>
                                        <TextBlock Text="Total Posted" FontSize="9" Foreground="{DynamicResource TextMutedBrush}"/>
                                    </StackPanel>
                                </Border>

                                <!-- Students Card -->
                                <Border Grid.Row="1" Grid.Column="0" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,4,4,0">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,4">
                                            <Border Width="16" Height="16" Background="{DynamicResource WarningBrush}" CornerRadius="3">
                                                <ic:FluentIcon Icon="Person" IconSize="Size12" Foreground="{DynamicResource AccentTextOnAccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="Students" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding TotalStudents}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,2"/>
                                        <TextBlock Text="Total Students" FontSize="9" Foreground="{DynamicResource TextMutedBrush}"/>
                                    </StackPanel>
                                </Border>

                                <!-- Messages Card -->
                                <Border Grid.Row="1" Grid.Column="1" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="4,4,0,0">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,4">
                                            <Border Width="16" Height="16" Background="{DynamicResource AccentBrush}" CornerRadius="3">
                                                <ic:FluentIcon Icon="Chat" IconSize="Size12" Foreground="{DynamicResource AccentTextOnAccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="Messages" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding UnreadMessages}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,2"/>
                                        <TextBlock Text="Unread Messages" FontSize="9" Foreground="{DynamicResource TextMutedBrush}"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Schedule Section -->
                        <Border Padding="16,8" Margin="0,8,0,0"
                                Background="{DynamicResource CardBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <TextBlock Text="Today's Schedule" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>

                                <!-- Calendar Header -->
                                <Border Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8,8,0,0" Padding="12">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <Button Background="Transparent" BorderThickness="0" Padding="4" HorizontalAlignment="Left"
                                                    Command="{Binding NavigatePreviousMonthCommand}">
                                                <ic:FluentIcon Icon="ChevronLeft" IconSize="Size16" Foreground="{DynamicResource TextMutedBrush}"/>
                                            </Button>
                                            <TextBlock Text="{Binding CurrentMonth}" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            <Button Background="Transparent" BorderThickness="0" Padding="4" HorizontalAlignment="Right"
                                                    Command="{Binding NavigateNextMonthCommand}">
                                                <ic:FluentIcon Icon="ChevronRight" IconSize="Size16" Foreground="{DynamicResource SuccessBrush}"/>
                                            </Button>
                                        </StackPanel>

                                        <!-- Calendar Days -->
                                        <Grid ColumnDefinitions="*,*,*,*,*,*,*" Margin="0,8,0,0">
                                            <TextBlock Grid.Column="0" Text="Mon" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="Tue" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="Wed" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="3" Text="Thu" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="4" Text="Fri" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="5" Text="Sat" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="6" Text="Sun" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                        </Grid>

                                        <!-- Week pager (single visible week) -->
                                        <ItemsControl ItemsSource="{Binding FirstWeekDays}" Margin="0,8,0,0">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Columns="7"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="vm:CalendarDayItem">
                                                    <Grid Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <Border Background="{DynamicResource SuccessBrush}" CornerRadius="50" Width="24" Height="24" IsVisible="{Binding IsToday}"/>
                                                        <TextBlock Text="{Binding Day}" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource AccentTextOnAccentBrush}" IsVisible="{Binding IsToday}"/>
                                                        <TextBlock Text="{Binding Day}" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource TextMutedBrush}" IsVisible="{Binding IsToday, Converter={StaticResource InverseBoolConverter}}"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <!-- Today Section -->
                                <Border Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,1,1" Padding="12,8">
                                    <StackPanel>
                                        <TextBlock Text="Today" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                                        <Border Background="{DynamicResource PageBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                                            <Grid>
                                                <!-- Show current class if available -->
                                                <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center" IsVisible="{Binding HasCurrentClass}">
                                                    <!-- Left status bar -->
                                                    <Border Grid.Column="0" Width="4" Height="40" Background="{DynamicResource SuccessBrush}" CornerRadius="2" Margin="0,0,12,0"/>
                                                    <!-- Animated content -->
                                                    <TransitioningContentControl Grid.Column="1" Content="{Binding CurrentTodayClass}" VerticalAlignment="Center">
                                                        <TransitioningContentControl.PageTransition>
                                                            <CompositePageTransition>
                                                                <PageSlide Duration="0:0:0.35" />
                                                                <CrossFade Duration="0:0:0.25" />
                                                            </CompositePageTransition>
                                                        </TransitioningContentControl.PageTransition>
                                                        <TransitioningContentControl.ContentTemplate>
                                                            <DataTemplate DataType="vm:TodayClassItem">
                                                                <StackPanel VerticalAlignment="Center">
                                                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,2">
                                                                        <Border Background="{DynamicResource SuccessBrush}" CornerRadius="3" Padding="4,2">
                                                                            <TextBlock Text="{Binding Subject}" Foreground="{DynamicResource AccentTextOnAccentBrush}" FontSize="9"/>
                                                                        </Border>
                                                                        <Border Background="{DynamicResource InfoBrush}" CornerRadius="3" Padding="4,2">
                                                                            <TextBlock Text="{Binding Room}" Foreground="{DynamicResource AccentTextOnAccentBrush}" FontSize="9"/>
                                                                        </Border>
                                                                    </StackPanel>
                                                                    <TextBlock Text="{Binding Grade}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                                    <TextBlock Text="{Binding Time}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </TransitioningContentControl.ContentTemplate>
                                                    </TransitioningContentControl>
                                                    <!-- Fixed right edge next button -->
                                                    <Button Grid.Column="2" Background="Transparent" BorderThickness="0" Width="32" Height="40"
                                                            HorizontalAlignment="Right" VerticalAlignment="Center"
                                                            Command="{Binding NextTodayClassCommand}" IsVisible="{Binding HasMultipleTodayClasses}">
                                                        <ic:FluentIcon Icon="ChevronRight" IconSize="Size16" Foreground="{DynamicResource TextMutedBrush}"/>
                                                    </Button>
                                                </Grid>
                                                
                                                <!-- Show empty state when no class -->
                                                <Grid ColumnDefinitions="Auto,*" VerticalAlignment="Center" IsVisible="{Binding HasCurrentClass, Converter={StaticResource InverseBoolConverter}}">
                                                    <!-- Left gray status bar -->
                                                    <Border Grid.Column="0" Width="4" Height="40" Background="{DynamicResource BorderBrush}" CornerRadius="2" Margin="0,0,12,0"/>
                                                    <!-- Empty state message -->
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="No classes scheduled for today" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                        <Button Content="View full schedule..." Background="Transparent" Foreground="{DynamicResource SuccessBrush}" BorderThickness="0" FontSize="11" HorizontalAlignment="Center" Padding="8,4"
                                                Command="{Binding ViewFullScheduleCommand}"/>
                                    </StackPanel>
                                </Border>

                                <!-- Next Class -->
                                <Border Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,1,1" CornerRadius="0,0,8,8" Padding="12,8">
                                    <StackPanel>
                                        <TextBlock Text="Next Class" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,8"/>
                                        <Border Background="{DynamicResource WarningBrush}" BorderBrush="{DynamicResource WarningBrush}" BorderThickness="1" CornerRadius="8" Padding="12">
                                            <StackPanel>
                                                <TextBlock Text="{Binding NextClassSubject}" FontSize="11" Foreground="{DynamicResource AccentTextOnAccentBrush}" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding NextClassTime}" FontSize="10" Foreground="{DynamicResource AccentTextOnAccentBrush}" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- My Announcements Section -->
                        <Border Padding="16,8,16,16" Margin="0,8,0,0"
                                Background="{DynamicResource CardBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <ic:FluentIcon Icon="Megaphone" IconSize="Size16" Foreground="{DynamicResource InfoBrush}" Margin="0,0,8,0"/>
                                    <TextBlock Text="My Announcements" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>
                                
                                <ItemsControl ItemsSource="{Binding RecentAnnouncements}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="vm:AnnouncementSummaryItem">
                                            <Border Background="{DynamicResource PageBackgroundBrush}" 
                                                    BorderBrush="{DynamicResource BorderBrush}" 
                                                    BorderThickness="1" 
                                                    CornerRadius="6" 
                                                    Padding="12" 
                                                    Margin="0,0,0,8">
                                                <Grid ColumnDefinitions="*,Auto">
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="{Binding Title}" 
                                                                  FontSize="11" 
                                                                  FontWeight="SemiBold" 
                                                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                                                  TextTrimming="CharacterEllipsis"
                                                                  MaxLines="2"/>
                                                        <TextBlock Text="{Binding TimeAgo}" 
                                                                  FontSize="10" 
                                                                  Foreground="{DynamicResource TextMutedBrush}"
                                                                  Margin="0,4,0,0"/>
                                                    </StackPanel>
                                                    <Border Grid.Column="1" 
                                                            Background="{DynamicResource SuccessBrush}" 
                                                            CornerRadius="3" 
                                                            Padding="6,2"
                                                            VerticalAlignment="Top"
                                                            Margin="8,0,0,0">
                                                        <TextBlock Text="{Binding Status}" 
                                                                  FontSize="9" 
                                                                  Foreground="{DynamicResource AccentTextOnAccentBrush}"/>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                
                                <Button Content="View all announcements..." 
                                        Background="Transparent" 
                                        Foreground="{DynamicResource InfoBrush}" 
                                        BorderThickness="0" 
                                        FontSize="11" 
                                        HorizontalAlignment="Center" 
                                        Padding="8,4"
                                        Command="{Binding NavigateToMyAnnouncementsCommand}"/>
                            </StackPanel>
                        </Border>

                        <!-- Recent Activity Section: add border/background -->
                        <Border Padding="16,8,16,16" Margin="0,8,0,0"
                                Background="{DynamicResource CardBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <TextBlock Text="Recent Activity" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>
                                <ItemsControl ItemsSource="{Binding RecentActivities}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="vm:TeacherActivityItem">
                                            <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,12">
                                                <Border Width="32" Height="32" Background="{DynamicResource BorderBrush}" CornerRadius="16">
                                                    <TextBlock Text="{Binding StudentInitials}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                                </Border>
                                                <StackPanel VerticalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <TextBlock Text="{Binding StudentName}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                        <TextBlock Text="{Binding TimeAgo}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Activity}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Overlay to close dropdown when clicking outside -->
        <Border Grid.ColumnSpan="3" Background="Transparent" 
                IsVisible="{Binding IsUserDropdownVisible}"
                ZIndex="1000">
          <Button Classes="overlay-dismiss"
                  Background="Transparent"
                  BorderThickness="0" 
                  Command="{Binding CloseUserDropdownCommand}"
                  HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                  IsHitTestVisible="True"/>
        </Border>
    </Grid>
</UserControl>
