<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Southville8BEdgeUI.ViewModels.Admin"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Southville8BEdgeUI.Views.Admin.ELibraryManagementView"
             x:DataType="vm:ELibraryManagementViewModel"
             Background="#F9FAFB">
  
  <StackPanel Margin="40" Spacing="24" HorizontalAlignment="Center" VerticalAlignment="Center">
    <TextBlock Text="{Binding Title}" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center"/>
    <TextBlock Text="Coming Soon - Digital Library Management System" FontSize="16" Foreground="#6B7280" HorizontalAlignment="Center"/>
  </StackPanel>
</UserControl>