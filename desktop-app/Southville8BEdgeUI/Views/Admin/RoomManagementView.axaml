<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Southville8BEdgeUI.ViewModels.Admin"
             mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="800"
             x:Class="Southville8BEdgeUI.Views.Admin.RoomManagementView"
             x:DataType="vm:RoomManagementViewModel"
             Background="#F9FAFB">

    <UserControl.Styles>
        <!-- Base TextBlock Style -->
        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="#111827"/>
        </Style>
        <Style Selector="TextBlock.light">
            <Setter Property="Foreground" Value="#6B7280"/>
        </Style>
        <Style Selector="TextBlock.label">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="#6B7280"/>
        </Style>

        <!-- Main Card Style -->
        <Style Selector="Border.card">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="BoxShadow" Value="0 2 8 0 #10000000"/>
        </Style>

        <!-- Button Styles -->
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#4F46E5"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.primary:pointerover">
            <Setter Property="RenderTransform" Value="scale(1.02)"/>
        </Style>
        
        <Style Selector="Button.secondary">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.secondary:pointerover">
            <Setter Property="RenderTransform" Value="scale(1.02)"/>
            <Setter Property="Background" Value="#F9FAFB"/>
        </Style>

        <!-- Status Indicator Styles -->
        <Style Selector="Border.status-indicator">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Height" Value="8"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>

        <!-- Room Card Styles -->
        <Style Selector="Border.room-card">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="BoxShadow" Value="0 1 3 0 #1000000F"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.2"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.room-card:pointerover">
            <Setter Property="BoxShadow" Value="0 4 12 0 #20000000"/>
			<Setter Property="RenderTransform" Value="translate(-1px)"/>
        </Style>

        <!-- Status-specific styles -->
        <Style Selector="Border.status-available /template/ Border#PART_border">
            <Setter Property="BorderBrush" Value="#10B981"/>
        </Style>
        <Style Selector="Border.status-occupied /template/ Border#PART_border">
            <Setter Property="BorderBrush" Value="#EF4444"/>
        </Style>
        <Style Selector="Border.status-maintenance /template/ Border#PART_border">
            <Setter Property="BorderBrush" Value="#F59E0B"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer>
        <StackPanel Margin="40" Spacing="24">

            <!-- Header -->
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Room Management" FontSize="28" FontWeight="Bold"/>
                    <TextBlock Text="Manage classroom and event space bookings efficiently" Classes="light" FontSize="14"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Button Content="📅 View Calendar" Classes="secondary" Command="{Binding ViewCalendarCommand}"/>
                    <Button Content="➕ Book Room" Classes="primary" Command="{Binding BookRoomCommand}"/>
                </StackPanel>
            </Grid>

            <!-- Stat Cards -->
            <Grid ColumnDefinitions="*,*,*,*">
                <!-- Available -->
                <Border Grid.Column="0" Classes="card" Margin="0,0,12,0">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="Available" Classes="label"/>
                            <TextBlock Text="{Binding AvailableRooms}" FontSize="28" FontWeight="Bold"/>
                            <TextBlock Text="{Binding AvailablePercentage, StringFormat={}{0:F1}% of total}" Classes="light" FontSize="12"/>
                        </StackPanel>
                        <Border Grid.Column="1" Width="40" Height="40" Background="#E0F2F1" CornerRadius="8">
                            <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" Fill="#10B981" Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>
                <!-- Occupied -->
                <Border Grid.Column="1" Classes="card" Margin="12,0">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="Occupied" Classes="label"/>
                            <TextBlock Text="{Binding OccupiedRooms}" FontSize="28" FontWeight="Bold"/>
                            <TextBlock Text="{Binding OccupiedPercentage, StringFormat={}{0:F1}% of total}" Classes="light" FontSize="12"/>
                        </StackPanel>
                        <Border Grid.Column="1" Width="40" Height="40" Background="#FEE2E2" CornerRadius="8">
                            <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z" Fill="#EF4444" Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>
                <!-- Maintenance -->
                <Border Grid.Column="2" Classes="card" Margin="12,0">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="Maintenance" Classes="label"/>
                            <TextBlock Text="{Binding MaintenanceRooms}" FontSize="28" FontWeight="Bold"/>
                            <TextBlock Text="{Binding MaintenancePercentage, StringFormat={}{0:F1}% of total}" Classes="light" FontSize="12"/>
                        </StackPanel>
                        <Border Grid.Column="1" Width="40" Height="40" Background="#FFFBEB" CornerRadius="8">
                            <Path Data="M22.7 19l-9.1-9.1c.9-2.3.4-5-1.5-6.9-2-2-5-2.4-7.4-1.3L9 6.1 6.1 9 1.3 4.2c-1.1 2.4-.7 5.4 1.3 7.4 1.9 1.9 4.6 2.4 6.9 1.5l9.1 9.1c.4.4 1 .4 1.4 0l2.1-2.1c.4-.4.4-1 0-1.4z" Fill="#F59E0B" Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>
                <!-- Utilization -->
                <Border Grid.Column="3" Classes="card" Margin="12,0,0,0">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Utilization" Classes="label"/>
                        <TextBlock Text="{Binding UtilizationPercentage, StringFormat={}{0:F1}%}" FontSize="28" FontWeight="Bold"/>
                        <ProgressBar Value="{Binding UtilizationPercentage}" Minimum="0" Maximum="100" Height="8" CornerRadius="4" Foreground="#4F46E5"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Filter and Search Bar -->
            <Border Classes="card">
                <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto">
                    <TextBox Grid.Column="0" 
                             Watermark="Search for a room..." 
                             VerticalAlignment="Center"
                             Text="{Binding SearchText}"/>
                    <Border Grid.Column="1" Background="#E5E7EB" Width="1" Margin="12,0"/>
                    <ComboBox Grid.Column="2" 
                              PlaceholderText="All Floors" 
                              Margin="12,0"
                              ItemsSource="{Binding FloorOptions}"
                              SelectedItem="{Binding SelectedFloor}"/>
                    <ComboBox Grid.Column="3" 
                              PlaceholderText="All Status" 
                              Margin="12,0"
                              ItemsSource="{Binding StatusOptions}"
                              SelectedItem="{Binding SelectedStatus}"/>
                    <ComboBox Grid.Column="4" 
                              PlaceholderText="All Types" 
                              Margin="12,0"
                              ItemsSource="{Binding TypeOptions}"
                              SelectedItem="{Binding SelectedType}"/>
                </Grid>
            </Border>

            <!-- Room Grid -->
            <ItemsControl ItemsSource="{Binding FilteredRooms}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:RoomViewModel">
                        <Border Classes="room-card" 
                                Width="320" 
                                Margin="0,0,20,20"
                                Classes.status-available="{Binding IsAvailable}"
                                Classes.status-occupied="{Binding IsOccupied}"
                                Classes.status-maintenance="{Binding IsInMaintenance}">
                            <StackPanel Spacing="16">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Type}" Classes="light" FontSize="12"/>
                                    </StackPanel>
                                    <Border Grid.Column="1" 
                                            Classes="status-indicator"
                                            Background="{Binding StatusColor}"/>
                                </Grid>

                                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto">
                                    <StackPanel Grid.Column="0" Grid.Row="0" Spacing="4">
                                        <TextBlock Text="Status" Classes="label"/>
                                        <TextBlock Text="{Binding Status}" FontWeight="Medium"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Grid.Row="0" Spacing="4">
                                        <TextBlock Text="Capacity" Classes="label"/>
                                        <TextBlock Text="{Binding Capacity}" FontWeight="Medium"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="0" Grid.Row="1" Spacing="4">
                                        <TextBlock Text="Floor" Classes="label"/>
                                        <TextBlock Text="{Binding Floor, StringFormat=Floor {0}}" FontWeight="Medium"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Grid.Row="1" Spacing="4">
                                        <TextBlock Text="Room ID" Classes="label"/>
                                        <TextBlock Text="{Binding RoomId}" FontWeight="Medium"/>
                                    </StackPanel>
                                </Grid>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="Current Booking" Classes="label"/>
                                    <TextBlock Text="{Binding CurrentBooking}" 
                                               FontWeight="Medium" 
                                               TextWrapping="Wrap"
                                               Foreground="{Binding CurrentBookingColor}"/>
                                </StackPanel>

                                <Grid ColumnDefinitions="*,Auto">
                                    <Button Grid.Column="0" 
                                            Content="View Details" 
                                            Classes="secondary"
                                            Command="{Binding $parent[UserControl].((vm:RoomManagementViewModel)DataContext).ViewRoomDetailsCommand}"
                                            CommandParameter="{Binding}"/>
                                    <Button Grid.Column="1" 
                                            Content="{Binding ActionButtonText}" 
                                            Classes.primary="{Binding IsAvailable}"
                                            Classes.secondary="{Binding !IsAvailable}"
                                            Command="{Binding $parent[UserControl].((vm:RoomManagementViewModel)DataContext).RoomActionCommand}"
                                            CommandParameter="{Binding}"
                                            IsEnabled="{Binding CanPerformAction}"
                                            Margin="8,0,0,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Empty State -->
            <Border Classes="card" 
                    IsVisible="{Binding !HasFilteredRooms}"
                    HorizontalAlignment="Center"
                    Padding="40">
                <StackPanel Spacing="16" HorizontalAlignment="Center">
                    <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z" 
                          Fill="#9CA3AF" 
                          Width="48" 
                          Height="48" 
                          HorizontalAlignment="Center"/>
                    <TextBlock Text="No rooms found" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Try adjusting your search criteria or filters" Classes="light" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
