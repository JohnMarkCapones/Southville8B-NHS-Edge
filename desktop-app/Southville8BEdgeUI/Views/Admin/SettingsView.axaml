<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Southville8BEdgeUI.ViewModels.Admin"
             xmlns:ic="using:FluentIcons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="Southville8BEdgeUI.Views.Admin.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <UserControl.Styles>
        <!-- Headings -->
        <Style Selector="TextBlock.page-title">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>
        <Style Selector="TextBlock.page-subtitle">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
        </Style>
        <Style Selector="TextBlock.section-title">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>
        <Style Selector="TextBlock.field-label">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        </Style>

        <!-- Cards -->
        <Style Selector="Border.settings-card">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- Inputs -->
        <Style Selector="TextBox, ComboBox, NumericUpDown">
            <Setter Property="Padding" Value="12"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- CheckBoxes -->
        <Style Selector="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <!-- Buttons -->
        <Style Selector="Button.neutral">
            <Setter Property="Background" Value="{DynamicResource TextMutedBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentTextOnAccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.danger">
            <Setter Property="Background" Value="{DynamicResource DangerBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentTextOnAccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="{DynamicResource IndigoBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentTextOnAccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.success">
            <Setter Property="Background" Value="{DynamicResource SuccessBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentTextOnAccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <!-- Button icon color -->
        <Style Selector="Button.neutral ic|FluentIcon, Button.danger ic|FluentIcon, Button.primary ic|FluentIcon, Button.success ic|FluentIcon">
            <Setter Property="Foreground" Value="{DynamicResource AccentTextOnAccentBrush}"/>
        </Style>
    </UserControl.Styles>

    <Border Background="{DynamicResource CardBackgroundBrush}" Padding="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="12">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="24" MaxWidth="600">
                <!-- Header -->
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <ic:FluentIcon Icon="Settings" IconSize="Size20" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="System Settings" Classes="page-title"/>
                    </StackPanel>
                    <TextBlock Text="Configure your application preferences and system settings" Classes="page-subtitle"/>
                </StackPanel>

                <!-- School Information -->
                <Border Classes="settings-card">
                    <StackPanel Spacing="16">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <ic:FluentIcon Icon="Building" IconSize="Size20" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="School Information" Classes="section-title"/>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock Text="School Name" Classes="field-label"/>
                            <TextBox Text="{Binding SchoolName}" HorizontalAlignment="Stretch"/>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock Text="Current School Year" Classes="field-label"/>
                            <ComboBox ItemsSource="{Binding SchoolYears}" SelectedItem="{Binding CurrentSchoolYear}" HorizontalAlignment="Stretch"/>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock Text="Current Semester" Classes="field-label"/>
                            <ComboBox ItemsSource="{Binding Semesters}" SelectedItem="{Binding CurrentSemester}" HorizontalAlignment="Stretch"/>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock Text="School Theme Color" Classes="field-label"/>
                            <ComboBox ItemsSource="{Binding SchoolThemes}" SelectedItem="{Binding SchoolTheme}" HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Display Preferences -->
                <Border Classes="settings-card">
                    <StackPanel Spacing="16">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <ic:FluentIcon Icon="Table" IconSize="Size20" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="Display Preferences" Classes="section-title"/>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock Text="Students per page" Classes="field-label"/>
                            <ComboBox ItemsSource="{Binding StudentsPerPageOptions}" SelectedItem="{Binding StudentsPerPage}" HorizontalAlignment="Stretch"/>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock Text="Date Format" Classes="field-label"/>
                            <ComboBox ItemsSource="{Binding DateFormats}" SelectedItem="{Binding DateFormat}" HorizontalAlignment="Stretch"/>
                        </StackPanel>

                        <StackPanel Spacing="12">
                            <CheckBox Content="Show student photos in lists" IsChecked="{Binding ShowStudentPhotos}"/>
                            <CheckBox Content="Show detailed information by default" IsChecked="{Binding ShowDetailedInfo}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Notifications &amp; Alerts -->
                <Border Classes="settings-card">
                    <StackPanel Spacing="16">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <ic:FluentIcon Icon="Alert" IconSize="Size20" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="Notifications &amp; Alerts" Classes="section-title"/>
                        </StackPanel>

                        <StackPanel Spacing="12">
                            <CheckBox Content="Email notifications for new students" IsChecked="{Binding EmailNewStudents}"/>
                            <CheckBox Content="Email notifications for grade submissions" IsChecked="{Binding EmailGradeSubmissions}"/>
                            <CheckBox Content="Show popup alerts for important events" IsChecked="{Binding ShowPopupAlerts}"/>
                            <CheckBox Content="Notification sound" IsChecked="{Binding NotificationSound}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Data Management -->
                <Border Classes="settings-card">
                    <StackPanel Spacing="16">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <ic:FluentIcon Icon="Database" IconSize="Size20" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="Data Management" Classes="section-title"/>
                        </StackPanel>

                        <StackPanel Spacing="12">
                            <CheckBox Content="Auto-save when creating new records" IsChecked="{Binding AutoSaveRecords}"/>
                            <CheckBox Content="Ask before deleting students" IsChecked="{Binding ConfirmDeleteStudents}"/>
                            <CheckBox Content="Ask before deleting teachers" IsChecked="{Binding ConfirmDeleteTeachers}"/>
                            <CheckBox Content="Show confirmation messages" IsChecked="{Binding ShowConfirmationMessages}"/>
                            <CheckBox Content="Remember last viewed page" IsChecked="{Binding RememberLastPage}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Security &amp; Access -->
                <Border Classes="settings-card">
                    <StackPanel Spacing="16">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <ic:FluentIcon Icon="Shield" IconSize="Size20" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="Security &amp; Access" Classes="section-title"/>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock Text="Session timeout (minutes)" Classes="field-label"/>
                            <NumericUpDown Value="{Binding SessionTimeoutMinutes}" Minimum="5" Maximum="120" Increment="5"/>
                        </StackPanel>

                        <StackPanel Spacing="12">
                            <CheckBox Content="Require password for sensitive actions" IsChecked="{Binding RequirePasswordForSensitiveActions}"/>
                            <CheckBox Content="Log user activities" IsChecked="{Binding LogUserActivities}"/>
                            <CheckBox Content="Backup data automatically" IsChecked="{Binding AutoBackupData}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Reports &amp; Export -->
                <Border Classes="settings-card">
                    <StackPanel Spacing="16">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <ic:FluentIcon Icon="Document" IconSize="Size20" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="Reports &amp; Export" Classes="section-title"/>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock Text="Default report format" Classes="field-label"/>
                            <ComboBox ItemsSource="{Binding ReportFormats}" SelectedItem="{Binding DefaultReportFormat}" HorizontalAlignment="Stretch"/>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock Text="Export data location" Classes="field-label"/>
                            <ComboBox ItemsSource="{Binding ExportLocations}" SelectedItem="{Binding ExportDataLocation}" HorizontalAlignment="Stretch"/>
                        </StackPanel>

                        <StackPanel Spacing="12">
                            <CheckBox Content="Include school logo in reports" IsChecked="{Binding IncludeSchoolLogoInReports}"/>
                            <CheckBox Content="Auto-generate monthly reports" IsChecked="{Binding AutoGenerateMonthlyReports}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Action Buttons -->
                <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                    <Button Classes="neutral" Command="{Binding ExportSettingsCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <ic:FluentIcon Icon="Notepad" IconSize="Size16"/>
                            <TextBlock Text="Export Settings"/>
                        </StackPanel>
                    </Button>
                    <Button Classes="neutral" Command="{Binding ImportSettingsCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <ic:FluentIcon Icon="Notepad" IconSize="Size16"/>
                            <TextBlock Text="Import Settings"/>
                        </StackPanel>
                    </Button>
                    <Button Classes="danger" Command="{Binding ResetToDefaultsCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <ic:FluentIcon Icon="Dismiss" IconSize="Size16"/>
                            <TextBlock Text="Reset to Defaults"/>
                        </StackPanel>
                    </Button>
                    <Button Classes="primary" Command="{Binding SaveSettingsCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <ic:FluentIcon Icon="Save" IconSize="Size16"/>
                            <TextBlock Text="Save Settings"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
