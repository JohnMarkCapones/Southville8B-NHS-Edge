<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Southville8BEdgeUI.ViewModels.Admin"
             xmlns:ic="using:FluentIcons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="Southville8BEdgeUI.Views.Admin.CreateTeacherView"
             x:DataType="vm:CreateTeacherViewModel"
             Background="{DynamicResource PageBackgroundBrush}">

    <UserControl.Styles>
        <!-- Form Styles -->
        <Style Selector="TextBlock.form-title">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,24"/>
        </Style>

        <Style Selector="TextBlock.form-subtitle">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
        </Style>

        <Style Selector="TextBlock.field-label">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style Selector="TextBlock.required">
            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
        </Style>

        <Style Selector="TextBox.form-input">
            <Setter Property="Padding" Value="12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style Selector="ComboBox.form-combo">
            <Setter Property="Padding" Value="12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style Selector="Button.primary">
            <Setter Property="Background" Value="{DynamicResource IndigoBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentTextOnAccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>

        <Style Selector="Button.secondary">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style Selector="Border.error-message">
            <Setter Property="Background" Value="{DynamicResource DangerSoftBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style Selector="Border.success-message">
            <Setter Property="Background" Value="{DynamicResource SuccessSoftBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style Selector="Border.loading-overlay">
            <Setter Property="Background" Value="#80000000"/>
            <Setter Property="IsVisible" Value="{Binding IsLoading}"/>
        </Style>
    </UserControl.Styles>

    <Grid>
        <ScrollViewer>
            <Border Classes="card" Margin="40" MaxWidth="600" HorizontalAlignment="Center">
                <StackPanel Spacing="0">
                    <!-- Header -->
                    <StackPanel Margin="0,0,0,32">
                        <TextBlock Text="Create New Teacher" Classes="form-title"/>
                        <TextBlock Text="Fill in the teacher information below. All fields marked with * are required." Classes="form-subtitle"/>
                    </StackPanel>

                    <!-- Error Message -->
                    <Border Classes="error-message" IsVisible="{Binding HasError}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <ic:FluentIcon Icon="Warning" IconSize="Size20" Foreground="{DynamicResource DangerBrush}"/>
                            <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource DangerBrush}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Success Message -->
                    <Border Classes="success-message" IsVisible="{Binding HasSuccess}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <ic:FluentIcon Icon="CheckmarkCircle" IconSize="Size20" Foreground="{DynamicResource SuccessBrush}"/>
                            <TextBlock Text="{Binding SuccessMessage}" Foreground="{DynamicResource SuccessBrush}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Form Fields -->
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                        <!-- First Name -->
                        <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,12,0">
                            <TextBlock Text="First Name" Classes="field-label"/>
                            <TextBlock Text="*" Classes="required"/>
                            <TextBox Text="{Binding FirstName}" Classes="form-input" Watermark="Enter first name"/>
                        </StackPanel>

                        <!-- Last Name -->
                        <StackPanel Grid.Column="1" Grid.Row="0" Margin="12,0,0,0">
                            <TextBlock Text="Last Name" Classes="field-label"/>
                            <TextBlock Text="*" Classes="required"/>
                            <TextBox Text="{Binding LastName}" Classes="form-input" Watermark="Enter last name"/>
                        </StackPanel>

                        <!-- Middle Name -->
                        <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,0,12,0">
                            <TextBlock Text="Middle Name" Classes="field-label"/>
                            <TextBox Text="{Binding MiddleName}" Classes="form-input" Watermark="Enter middle name (optional)"/>
                        </StackPanel>

                        <!-- Email -->
                        <StackPanel Grid.Column="1" Grid.Row="1" Margin="12,0,0,0">
                            <TextBlock Text="Email" Classes="field-label"/>
                            <TextBlock Text="*" Classes="required"/>
                            <TextBox Text="{Binding Email}" Classes="form-input" Watermark="teacher@school.edu"/>
                        </StackPanel>

                        <!-- Birthday -->
                        <StackPanel Grid.Column="0" Grid.Row="2" Margin="0,0,12,0">
                            <TextBlock Text="Birthday" Classes="field-label"/>
                            <TextBlock Text="*" Classes="required"/>
                            <DatePicker SelectedDate="{Binding Birthday}" Classes="form-input"/>
                        </StackPanel>

                        <!-- Age -->
                        <StackPanel Grid.Column="1" Grid.Row="2" Margin="12,0,0,0">
                            <TextBlock Text="Age" Classes="field-label"/>
                            <TextBox Text="{Binding Age}" 
                                     Classes="form-input" 
                                     Watermark="Auto-calculated from birthday"
                                     IsReadOnly="True"
                                     Background="{DynamicResource PageBackgroundBrush}"/>
                        </StackPanel>

                        <!-- Department -->
                        <StackPanel Grid.Column="0" Grid.Row="3" Margin="0,0,12,0">
                            <TextBlock Text="Department" Classes="field-label"/>
                            <ComboBox ItemsSource="{Binding Departments}" 
                                      SelectedItem="{Binding SelectedDepartment}" 
                                      Classes="form-combo" 
                                      PlaceholderText="Select department (optional)">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DepartmentName}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <!-- Subject Specialization -->
                        <StackPanel Grid.Column="1" Grid.Row="3" Margin="12,0,0,0">
                            <TextBlock Text="Subject Specialization" Classes="field-label"/>
                            <ComboBox ItemsSource="{Binding Subjects}" 
                                      SelectedItem="{Binding SelectedSubject}" 
                                      Classes="form-combo" 
                                      PlaceholderText="Select subject (optional)"
                                      IsEnabled="{Binding SelectedDepartment, Converter={x:Static ObjectConverters.IsNotNull}}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding SubjectName}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <!-- Phone Number -->
                        <StackPanel Grid.Column="0" Grid.Row="4" Margin="0,0,12,0" Grid.ColumnSpan="2">
                            <TextBlock Text="Phone Number" Classes="field-label"/>
                            <TextBox Text="{Binding PhoneNumber}" Classes="form-input" Watermark="Enter phone number (optional)"/>
                        </StackPanel>
                    </Grid>

                    <!-- Action Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,32,0,0">
                        <Button Content="Cancel" Classes="secondary" Command="{Binding CancelCommand}"/>
                        <Button Content="Create Teacher" Classes="primary" Command="{Binding SaveTeacherCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Border Classes="loading-overlay">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ic:FluentIcon Icon="ArrowSync" IconSize="Size32" Foreground="{DynamicResource AccentTextOnAccentBrush}"/>
                <TextBlock Text="Creating teacher..." 
                           Foreground="{DynamicResource AccentTextOnAccentBrush}" 
                           FontSize="16" 
                           Margin="0,12,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
