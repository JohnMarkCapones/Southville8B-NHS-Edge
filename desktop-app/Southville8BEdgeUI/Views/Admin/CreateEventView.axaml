<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Southville8BEdgeUI.ViewModels.Admin"
             xmlns:api="using:Southville8BEdgeUI.Models.Api"
             xmlns:converters="using:Southville8BEdgeUI.Converters"
             x:Class="Southville8BEdgeUI.Views.Admin.CreateEventView"
             x:DataType="vm:CreateEventViewModel"
             mc:Ignorable="d"
             Background="{DynamicResource PageBackgroundBrush}">
  <UserControl.Resources>
    <converters:InverseBoolConverter x:Key="InvertBool"/>
  </UserControl.Resources>
  <UserControl.Styles>
    <Style Selector="Border.card">
      <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="16"/>
      <Setter Property="Padding" Value="32"/>
    </Style>
    <Style Selector="Border.card.mobile">
      <Setter Property="Padding" Value="20"/>
    </Style>
    <Style Selector="TextBlock.section-title">
      <Setter Property="FontSize" Value="16"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Margin" Value="0,8,0,16"/>
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    </Style>
    <Style Selector="TextBlock.field-label">
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="FontWeight" Value="Medium"/>
      <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
      <Setter Property="Margin" Value="0,12,0,4"/>
    </Style>
    <Style Selector="TextBox, ComboBox, DatePicker, NumericUpDown">
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="10"/>
      <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
      <Setter Property="Margin" Value="0,0,0,0"/>
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    </Style>
    <Style Selector="TextBox.description">
      <Setter Property="AcceptsReturn" Value="True"/>
      <Setter Property="MinHeight" Value="140"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
      <Setter Property="Margin" Value="0,0,0,0"/>
    </Style>
    <Style Selector="Button.primary">
      <Setter Property="Background" Value="{DynamicResource IndigoBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource AccentTextOnAccentBrush}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="18,10"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="FontSize" Value="14"/>
    </Style>
    <Style Selector="Button.secondary">
      <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="18,10"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="FontSize" Value="14"/>
    </Style>
    <Style Selector="TextBlock.page-title">
      <Setter Property="FontSize" Value="28"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    </Style>
    <Style Selector="TextBlock.page-subtitle">
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
      <Setter Property="Margin" Value="0,4,0,28"/>
    </Style>
    <Style Selector="TextBlock.validation">
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
      <Setter Property="Margin" Value="0,8,0,0"/>
    </Style>
    <Style Selector="ToggleButton.tag-toggle">
      <Setter Property="Background" Value="{DynamicResource PageBackgroundBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="16"/>
      <Setter Property="Padding" Value="12,6"/>
      <Setter Property="FontSize" Value="12"/>
    </Style>
    <Style Selector="ToggleButton.tag-toggle:checked">
      <Setter Property="Background" Value="{DynamicResource IndigoBrush}"/>
      <Setter Property="Foreground" Value="White"/>
    </Style>
  </UserControl.Styles>

  <ScrollViewer HorizontalScrollBarVisibility="Disabled">
    <StackPanel Margin="40" Spacing="32" x:Name="MainStack">
      <StackPanel>
        <TextBlock Text="{Binding DialogTitle}" Classes="page-title"/>
        <TextBlock Text="Manage event details" Classes="page-subtitle"/>
      </StackPanel>

      <!-- Loading Overlay -->
      <Border IsVisible="{Binding IsLoading}" 
              Background="#80000000" 
              Padding="20">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
          <ProgressBar IsIndeterminate="True" Width="200"/>
          <TextBlock Text="Creating event..." Margin="0,8,0,0"/>
        </StackPanel>
      </Border>

      <!-- Error Message -->
      <Border IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
              Background="#FEF2F2" 
              BorderBrush="#FECACA"
              Padding="12" 
              Margin="0,0,0,16">
        <TextBlock Text="{Binding ErrorMessage}" Foreground="#DC2626"/>
      </Border>

      <Border Classes="card">
        <StackPanel>
          <!-- BASIC INFO -->
          <TextBlock Text="Basic Information" Classes="section-title"/>
          <TextBlock Text="Title" Classes="field-label"/>
          <TextBox Text="{Binding Title}" Watermark="Event title"/>
          <TextBlock Text="{Binding TitleValidationMessage}" 
                     Foreground="#DC2626" FontSize="12" 
                     IsVisible="{Binding TitleValidationMessage, Converter={StaticResource InvertBool}}"/>
          <TextBlock Text="Status" Classes="field-label"/>
          <ComboBox ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding Status}"/>
          <TextBlock Text="Location" Classes="field-label"/>
          <ComboBox ItemsSource="{Binding LocationOptions}" SelectedItem="{Binding Location}"/>
          <TextBlock Text="{Binding LocationValidationMessage}" 
                     Foreground="#DC2626" FontSize="12" 
                     IsVisible="{Binding LocationValidationMessage, Converter={StaticResource InvertBool}}"/>
          <TextBlock Text="Visibility" Classes="field-label"/>
          <ComboBox ItemsSource="{Binding VisibilityOptions}" SelectedItem="{Binding Visibility}"/>

          <!-- SCHEDULING -->
          <TextBlock Text="Scheduling" Classes="section-title"/>
          <TextBlock Text="Date" Classes="field-label"/>
          <DatePicker SelectedDate="{Binding StartDateOffset}"/>
          <TextBlock Text="{Binding DateValidationMessage}" 
                     Foreground="#DC2626" FontSize="12" 
                     IsVisible="{Binding DateValidationMessage, Converter={StaticResource InvertBool}}"/>
          <TextBlock Text="Time" Classes="field-label"/>
          <TimePicker SelectedTime="{Binding StartTime}"/>

          <!-- DETAILS -->
          <TextBlock Text="Details" Classes="section-title"/>
          <TextBlock Text="Description" Classes="field-label"/>
          <TextBox Text="{Binding Description}" Classes="description" Watermark="Describe the event purpose, agenda, etc."/>
          <TextBlock Text="{Binding DescriptionValidationMessage}" 
                     Foreground="#DC2626" FontSize="12" 
                     IsVisible="{Binding DescriptionValidationMessage, Converter={StaticResource InvertBool}}"/>

          <!-- IMAGE UPLOAD -->
          <TextBlock Text="Event Image (Optional)" Classes="field-label"/>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="Select Image" Command="{Binding SelectImageCommand}" Classes="secondary"/>
            <TextBlock Text="{Binding EventImagePath}" VerticalAlignment="Center" 
                       Foreground="{DynamicResource TextMutedBrush}"/>
          </StackPanel>

          <!-- TAG SELECTION -->
          <TextBlock Text="Tags (Optional)" Classes="field-label"/>
          <ItemsControl ItemsSource="{Binding AvailableTags}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel Orientation="Horizontal"/>
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate DataType="api:TagDto">
                <ToggleButton Content="{Binding Name}" 
                              Command="{Binding $parent[UserControl].((vm:CreateEventViewModel)DataContext).ToggleTagCommand}"
                              CommandParameter="{Binding}"
                              Classes="tag-toggle"
                              Margin="0,0,8,8"/>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <!-- FAQ SECTION -->
          <StackPanel>
            <TextBlock Text="FAQs" Classes="section-title"/>
            
            <!-- Add New FAQ -->
            <TextBlock Text="Question" Classes="field-label"/>
            <TextBox Text="{Binding NewFaqQuestion}" Watermark="What should attendees know?"/>
            
            <TextBlock Text="Answer" Classes="field-label"/>
            <TextBox Text="{Binding NewFaqAnswer}" 
                     Classes="description" 
                     Watermark="Provide a helpful answer..."/>
            
            <Button Content="Add FAQ" 
                    Command="{Binding AddFaqCommand}" 
                    Classes="secondary"/>
            
            <!-- FAQ List -->
            <ItemsControl ItemsSource="{Binding Faq}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="api:EventFaqDto">
                  <Border BorderBrush="{DynamicResource BorderBrush}" 
                          BorderThickness="1" 
                          CornerRadius="8" 
                          Padding="12">
                    <StackPanel>
                      <!-- View Mode -->
                      <StackPanel IsVisible="{Binding $parent[vm:CreateEventViewModel].EditingFaq, Converter={StaticResource InvertBool}}">
                        <TextBlock Text="{Binding Question}" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Answer}"/>
                        <StackPanel Orientation="Horizontal">
                          <Button Content="Edit" Command="{Binding $parent[vm:CreateEventViewModel].StartEditFaqCommand}" CommandParameter="{Binding}"/>
                          <Button Content="Delete" Command="{Binding $parent[vm:CreateEventViewModel].DeleteFaqCommand}" CommandParameter="{Binding}" Classes="danger"/>
                        </StackPanel>
                      </StackPanel>
                      
                      <!-- Edit Mode -->
                      <StackPanel IsVisible="{Binding $parent[vm:CreateEventViewModel].EditingFaq}">
                        <TextBox Text="{Binding $parent[vm:CreateEventViewModel].EditFaqQuestion}"/>
                        <TextBox Text="{Binding $parent[vm:CreateEventViewModel].EditFaqAnswer}" Classes="description"/>
                        <StackPanel Orientation="Horizontal">
                          <Button Content="Save" Command="{Binding $parent[vm:CreateEventViewModel].SaveEditFaqCommand}"/>
                          <Button Content="Cancel" Command="{Binding $parent[vm:CreateEventViewModel].CancelEditFaqCommand}"/>
                        </StackPanel>
                      </StackPanel>
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>

          <!-- ACTIONS -->
          <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,28,0,0" HorizontalAlignment="Right">
            <Button Content="Cancel" Classes="secondary" Command="{Binding CancelCommand}"/>
            <Button Content="{Binding SaveButtonText}" Classes="primary" Command="{Binding SaveCommand}" IsEnabled="{Binding CanSave}"/>
          </StackPanel>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>