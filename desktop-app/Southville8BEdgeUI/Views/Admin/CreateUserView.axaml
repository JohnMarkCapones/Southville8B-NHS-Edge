<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Southville8BEdgeUI.ViewModels.Admin"
             xmlns:ic="using:FluentIcons.Avalonia"
             xmlns:conv="using:Southville8BEdgeUI.Converters"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="Southville8BEdgeUI.Views.Admin.CreateUserView"
             x:DataType="vm:CreateUserViewModel"
             Background="{DynamicResource PageBackgroundBrush}">

    <UserControl.Styles>
        <!-- Card Styles -->
        <Style Selector="Border.role-card">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.2"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1"/>
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Border.role-card:pointerover">
            <Setter Property="BoxShadow" Value="0 4 16 0 #20000000"/>
            <Setter Property="RenderTransform" Value="translate(0, -2px)"/>
            <Setter Property="BorderBrush" Value="{DynamicResource IndigoBrush}"/>
        </Style>

        <Style Selector="Border.role-card.selected">
            <Setter Property="BorderBrush" Value="{DynamicResource IndigoBrush}"/>
            <Setter Property="Background" Value="{DynamicResource IndigoSoftBrush}"/>
        </Style>

        <!-- Text Styles -->
        <Style Selector="TextBlock.wizard-title">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style Selector="TextBlock.wizard-subtitle">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
            <Setter Property="Margin" Value="0,0,0,32"/>
        </Style>

        <Style Selector="TextBlock.role-title">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style Selector="TextBlock.role-description">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <!-- Button Styles -->
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="{DynamicResource IndigoBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentTextOnAccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="24,12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>

        <Style Selector="Button.secondary">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="24,12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
    </UserControl.Styles>

    <Grid>
        <ScrollViewer>
            <Border Classes="card" Margin="40" MaxWidth="700" HorizontalAlignment="Center">
                <StackPanel Spacing="0">
                    <!-- Header -->
                    <StackPanel Margin="0,0,0,32" HorizontalAlignment="Center">
                        <TextBlock Text="Create New User" Classes="wizard-title" HorizontalAlignment="Center"/>
                        <TextBlock Text="Select the type of user account you want to create" Classes="wizard-subtitle" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Role Selection -->
                    <ItemsControl ItemsSource="{Binding RoleOptions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:RoleOption">
                                <Border Classes="role-card" 
                                        Tapped="OnRoleCardTapped">
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <!-- Icon -->
                                        <Border Grid.Column="0" 
                                                Width="48" Height="48" 
                                                Background="{DynamicResource IndigoSoftBrush}" 
                                                CornerRadius="24" 
                                                Margin="0,0,16,0"
                                                HorizontalAlignment="Center" 
                                                VerticalAlignment="Center">
                                            <ic:FluentIcon Icon="{Binding Icon}" 
                                                          IconSize="Size24" 
                                                          Foreground="{DynamicResource IndigoBrush}"/>
                                        </Border>

                                        <!-- Content -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}" Classes="role-title"/>
                                            <TextBlock Text="{Binding Description}" Classes="role-description"/>
                                        </StackPanel>

                                        <!-- Selection Indicator -->
                                        <Border Grid.Column="2" 
                                                Width="20" Height="20" 
                                                Background="{DynamicResource IndigoBrush}" 
                                                CornerRadius="10"
                                                IsVisible="{Binding $parent[UserControl].((vm:CreateUserViewModel)DataContext).SelectedRole, Converter={x:Static conv:StringConverters.Equal}, ConverterParameter={Binding Value}}">
                                            <ic:FluentIcon Icon="Checkmark" 
                                                          IconSize="Size12" 
                                                          Foreground="{DynamicResource AccentTextOnAccentBrush}"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Action Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,32,0,0">
                        <Button Content="Cancel" Classes="secondary" Command="{Binding CancelCommand}"/>
                        <Button Content="Continue" Classes="primary" Command="{Binding CreateUserCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>