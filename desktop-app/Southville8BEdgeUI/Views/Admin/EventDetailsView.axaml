<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Southville8BEdgeUI.ViewModels.Admin"
             xmlns:api="using:Southville8BEdgeUI.Models.Api"
             x:Class="Southville8BEdgeUI.Views.Admin.EventDetailsView"
             x:DataType="vm:EventDetailsViewModel"
             mc:Ignorable="d"
             Background="{DynamicResource PageBackgroundBrush}">

  <UserControl.Styles>
    <Style Selector="Border.card">
      <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="16"/>
      <Setter Property="Padding" Value="24"/>
      <Setter Property="Margin" Value="0,0,0,16"/>
    </Style>
    
    <Style Selector="Border.hero-card">
      <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="20"/>
      <Setter Property="Padding" Value="32"/>
      <Setter Property="Margin" Value="0,0,0,24"/>
    </Style>

    <Style Selector="TextBlock.section-title">
      <Setter Property="FontSize" Value="18"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Margin" Value="0,0,0,12"/>
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    </Style>

    <Style Selector="TextBlock.field-label">
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="FontWeight" Value="Medium"/>
      <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
      <Setter Property="Margin" Value="0,0,0,4"/>
    </Style>

    <Style Selector="TextBlock.field-value">
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="FontWeight" Value="Medium"/>
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
      <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <Style Selector="Border.status-badge">
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="Padding" Value="8,4"/>
      <Setter Property="HorizontalAlignment" Value="Left"/>
    </Style>

    <Style Selector="Border.tag-chip">
      <Setter Property="Background" Value="{DynamicResource GraySoftBrush}"/>
      <Setter Property="CornerRadius" Value="16"/>
      <Setter Property="Padding" Value="8,4"/>
      <Setter Property="Margin" Value="0,0,8,8"/>
    </Style>

    <Style Selector="Border.timeline-item">
      <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="16"/>
      <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <Style Selector="Border.faq-item">
      <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="16"/>
      <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <!-- Button Styles -->
    <Style Selector="Button.primary">
      <Setter Property="Background" Value="{DynamicResource IndigoBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource AccentTextOnAccentBrush}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="16,10"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="Transitions">
        <Transitions>
          <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Button.primary:pointerover">
      <Setter Property="RenderTransform" Value="scale(1.02)"/>
    </Style>

    <Style Selector="Button.secondary">
      <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="16,10"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="Transitions">
        <Transitions>
          <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Button.secondary:pointerover">
      <Setter Property="RenderTransform" Value="scale(1.02)"/>
      <Setter Property="Background" Value="{DynamicResource PageBackgroundBrush}"/>
    </Style>

    <Style Selector="Button.danger">
      <Setter Property="Background" Value="{DynamicResource DangerBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource AccentTextOnAccentBrush}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="12,8"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="FontSize" Value="12"/>
    </Style>
    <Style Selector="Button.danger:pointerover">
      <Setter Property="Background" Value="{DynamicResource DangerHoverBrush}"/>
    </Style>
  </UserControl.Styles>

  <ScrollViewer>
    <StackPanel Margin="24" MaxWidth="1200">
      
      <!-- Loading Overlay -->
      <Border IsVisible="{Binding IsLoading}" 
              Background="#80000000" 
              CornerRadius="8" 
              Padding="24" 
              HorizontalAlignment="Center" 
              VerticalAlignment="Center">
        <StackPanel Orientation="Horizontal" Spacing="12">
          <TextBlock Text="⏳" FontSize="24"/>
          <TextBlock Text="Loading event details..." 
                     FontSize="16" 
                     Foreground="White" 
                     VerticalAlignment="Center"/>
        </StackPanel>
      </Border>

      <!-- Error Message -->
      <Border IsVisible="{Binding HasError}" 
              Background="#FEF2F2" 
              BorderBrush="#FECACA" 
              BorderThickness="1" 
              CornerRadius="8" 
              Padding="16" 
              Margin="0,0,0,16">
        <StackPanel>
          <TextBlock Text="❌ Error" 
                     FontWeight="SemiBold" 
                     Foreground="#DC2626" 
                     Margin="0,0,0,4"/>
          <TextBlock Text="{Binding ErrorMessage}" 
                     Foreground="#DC2626"/>
        </StackPanel>
      </Border>

      <!-- Header Section -->
      <Border Classes="card">
        <StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,0,0,16">
            <Button Content="← Back" 
                    Command="{Binding GoBackCommand}" 
                    Classes="secondary" 
                    VerticalAlignment="Center"/>
            <TextBlock Text="Event Details" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       VerticalAlignment="Center" 
                       HorizontalAlignment="Left"/>
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
              <Button Content="Edit" 
                      Command="{Binding EditEventCommand}" 
                      Classes="primary"/>
              <Button Content="Delete" 
                      Command="{Binding DeleteEventCommand}" 
                      Classes="danger"/>
            </StackPanel>
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Hero Section -->
      <Border Classes="hero-card">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>
          
          <!-- Event Image -->
          <Border Grid.Column="0" 
                  Width="300" 
                  Height="200" 
                  Background="{DynamicResource GraySoftBrush}" 
                  CornerRadius="12" 
                  ClipToBounds="True"
                  Margin="0,0,24,0">
            <Grid>
              <Image Source="{Binding EventImageBitmap}" 
                     Stretch="UniformToFill" 
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     IsVisible="{Binding EventImageBitmap, Converter={x:Static ObjectConverters.IsNotNull}}"/>
              <Border Background="{DynamicResource GraySoftBrush}" 
                      CornerRadius="8"
                      IsVisible="{Binding EventImageBitmap, Converter={x:Static ObjectConverters.IsNull}}">
                <TextBlock Text="No Image" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center" 
                           Foreground="#9CA3AF"
                           FontSize="14"/>
              </Border>
            </Grid>
          </Border>

          <!-- Event Info -->
          <StackPanel Grid.Column="1">
            <TextBlock Text="{Binding Title}" 
                       FontSize="28" 
                       FontWeight="Bold" 
                       Margin="0,0,0,8"/>
            
            <!-- Status Badge -->
            <Border Classes="status-badge" 
                    Background="{Binding StatusColor}" 
                    Margin="0,0,0,16">
              <TextBlock Text="{Binding StatusDisplayText}" 
                         Foreground="White" 
                         FontWeight="SemiBold"/>
            </Border>

            <!-- Date, Time, Location, Visibility - with wrapping -->
            <WrapPanel Orientation="Horizontal">
              <StackPanel Margin="0,0,24,12">
                <TextBlock Text="📅 Date" Classes="field-label"/>
                <TextBlock Text="{Binding FormattedDate}" Classes="field-value"/>
              </StackPanel>
              <StackPanel Margin="0,0,24,12">
                <TextBlock Text="🕐 Time" Classes="field-label"/>
                <TextBlock Text="{Binding FormattedTime}" Classes="field-value"/>
              </StackPanel>
              <StackPanel Margin="0,0,24,12">
                <TextBlock Text="📍 Location" Classes="field-label"/>
                <TextBlock Text="{Binding Location}" Classes="field-value"/>
              </StackPanel>
              <StackPanel Margin="0,0,24,12">
                <TextBlock Text="👁️ Visibility" Classes="field-label"/>
                <TextBlock Text="{Binding VisibilityDisplayText}" Classes="field-value"/>
              </StackPanel>
            </WrapPanel>
          </StackPanel>
        </Grid>
      </Border>

      <!-- Organizer Section -->
      <Border Classes="card">
        <StackPanel>
          <TextBlock Text="Organizer" Classes="section-title"/>
          <StackPanel Orientation="Horizontal" Spacing="24">
            <StackPanel>
              <TextBlock Text="Name" Classes="field-label"/>
              <TextBlock Text="{Binding OrganizerName}" Classes="field-value"/>
            </StackPanel>
            <StackPanel>
              <TextBlock Text="Email" Classes="field-label"/>
              <TextBlock Text="{Binding OrganizerEmail}" Classes="field-value"/>
            </StackPanel>
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Description Section -->
      <Border Classes="card">
        <StackPanel>
          <TextBlock Text="Description" Classes="section-title"/>
       
            <TextBlock Text="{Binding Description}" 
                       FontSize="14" 
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       FontWeight="Normal"/>
 
        </StackPanel>
      </Border>

      <!-- Tags Section -->
      <Border Classes="card">
        <StackPanel>
          <TextBlock Text="Tags" Classes="section-title"/>
          <ItemsControl ItemsSource="{Binding Tags}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel/>
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="api:TagDto">
                <Border Classes="tag-chip">
                  <TextBlock Text="{Binding Name}" 
                             FontSize="12" 
                             FontWeight="Medium"/>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
          <TextBlock Text="No tags added" 
                     Foreground="{DynamicResource TextMutedBrush}" 
                     FontStyle="Italic"
                     IsVisible="{Binding !HasTags}"/>
        </StackPanel>
      </Border>

      <!-- Additional Information Section -->
      <Border Classes="card" IsVisible="{Binding HasAdditionalInfo}">
        <StackPanel>
          <TextBlock Text="Additional Information" Classes="section-title"/>
          <ItemsControl ItemsSource="{Binding AdditionalInfo}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="api:EventAdditionalInfoDto">
                <Border Margin="0,0,0,12" 
                        Background="{DynamicResource CardBackgroundBrush}" 
                        CornerRadius="8" 
                        Padding="16">
                  <StackPanel>
                    <TextBlock Text="{Binding Title}" 
                               FontWeight="SemiBold" 
                               Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding Content}" 
                               TextWrapping="Wrap" 
                               LineHeight="1.4"/>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

      <!-- Highlights Section -->
      <Border Classes="card" IsVisible="{Binding HasHighlights}">
        <StackPanel>
          <TextBlock Text="Highlights" Classes="section-title"/>
          <ItemsControl ItemsSource="{Binding Highlights}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <UniformGrid Columns="3"/>
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="api:EventHighlightDto">
                <Border Margin="0,0,12,12" 
                        Background="{DynamicResource CardBackgroundBrush}" 
                        CornerRadius="8" 
                        Padding="16">
                  <StackPanel>
                    <Border Width="60" 
                            Height="60" 
                            Background="{DynamicResource GraySoftBrush}" 
                            CornerRadius="8" 
                            Margin="0,0,0,8">
                      <Grid>
                        <Image Source="{Binding ImageUrl}" 
                               Stretch="UniformToFill" 
                               IsVisible="{Binding ImageUrl, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                        <TextBlock Text="📸" 
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center" 
                                   FontSize="24"
                                   IsVisible="{Binding ImageUrl, Converter={x:Static StringConverters.IsNullOrEmpty}}"/>
                      </Grid>
                    </Border>
                    <TextBlock Text="{Binding Title}" 
                               FontWeight="SemiBold" 
                               Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding Content}" 
                               FontSize="12" 
                               TextWrapping="Wrap" 
                               LineHeight="1.3"/>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

      <!-- Schedule Section -->
      <Border Classes="card" IsVisible="{Binding HasSchedule}">
        <StackPanel>
          <TextBlock Text="Schedule" Classes="section-title"/>
          <ItemsControl ItemsSource="{Binding Schedule}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="api:EventScheduleDto">
                <Border Classes="timeline-item">
                  <StackPanel Orientation="Horizontal" Spacing="12">
                    <Border Width="8" 
                            Height="8" 
                            Background="#3B82F6" 
                            CornerRadius="4" 
                            VerticalAlignment="Center"/>
                    <StackPanel>
                      <TextBlock Text="{Binding ActivityTime}" 
                                 FontWeight="SemiBold" 
                                 Margin="0,0,0,4"/>
                      <TextBlock Text="{Binding ActivityDescription}" 
                                 TextWrapping="Wrap"/>
                    </StackPanel>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

      <!-- FAQ Section -->
      <Border Classes="card" IsVisible="{Binding HasFaq}">
        <StackPanel>
          <TextBlock Text="Frequently Asked Questions" Classes="section-title"/>
          <ItemsControl ItemsSource="{Binding Faq}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="api:EventFaqDto">
                <Border Classes="faq-item">
                  <StackPanel>
                    <TextBlock Text="{Binding Question}" 
                               FontWeight="SemiBold" 
                               Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding Answer}" 
                               TextWrapping="Wrap" 
                               LineHeight="1.4"/>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

      <!-- Footer with Timestamps -->
      <Border Classes="card">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="24">
          <StackPanel>
            <TextBlock Text="Created" Classes="field-label"/>
            <TextBlock Text="{Binding CreatedAt, StringFormat='MMM dd, yyyy HH:mm'}" Classes="field-value"/>
          </StackPanel>
          <StackPanel>
            <TextBlock Text="Last Updated" Classes="field-label"/>
            <TextBlock Text="{Binding UpdatedAt, StringFormat='MMM dd, yyyy HH:mm'}" Classes="field-value"/>
          </StackPanel>
        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>
</UserControl>
