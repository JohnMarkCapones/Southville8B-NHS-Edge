<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Southville8BEdgeUI.ViewModels.Admin"
             xmlns:conv="using:Southville8BEdgeUI.Converters"
             xmlns:ic="using:FluentIcons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="Southville8BEdgeUI.Views.Admin.BuildingManagementView"
             x:DataType="vm:BuildingManagementViewModel"
             Background="{DynamicResource PageBackgroundBrush}">

    <UserControl.Styles>
        <!-- Card Styles -->
        <Style Selector="Border.building-card">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
            <Setter Property="BoxShadow" Value="0 2 8 0 #10000000"/>
        </Style>

        <Style Selector="Border.floor-section">
            <Setter Property="Background" Value="#F5F5F5"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style Selector="Border.room-box">
            <Setter Property="Width" Value="80"/>
            <Setter Property="Height" Value="60"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- Button Styles -->
        <Style Selector="Button.action-button">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="MinWidth" Value="60"/>
        </Style>

        <Style Selector="Button.action-button:hover">
            <Setter Property="Background" Value="{DynamicResource IndigoBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentTextOnAccentBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource IndigoBrush}"/>
	    </Style>

        <Style Selector="Button.primary-button">
            <Setter Property="Background" Value="{DynamicResource IndigoBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentTextOnAccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="MinWidth" Value="100"/>
        </Style>

        <!-- Dialog Styles -->
        <Style Selector="Border.dialog-overlay">
            <Setter Property="Background" Value="#80000000"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
        </Style>
        
        <Style Selector="Border.dialog-content">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="MaxWidth" Value="400"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="BoxShadow" Value="0 8 32 0 #20000000"/>
        </Style>

        <!-- Text Styles -->
        <Style Selector="TextBlock.building-name">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>

        <Style Selector="TextBlock.building-code">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
        </Style>

        <Style Selector="TextBlock.floor-name">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>

        <Style Selector="TextBlock.room-number">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <Style Selector="TextBlock.room-name">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <!-- Expansion Arrow -->
        <Style Selector="Button.expand-button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="MinWidth" Value="24"/>
            <Setter Property="MinHeight" Value="24"/>
        </Style>
    </UserControl.Styles>

    <Grid>
        <!-- Main Content -->
    <ScrollViewer>
            <StackPanel Margin="24" Spacing="16">
                <!-- Header -->
                <Grid ColumnDefinitions="*,Auto">
                    <!-- <TextBlock Text="Buildings" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/> -->
                    <Button Content="+ Add Building" 
                            Command="{Binding OpenCreateBuildingDialogCommand}"
                            Classes="primary-button"/>
                </Grid>

                <!-- Search Bar -->
                <TextBox Text="{Binding SearchText}" 
                         Watermark="Search buildings..."
                         Padding="12"
                         CornerRadius="8"
                         BorderBrush="{DynamicResource BorderBrush}"
                         Background="{DynamicResource CardBackgroundBrush}"/>

                <!-- Buildings List -->
                <ItemsControl ItemsSource="{Binding FilteredBuildings}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Classes="building-card">
                                <StackPanel Spacing="12">
                                    <!-- Building Header -->
                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
                                        <Button Grid.Column="0" 
                                                Command="{Binding ToggleExpandCommand}"
                                                Classes="expand-button">
                                            <StackPanel>
                                                <ic:FluentIcon Icon="ChevronDown" 
                                                               IconVariant="Regular" 
                                                               IconSize="Size16"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               IsVisible="{Binding IsExpanded}"/>
                                                <ic:FluentIcon Icon="ChevronRight" 
                                                               IconVariant="Regular" 
                                                               IconSize="Size16"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               IsVisible="{Binding !IsExpanded}"/>
                                            </StackPanel>
                                        </Button>
                                        
                                        <StackPanel Grid.Column="1" Margin="8,0">
                                            <TextBlock Text="{Binding BuildingName}" Classes="building-name"/>
                                            <TextBlock Text="{Binding Code}" Classes="building-code"/>
                </StackPanel>

                                        <Button Grid.Column="2" 
                                                Content="+ Add Floor"
                                                Command="{Binding AddFloorCommand}"
                                                Classes="action-button"/>
                                        
                                        <Button Grid.Column="3" 
                                                Content="Edit"
                                                Command="{Binding EditBuildingCommand}"
                                                Classes="action-button"/>
                                        
                                        <Button Grid.Column="4" 
                                                Content="Delete"
                                                Command="{Binding DeleteBuildingCommand}"
                                                Classes="action-button"/>
            </Grid>

                                    <!-- Floors (visible when expanded) -->
                                    <ItemsControl ItemsSource="{Binding Floors}" 
                                                  IsVisible="{Binding IsExpanded}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Classes="floor-section">
                                                    <StackPanel Spacing="8">
                                                        <!-- Floor Header -->
                                                        <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                                                            <Button Grid.Column="0" 
                                                                    Command="{Binding ToggleExpandCommand}"
                                                                    Classes="expand-button">
                                                                <StackPanel>
                                                                    <ic:FluentIcon Icon="ChevronDown" 
                                                                                   IconVariant="Regular" 
                                                                                   IconSize="Size16"
                                                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                                                   IsVisible="{Binding IsExpanded}"/>
                                                                    <ic:FluentIcon Icon="ChevronRight" 
                                                                                   IconVariant="Regular" 
                                                                                   IconSize="Size16"
                                                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                                                   IsVisible="{Binding !IsExpanded}"/>
                                                                </StackPanel>
                                                            </Button>
                                                            
                                                            <TextBlock Grid.Column="1" 
                                                                       Text="{Binding Name}" 
                                                                       Classes="floor-name"/>
                                                            
                                                            <Button Grid.Column="2" 
                                                                    Content="+ Add Room"
                                                                    Command="{Binding AddRoomCommand}"
                                                                    Classes="action-button"/>
                                                            
                                                            <Button Grid.Column="3" 
                                                                    Content="Delete"
                                                                    Command="{Binding DeleteFloorCommand}"
                                                                    Classes="action-button"/>
            </Grid>

                                                        <!-- Rooms Grid (visible when expanded) -->
                                                        <ItemsControl ItemsSource="{Binding Rooms}" 
                                                                      IsVisible="{Binding IsExpanded}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Background="{DynamicResource CardBackgroundBrush}"
                                                                            BorderBrush="{DynamicResource BorderBrush}"
                                                                            BorderThickness="1"
                                                                            CornerRadius="8"
                                                                            Padding="8"
                                                                            Margin="0,0,8,8"
                                                                            MinWidth="120">
                                                                        <StackPanel Spacing="8">
                                                                            <!-- Room Info Card -->
                                                                            <Border Classes="room-box" 
                                                                                    Background="{Binding Status, Converter={x:Static conv:RoomStatusToColorConverter.Instance}}">
                                                                                <StackPanel>
                                                                                    <TextBlock Text="{Binding RoomNumber}" Classes="room-number"/>
                                                                                    <TextBlock Text="{Binding Name}" Classes="room-name"/>
                                                                                </StackPanel>
                                                                            </Border>
                                                                            
                                                                            <!-- Action Buttons -->
                                                                            <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                                                                                <Button Content="Edit" 
                                                                                        Command="{Binding EditRoomCommand}"
                                                                                        Classes="action-button"
                                                                                        FontSize="10"
                                                                                        Padding="6,3"
                                                                                        MinWidth="40"/>
                                                                                <Button Content="Delete" 
                                                                                        Command="{Binding DeleteRoomCommand}"
                                                                                        Classes="danger-button"
                                                                                        FontSize="10"
                                                                                        Padding="6,3"
                                                                                        MinWidth="40"/>
                                                                            </StackPanel>
                                                                        </StackPanel>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                                    </StackPanel>
        </ScrollViewer>

        <!-- Create Building Dialog -->
        <Border IsVisible="{Binding IsCreateBuildingDialogOpen}" 
                Classes="dialog-overlay">
            <Border Classes="dialog-content">
                <StackPanel Spacing="16">
                    <TextBlock Text="Create New Building" 
                               FontSize="20" 
                               FontWeight="SemiBold" 
                               HorizontalAlignment="Center"/>
                    
                    <StackPanel Spacing="8">
                        <TextBlock Text="Building Name" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding EditingBuilding.BuildingName}" 
                                 Watermark="Enter building name"/>
                                    </StackPanel>
                    
                    <StackPanel Spacing="8">
                        <TextBlock Text="Building Code" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding EditingBuilding.Code}" 
                                 Watermark="Enter building code"/>
                                    </StackPanel>
                    
                    <StackPanel Spacing="8">
                        <TextBlock Text="Capacity (Optional)" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding EditingBuilding.Capacity}" 
                                 Watermark="Enter total capacity"/>
                                    </StackPanel>
                    
                    <Grid ColumnDefinitions="*,*" Margin="0,8,0,0">
                        <Button Grid.Column="0" 
                                Content="Cancel" 
                                Command="{Binding CloseCreateBuildingDialogCommand}"
                                Classes="action-button"
                                Margin="0,0,8,0"/>
                        <Button Grid.Column="1" 
                                Content="Create" 
                                Command="{Binding SaveBuildingCommand}"
                                Classes="primary-button"/>
                    </Grid>
                                    </StackPanel>
            </Border>
        </Border>

        <!-- Create Floor Dialog -->
        <Border IsVisible="{Binding IsCreateFloorDialogOpen}" 
                Classes="dialog-overlay">
            <Border Classes="dialog-content">
                <StackPanel Spacing="16">
                    <TextBlock Text="Add New Floor" 
                               FontSize="20" 
                               FontWeight="SemiBold" 
                               HorizontalAlignment="Center"/>
                    
                    <TextBlock Text="{Binding SelectedBuildingForFloor.BuildingName, StringFormat='Building: {0}'}" 
                               FontWeight="SemiBold" 
                               HorizontalAlignment="Center"/>
                    
                    <StackPanel Spacing="8">
                        <TextBlock Text="Floor Name" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding EditingFloor.Name}" 
                                 Watermark="Enter floor name"/>
                    </StackPanel>
                    
                    <StackPanel Spacing="8">
                        <TextBlock Text="Floor Number" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding EditingFloor.Number, Converter={x:Static conv:IntegerValidationConverter.Instance}}" 
                                 Watermark="Enter floor number"/>
                                </StackPanel>

                    <Grid ColumnDefinitions="*,*" Margin="0,8,0,0">
                                    <Button Grid.Column="0" 
                                Content="Cancel" 
                                Command="{Binding CloseCreateFloorDialogCommand}"
                                Classes="action-button"
                                Margin="0,0,8,0"/>
                                    <Button Grid.Column="1" 
                                Content="Create" 
                                Command="{Binding SaveFloorCommand}"
                                Classes="primary-button"/>
                                </Grid>
                            </StackPanel>
                        </Border>
        </Border>

        <!-- Create Room Dialog -->
        <Border IsVisible="{Binding IsCreateRoomDialogOpen}" 
                Classes="dialog-overlay">
            <Border Classes="dialog-content">
                <StackPanel Spacing="16">
                    <TextBlock Text="Add New Room" 
                               FontSize="20" 
                               FontWeight="SemiBold" 
                               HorizontalAlignment="Center"/>
                    
                    <TextBlock Text="{Binding SelectedFloorForRoom.Name, StringFormat='Floor: {0}'}" 
                               FontWeight="SemiBold" 
                               HorizontalAlignment="Center"/>
                    
                    <StackPanel Spacing="8">
                        <TextBlock Text="Room Name" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding EditingRoom.Name}" 
                                 Watermark="Enter room name"/>
                    </StackPanel>
                    
                    <StackPanel Spacing="8">
                        <TextBlock Text="Capacity" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding EditingRoom.Capacity, Converter={x:Static conv:IntegerValidationConverter.Instance}}" 
                                 Watermark="Enter room capacity"/>
                    </StackPanel>
                    
                    <StackPanel Spacing="8">
                        <TextBlock Text="Status" FontWeight="SemiBold"/>
                        <ComboBox SelectedItem="{Binding EditingRoom.Status}">
                            <x:String>Available</x:String>
                            <x:String>Occupied</x:String>
                            <x:String>Maintenance</x:String>
                        </ComboBox>
                    </StackPanel>
                    
                    <Grid ColumnDefinitions="*,*" Margin="0,8,0,0">
                        <Button Grid.Column="0" 
                                Content="Cancel" 
                                Command="{Binding CloseCreateRoomDialogCommand}"
                                Classes="action-button"
                                Margin="0,0,8,0"/>
                        <Button Grid.Column="1" 
                                Content="Create" 
                                Command="{Binding SaveRoomCommand}"
                                Classes="primary-button"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Border>

        <!-- Edit Room Dialog -->
        <Border IsVisible="{Binding IsEditRoomDialogOpen}"
                Background="#80000000"
                Grid.RowSpan="2">
            <Border Background="{DynamicResource CardBackgroundBrush}"
                    Padding="24"
                    CornerRadius="8"
                    MaxWidth="500"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <StackPanel Spacing="16">
                    <TextBlock Text="Edit Room" 
                               FontSize="20" 
                               FontWeight="SemiBold" 
                               HorizontalAlignment="Center"/>
                    
                    <TextBlock Text="{Binding EditingRoomFloorName, StringFormat='Floor: {0}'}" 
                               FontWeight="SemiBold" 
                               HorizontalAlignment="Center"/>
                    
                    <StackPanel Spacing="8">
                        <TextBlock Text="Room Name" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding EditingRoomData.Name}" 
                                 Watermark="Enter room name"/>
                    </StackPanel>
                    
                    <StackPanel Spacing="8">
                        <TextBlock Text="Capacity" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding EditingRoomData.Capacity, Converter={x:Static conv:IntegerValidationConverter.Instance}}" 
                                 Watermark="Enter room capacity"/>
                    </StackPanel>
                    
                    <StackPanel Spacing="8">
                        <TextBlock Text="Status" FontWeight="SemiBold"/>
                        <ComboBox SelectedItem="{Binding EditingRoomData.Status}">
                            <x:String>Available</x:String>
                            <x:String>Occupied</x:String>
                            <x:String>Maintenance</x:String>
                        </ComboBox>
                    </StackPanel>
                    
                    <Grid ColumnDefinitions="*,*" Margin="0,8,0,0">
                        <Button Grid.Column="0" 
                                Content="Cancel" 
                                Command="{Binding CloseEditRoomDialogCommand}"
                                Classes="action-button"
                                Margin="0,0,4,0"/>
                        <Button Grid.Column="1" 
                                Content="Save Changes" 
                                Command="{Binding SaveEditedRoomCommand}"
                                Classes="primary-button"
                                Margin="4,0,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Border>

        <!-- Error/Success Messages -->
        <Border IsVisible="{Binding HasError}" 
                Background="{DynamicResource DangerBrush}" 
                CornerRadius="8" 
                Padding="12" 
                Margin="24" 
                VerticalAlignment="Top">
            <TextBlock Text="{Binding ErrorMessage}" 
                       Foreground="{DynamicResource AccentTextOnAccentBrush}"/>
            </Border>

        <Border IsVisible="{Binding HasSuccess}" 
                Background="{DynamicResource SuccessBrush}" 
                CornerRadius="8" 
                Padding="12" 
                Margin="24" 
                VerticalAlignment="Top">
            <TextBlock Text="{Binding SuccessMessage}" 
                       Foreground="{DynamicResource AccentTextOnAccentBrush}"/>
        </Border>

        <!-- Edit Building Dialog -->
        <Border IsVisible="{Binding IsEditBuildingDialogOpen}" 
                Background="#80000000" 
                HorizontalAlignment="Stretch" 
                VerticalAlignment="Stretch">
            <Border Background="{DynamicResource CardBackgroundBrush}" 
                    CornerRadius="12" 
                    Padding="24" 
                    MaxWidth="800" 
                    MaxHeight="600" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center">
                <ScrollViewer>
                    <StackPanel Spacing="20">
                        <!-- Header -->
                        <StackPanel>
                            <TextBlock Text="Edit Building" 
                                       FontSize="24" 
                                       FontWeight="Bold" 
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="{Binding EditingBuildingCard.BuildingName, StringFormat='Building: {0}'}" 
                                       FontSize="14" 
                                       Foreground="{DynamicResource TextMutedBrush}"/>
                        </StackPanel>

                        <!-- Building Details Form -->
                        <StackPanel Spacing="16">
                            <TextBlock Text="Building Details" 
                                       FontSize="18" 
                                       FontWeight="SemiBold" 
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            
                            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto">
                                <!-- Building Name -->
                                <StackPanel Grid.Column="0" Grid.Row="0" Spacing="8" Margin="0,0,6,12">
                                    <TextBlock Text="Building Name" FontWeight="SemiBold"/>
                                    <TextBox Text="{Binding EditingBuildingData.BuildingName}" 
                                             Watermark="Enter building name"/>
                                </StackPanel>

                                <!-- Building Code -->
                                <StackPanel Grid.Column="1" Grid.Row="0" Spacing="8" Margin="6,0,0,12">
                                    <TextBlock Text="Building Code" FontWeight="SemiBold"/>
                                    <TextBox Text="{Binding EditingBuildingData.Code}" 
                                             Watermark="Enter building code"/>
                                </StackPanel>

                                <!-- Capacity -->
                                <StackPanel Grid.Column="0" Grid.Row="1" Spacing="8" Margin="0,0,6,0">
                                    <TextBlock Text="Capacity" FontWeight="SemiBold"/>
                                    <TextBox Text="{Binding EditingBuildingData.Capacity, Converter={x:Static conv:IntegerValidationConverter.Instance}}" 
                                             Watermark="Enter capacity"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <!-- Floors Section -->
                        <StackPanel Spacing="12">
                            <TextBlock Text="Floors" 
                                       FontSize="18" 
                                       FontWeight="SemiBold" 
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            
                            <ItemsControl ItemsSource="{Binding EditingBuildingCard.Floors}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource CardBackgroundBrush}" 
                                                BorderBrush="{DynamicResource BorderBrush}" 
                                                BorderThickness="1" 
                                                CornerRadius="8" 
                                                Padding="16" 
                                                Margin="0,0,0,8">
                                            <StackPanel Spacing="12">
                                                <Grid ColumnDefinitions="*,Auto">
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="{Binding Name}" 
                                                                   FontWeight="SemiBold" 
                                                                   FontSize="16"/>
                                                        <TextBlock Text="{Binding Number, StringFormat='Floor {0}'}" 
                                                                   Foreground="{DynamicResource TextMutedBrush}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                                        <Button Content="Edit" 
                                                                Command="{Binding EditFloorCommand}" 
                                                                Classes="action-button"/>
                                                        <Button Content="Delete" 
                                                                Command="{Binding DeleteFloorCommand}" 
                                                                Classes="danger-button"/>
                                                    </StackPanel>
                                                </Grid>
                                                
                                                <!-- Rooms count info -->
                                                <TextBlock Text="{Binding Rooms.Count, StringFormat='Rooms: {0}'}" 
                                                           Foreground="{DynamicResource TextMutedBrush}" 
                                                           FontSize="12"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- Action Buttons -->
                        <Grid ColumnDefinitions="*,*" Margin="0,8,0,0">
                            <Button Grid.Column="0" 
                                    Content="Cancel" 
                                    Command="{Binding CloseEditBuildingDialogCommand}"
                                    Classes="action-button"
                                    Margin="0,0,8,0"/>
                            <Button Grid.Column="1" 
                                    Content="Save Changes" 
                                    Command="{Binding SaveEditedBuildingCommand}"
                                    Classes="primary-button"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Border>
    </Grid>
</UserControl>