<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Southville8BEdgeUI.ViewModels.Admin"
             xmlns:conv="using:Southville8BEdgeUI.Converters"
             xmlns:ic="using:FluentIcons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="Southville8BEdgeUI.Views.Admin.BuildingManagementView"
             x:DataType="vm:BuildingManagementViewModel"
             Background="{DynamicResource PageBackgroundBrush}">

    <UserControl.Styles>
        <!-- Card Styles -->
        <Style Selector="Border.building-card">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
            <Setter Property="BoxShadow" Value="0 2 8 0 #10000000"/>
        </Style>

        <Style Selector="Border.floor-section">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style Selector="Border.room-box">
            <Setter Property="Width" Value="80"/>
            <Setter Property="Height" Value="60"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- Button Styles -->
        <Style Selector="Button.action-button">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="MinWidth" Value="60"/>
        </Style>

        <Style Selector="Button.action-button:hover">
            <Setter Property="Background" Value="{DynamicResource IndigoBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentTextOnAccentBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource IndigoBrush}"/>
	    </Style>

        <Style Selector="Button.primary-button">
            <Setter Property="Background" Value="{DynamicResource IndigoBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentTextOnAccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="MinWidth" Value="100"/>
        </Style>

        <!-- Text Styles -->
        <Style Selector="TextBlock.building-name">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>

        <Style Selector="TextBlock.building-code">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
        </Style>

        <Style Selector="TextBlock.floor-name">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>

        <Style Selector="TextBlock.room-number">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <Style Selector="TextBlock.room-name">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <!-- Expansion Arrow -->
        <Style Selector="Button.expand-button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="MinWidth" Value="24"/>
            <Setter Property="MinHeight" Value="24"/>
        </Style>
    </UserControl.Styles>

    <Grid>
        <!-- Main Content -->
        <ScrollViewer>
            <StackPanel Margin="24" Spacing="16">
                <!-- Header -->
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="Buildings" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <Button Grid.Column="1"
                            Command="{Binding RefreshCommand}"
                            Background="Transparent"
                            BorderThickness="0"
                            ToolTip.Tip="Refresh buildings">
                        <ic:FluentIcon Icon="ArrowClockwise" 
                                       IconVariant="Regular" 
                                       IconSize="Size20"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </Button>
                </Grid>

                <!-- Search Section -->
                <Border Background="{DynamicResource CardBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <!-- Search Icon -->
                        <ic:FluentIcon Grid.Column="0" 
                                       Icon="Search" 
                                       IconVariant="Regular" 
                                       IconSize="Size20"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center"/>
                        
                        <!-- Search TextBox -->
                        <TextBox Grid.Column="1"
                                 Text="{Binding SearchText}"
                                 Watermark="Search buildings, floors, or rooms..."
                                 BorderThickness="0"
                                 Background="Transparent"
                                 VerticalAlignment="Center"/>
                        
                        <!-- Clear Button -->
                        <Button Grid.Column="2"
                                Command="{Binding ClearSearchCommand}"
                                IsVisible="{Binding SearchText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="4"
                                VerticalAlignment="Center">
                            <ic:FluentIcon Icon="Dismiss" 
                                           IconVariant="Regular" 
                                           IconSize="Size16"
                                           Foreground="{DynamicResource TextMutedBrush}"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- Search Result Count -->
                <TextBlock Text="{Binding SearchResultText}"
                           FontSize="14"
                           Foreground="{DynamicResource TextMutedBrush}"
                           Margin="0,4,0,0"/>

                <!-- No Results Message -->
                <Border IsVisible="{Binding HasNoSearchResults}"
                        Background="{DynamicResource CardBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="32"
                        HorizontalAlignment="Center">
                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                        <ic:FluentIcon Icon="SearchInfo" 
                                       IconVariant="Regular" 
                                       IconSize="Size48"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding SearchText, StringFormat='No results found for &quot;{0}&quot;'}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Try searching for a different building, floor, or room"
                                   FontSize="14"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Buildings List -->
                <ItemsControl ItemsSource="{Binding FilteredBuildings}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Classes="building-card">
                                <StackPanel Spacing="12">
                                    <!-- Building Header -->
                                    <Grid ColumnDefinitions="Auto,*">
                                        <Button Grid.Column="0" 
                                                Command="{Binding ToggleExpandCommand}"
                                                Classes="expand-button">
                                            <StackPanel>
                                                <ic:FluentIcon Icon="ChevronDown" 
                                                               IconVariant="Regular" 
                                                               IconSize="Size16"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               IsVisible="{Binding IsExpanded}"/>
                                                <ic:FluentIcon Icon="ChevronRight" 
                                                               IconVariant="Regular" 
                                                               IconSize="Size16"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               IsVisible="{Binding !IsExpanded}"/>
                                            </StackPanel>
                                        </Button>
                                        
                                        <StackPanel Grid.Column="1" Margin="8,0">
                                            <TextBlock Text="{Binding BuildingName}" Classes="building-name"/>
                                            <TextBlock Text="{Binding Code}" Classes="building-code"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Floors (visible when expanded) -->
                                    <ItemsControl ItemsSource="{Binding Floors}" 
                                                  IsVisible="{Binding IsExpanded}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Classes="floor-section">
                                                    <StackPanel Spacing="8">
                                                        <!-- Floor Header -->
                                                        <Grid ColumnDefinitions="Auto,*">
                                                            <Button Grid.Column="0" 
                                                                    Command="{Binding ToggleExpandCommand}"
                                                                    Classes="expand-button">
                                                                <StackPanel>
                                                                    <ic:FluentIcon Icon="ChevronDown" 
                                                                                   IconVariant="Regular" 
                                                                                   IconSize="Size16"
                                                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                                                   IsVisible="{Binding IsExpanded}"/>
                                                                    <ic:FluentIcon Icon="ChevronRight" 
                                                                                   IconVariant="Regular" 
                                                                                   IconSize="Size16"
                                                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                                                   IsVisible="{Binding !IsExpanded}"/>
                                                                </StackPanel>
                                                            </Button>
                                                            
                                                            <TextBlock Grid.Column="1" 
                                                                       Text="{Binding Name}" 
                                                                       Classes="floor-name"/>
                                                        </Grid>

                                                        <!-- Rooms Grid (visible when expanded) -->
                                                        <ItemsControl ItemsSource="{Binding Rooms}" 
                                                                      IsVisible="{Binding IsExpanded}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <WrapPanel Orientation="Horizontal"/>
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Background="{DynamicResource CardBackgroundBrush}"
                                                                            BorderBrush="{DynamicResource BorderBrush}"
                                                                            BorderThickness="1"
                                                                            CornerRadius="8"
                                                                            Padding="8"
                                                                            Margin="0,0,8,8"
                                                                            MinWidth="120">
                                                                        <StackPanel Spacing="8">
                                                                            <!-- Room Info Card -->
                                                                            <Border Classes="room-box" 
                                                                                    Background="{Binding Status, Converter={x:Static conv:RoomStatusToColorConverter.Instance}}">
                                                                                <StackPanel>
                                                                                    <TextBlock Text="{Binding RoomNumber}" Classes="room-number"/>
                                                                                    <TextBlock Text="{Binding Name}" Classes="room-name"/>
                                                                                </StackPanel>
                                                                            </Border>
                                                                        </StackPanel>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>