<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Southville8BEdgeUI.ViewModels.Admin"
             xmlns:ic="using:FluentIcons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="800"
             x:Class="Southville8BEdgeUI.Views.Admin.BuildingManagementView"
             x:DataType="vm:BuildingManagementViewModel"
             Background="{DynamicResource PageBackgroundBrush}">

    <UserControl.Styles>
        <!-- RESPONSIVE TEXT STYLES -->

        <!-- Main Header -->
        <Style Selector="TextBlock.main-header">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>
        <Style Selector="TextBlock.main-header.tablet">
            <Setter Property="FontSize" Value="24"/>
        </Style>
        <Style Selector="TextBlock.main-header.mobile">
            <Setter Property="FontSize" Value="20"/>
        </Style>

        <!-- Subtitle Text -->
        <Style Selector="TextBlock.subtitle">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
        </Style>
        <Style Selector="TextBlock.subtitle.tablet">
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="TextBlock.subtitle.mobile">
            <Setter Property="FontSize" Value="12"/>
        </Style>
        
        <!-- Base TextBlock Style -->
        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>
        <Style Selector="TextBlock.light">
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
        </Style>
        
        <!-- Label Text -->
        <Style Selector="TextBlock.label">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
        </Style>
        <Style Selector="TextBlock.label.tablet">
            <Setter Property="FontSize" Value="10"/>
        </Style>
        <Style Selector="TextBlock.label.mobile">
            <Setter Property="FontSize" Value="9"/>
        </Style>

        <!-- Stat Values -->
        <Style Selector="TextBlock.stat-value">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>
        <Style Selector="TextBlock.stat-value.tablet">
            <Setter Property="FontSize" Value="24"/>
        </Style>
        <Style Selector="TextBlock.stat-value.mobile">
            <Setter Property="FontSize" Value="20"/>
        </Style>

        <!-- Room Title Text -->
        <Style Selector="TextBlock.room-title">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>
        <Style Selector="TextBlock.room-title.tablet">
            <Setter Property="FontSize" Value="16"/>
        </Style>
        <Style Selector="TextBlock.room-title.mobile">
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <!-- Room Detail Text -->
        <Style Selector="TextBlock.room-detail">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>
        <Style Selector="TextBlock.room-detail.tablet">
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="TextBlock.room-detail.mobile">
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- Empty State Text -->
        <Style Selector="TextBlock.empty-title">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>
        <Style Selector="TextBlock.empty-title.tablet">
            <Setter Property="FontSize" Value="16"/>
        </Style>
        <Style Selector="TextBlock.empty-title.mobile">
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <!-- RESPONSIVE CARD STYLES -->

        <!-- Main Card Style -->
        <Style Selector="Border.card">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="BoxShadow" Value="0 2 8 0 #10000000"/>
        </Style>
        <Style Selector="Border.card.tablet">
            <Setter Property="Padding" Value="16"/>
        </Style>
        <Style Selector="Border.card.mobile">
            <Setter Property="Padding" Value="12"/>
        </Style>

        <!-- Room Card Styles -->
        <Style Selector="Border.room-card">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="BoxShadow" Value="0 1 3 0 #1000000F"/>
            <Setter Property="Width" Value="320"/>
            <Setter Property="Margin" Value="0,0,20,20"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.2"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.room-card:pointerover">
            <Setter Property="BoxShadow" Value="0 4 12 0 #20000000"/>
            <Setter Property="RenderTransform" Value="translate(-1px)"/>
        </Style>
        <Style Selector="Border.room-card.tablet">
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Width" Value="280"/>
            <Setter Property="Margin" Value="0,0,16,16"/>
        </Style>
	    <Style Selector="Border.room-card.mobile">
		    <Setter Property="Padding" Value="12"/>
		    <Setter Property="Width" Value="NaN"/>
		    <Setter Property="HorizontalAlignment" Value="Stretch"/>
		    <Setter Property="Margin" Value="0,0,0,12"/>
	    </Style>

        <!-- RESPONSIVE BUTTON STYLES -->

        <!-- Primary Button -->
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="{DynamicResource IndigoBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentTextOnAccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.primary:pointerover">
            <Setter Property="RenderTransform" Value="scale(1.02)"/>
        </Style>
        <Style Selector="Button.primary.tablet">
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="Button.primary.mobile">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        
        <!-- Secondary Button -->
        <Style Selector="Button.secondary">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.secondary:pointerover">
            <Setter Property="RenderTransform" Value="scale(1.02)"/>
            <Setter Property="Background" Value="{DynamicResource PageBackgroundBrush}"/>
        </Style>
        <Style Selector="Button.secondary.tablet">
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="Button.secondary.mobile">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- RESPONSIVE INPUT STYLES -->

        <Style Selector="TextBox.search-input">
            <Setter Property="Padding" Value="12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>
        <Style Selector="TextBox.search-input.tablet">
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="TextBox.search-input.mobile">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style Selector="ComboBox.filter-combo">
            <Setter Property="Padding" Value="12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>
        <Style Selector="ComboBox.filter-combo.tablet">
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="MinWidth" Value="100"/>
        </Style>
        <Style Selector="ComboBox.filter-combo.mobile">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="MinWidth" Value="80"/>
        </Style>

        <!-- RESPONSIVE LAYOUT STYLES -->

        <Style Selector="StackPanel.main-content">
            <Setter Property="Margin" Value="40"/>
            <Setter Property="Spacing" Value="24"/>
        </Style>
        <Style Selector="StackPanel.main-content-tablet">
            <Setter Property="Margin" Value="20"/>
            <Setter Property="Spacing" Value="16"/>
        </Style>
        <Style Selector="StackPanel.main-content-mobile">
            <Setter Property="Margin" Value="12"/>
            <Setter Property="Spacing" Value="12"/>
        </Style>

        <!-- Status Indicator Styles -->
        <Style Selector="Border.status-indicator">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Height" Value="8"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        <Style Selector="Border.status-indicator.tablet">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Height" Value="6"/>
            <Setter Property="CornerRadius" Value="3"/>
        </Style>
        <Style Selector="Border.status-indicator.mobile">
            <Setter Property="Width" Value="4"/>
            <Setter Property="Height" Value="4"/>
            <Setter Property="CornerRadius" Value="2"/>
        </Style>

        <!-- Status-specific styles -->
        <Style Selector="Border.room-card.status-available">
            <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}"/>
        </Style>
        <Style Selector="Border.room-card.status-occupied">
            <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}"/>
        </Style>
        <Style Selector="Border.room-card.status-maintenance">
            <Setter Property="BorderBrush" Value="{DynamicResource WarningBrush}"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer>
        <StackPanel x:Name="MainStackPanel" Classes="main-content">

            <!-- Header -->
            <Grid x:Name="HeaderGrid" ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="MainHeaderText" Text="Building Management" Classes="main-header"/>
                    <TextBlock x:Name="SubtitleText" Text="Manage buildings, floors, and rooms efficiently" Classes="subtitle"/>
                </StackPanel>

                <StackPanel x:Name="HeaderButtons" Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Button x:Name="RefreshButton" Classes="secondary" Command="{Binding RefreshCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                            <ic:FluentIcon Icon="ArrowClockwise" IconSize="Size20"/>
                            <TextBlock Text="Refresh"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="CreateBuildingButton" Classes="primary" Command="{Binding CreateBuildingWizardCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                            <ic:FluentIcon Icon="Add" IconSize="Size20"/>
                            <TextBlock Text="Create Building"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Stat Cards -->
            <Grid x:Name="StatsGrid" ColumnDefinitions="*,*,*,*">
                <!-- Total Buildings -->
                <Border Grid.Column="0" x:Name="StatsCard1" Classes="card" Margin="0,0,12,0">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="Total Buildings" Classes="label"/>
                            <TextBlock x:Name="TotalBuildingsValue" Text="{Binding TotalBuildings}" Classes="stat-value"/>
                            <TextBlock x:Name="TotalBuildingsText" Text="Buildings in system" Classes="light" FontSize="12"/>
                        </StackPanel>
                        <Border Grid.Column="1" Width="40" Height="40" Background="{DynamicResource IndigoSoftBrush}" CornerRadius="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <ic:FluentIcon Icon="Building" IconSize="Size20" Foreground="{DynamicResource IndigoBrush}"/>
                        </Border>
                    </Grid>
                </Border>
                <!-- Total Floors -->
                <Border Grid.Column="1" x:Name="StatsCard2" Classes="card" Margin="12,0">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="Total Floors" Classes="label"/>
                            <TextBlock x:Name="TotalFloorsValue" Text="{Binding TotalFloors}" Classes="stat-value"/>
                            <TextBlock x:Name="TotalFloorsText" Text="Floors across buildings" Classes="light" FontSize="12"/>
                        </StackPanel>
                        <Border Grid.Column="1" Width="40" Height="40" Background="{DynamicResource TealSoftBrush}" CornerRadius="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <ic:FluentIcon Icon="Layer" IconSize="Size20" Foreground="{DynamicResource TealBrush}"/>
                        </Border>
                    </Grid>
                </Border>
                <!-- Total Rooms -->
                <Border Grid.Column="2" x:Name="StatsCard3" Classes="card" Margin="12,0">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="Total Rooms" Classes="label"/>
                            <TextBlock x:Name="TotalRoomsValue" Text="{Binding TotalRooms}" Classes="stat-value"/>
                            <TextBlock x:Name="TotalRoomsText" Text="Rooms across all floors" Classes="light" FontSize="12"/>
                        </StackPanel>
                        <Border Grid.Column="1" Width="40" Height="40" Background="{DynamicResource GreenSoftBrush}" CornerRadius="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <ic:FluentIcon Icon="Door" IconSize="Size20" Foreground="{DynamicResource SuccessBrush}"/>
                        </Border>
                    </Grid>
                </Border>
                <!-- Total Capacity -->
                <Border Grid.Column="3" x:Name="StatsCard4" Classes="card" Margin="12,0,0,0">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="Total Capacity" Classes="label"/>
                            <TextBlock x:Name="TotalCapacityValue" Text="{Binding TotalCapacity}" Classes="stat-value"/>
                            <TextBlock x:Name="TotalCapacityText" Text="Total seating capacity" Classes="light" FontSize="12"/>
                        </StackPanel>
                        <Border Grid.Column="1" Width="40" Height="40" Background="{DynamicResource PurpleSoftBrush}" CornerRadius="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <ic:FluentIcon Icon="People" IconSize="Size20" Foreground="{DynamicResource PurpleBrush}"/>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- Search Bar -->
            <Border x:Name="FilterCard" Classes="card">
                <TextBox x:Name="SearchInput" 
                         Classes="search-input"
                         Watermark="Search buildings, floors, or rooms..." 
                         VerticalAlignment="Center"
                         Text="{Binding SearchText}"/>
            </Border>

            <!-- Buildings Grid -->
            <ItemsControl x:Name="BuildingsGrid" ItemsSource="{Binding FilteredBuildings}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:RoomCardViewModel">
                        <Border x:Name="RoomCard" Classes="room-card" 
                                Classes.status-available="{Binding IsAvailable}"
                                Classes.status-occupied="{Binding IsOccupied}"
                                Classes.status-maintenance="{Binding IsMaintenance}">
                            <StackPanel Spacing="16">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0">
                                        <TextBlock x:Name="RoomNameText" Text="{Binding Name}" Classes="room-title"/>
                                        <TextBlock x:Name="RoomTypeText" Text="{Binding RoomNumber}" Classes="light" FontSize="12"/>
                                    </StackPanel>
                                    <Border Grid.Column="1" 
                                            x:Name="StatusIndicator"
                                            Classes="status-indicator"
                                            Background="{Binding StatusBrush}"/>
                                </Grid>

                                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto">
                                    <StackPanel Grid.Column="0" Grid.Row="0" Spacing="4">
                                        <TextBlock Text="Status" Classes="label"/>
                                        <TextBlock x:Name="StatusText" Text="{Binding Status}" Classes="room-detail"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Grid.Row="0" Spacing="4">
                                        <TextBlock Text="Capacity" Classes="label"/>
                                        <TextBlock x:Name="CapacityText" Text="{Binding Capacity}" Classes="room-detail"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="0" Grid.Row="1" Spacing="4">
                                        <TextBlock Text="Floor" Classes="label"/>
                                        <TextBlock x:Name="FloorText" Text="{Binding Floor, StringFormat=Floor {0}}" Classes="room-detail"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Grid.Row="1" Spacing="4">
                                        <TextBlock Text="Room ID" Classes="label"/>
                                        <TextBlock x:Name="RoomIdText" Text="{Binding RoomId}" Classes="room-detail"/>
                                    </StackPanel>
                                </Grid>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="Current Booking" Classes="label"/>
                                    <TextBlock x:Name="CurrentBookingText" 
                                               Text="{Binding CurrentBooking}" 
                                               Classes="room-detail"
                                               TextWrapping="Wrap"
                                               Foreground="{Binding CurrentBookingBrush}"/>
                                </StackPanel>

                                <Grid ColumnDefinitions="*,Auto">
                                    <Button Grid.Column="0" 
                                            x:Name="ViewDetailsButton"
                                            Content="View Details" 
                                            Classes="secondary"
                                            Command="{Binding $parent[UserControl].((vm:BuildingManagementViewModel)DataContext).RefreshCommand}"
                                            CommandParameter="{Binding}"/>
                                    <Button Grid.Column="1" 
                                            x:Name="ActionButton"
                                            Content="{Binding ActionButtonText}" 
                                            Classes.primary="{Binding IsAvailable}"
                                            Classes.secondary="{Binding !IsAvailable}"
                                            Command="{Binding $parent[UserControl].((vm:BuildingManagementViewModel)DataContext).RefreshCommand}"
                                            CommandParameter="{Binding}"
                                            IsEnabled="{Binding CanPerformAction}"
                                            Margin="8,0,0,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Empty State -->
            <Border x:Name="EmptyStateCard" Classes="card" 
                    IsVisible="{Binding !HasFilteredRooms}"
                    HorizontalAlignment="Center"
                    Padding="40">
                <StackPanel Spacing="16" HorizontalAlignment="Center">
                    <ic:FluentIcon Icon="Info" IconSize="Size32" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="EmptyTitleText" Text="No rooms found" Classes="empty-title" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="EmptySubtitleText" Text="Try adjusting your search criteria or filters" Classes="subtitle" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
