<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Southville8BEdgeUI.ViewModels.Admin"
             xmlns:ic="using:FluentIcons.Avalonia"
             x:Class="Southville8BEdgeUI.Views.Admin.AlertsView"
             x:Name="AlertsRoot"
             x:DataType="vm:AlertsViewModel"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             Background="{DynamicResource PageBackgroundBrush}">

	<UserControl.Styles>
		<!-- RESPONSIVE TEXT STYLES -->

		<!-- Main Header -->
		<Style Selector="TextBlock.main-header">
			<Setter Property="FontSize" Value="18"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
			<Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
		</Style>
		<Style Selector="TextBlock.main-header.tablet">
			<Setter Property="FontSize" Value="16"/>
		</Style>
		<Style Selector="TextBlock.main-header.mobile">
			<Setter Property="FontSize" Value="14"/>
		</Style>

		<!-- Subtitle Text -->
		<Style Selector="TextBlock.subtitle">
			<Setter Property="FontSize" Value="12"/>
			<Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
		</Style>
		<Style Selector="TextBlock.subtitle.tablet">
			<Setter Property="FontSize" Value="11"/>
		</Style>
		<Style Selector="TextBlock.subtitle.mobile">
			<Setter Property="FontSize" Value="10"/>
		</Style>

		<!-- Section Header -->
		<Style Selector="TextBlock.section-header">
			<Setter Property="FontSize" Value="11"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
			<Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
			<Setter Property="Margin" Value="0,16,0,8"/>
		</Style>
		<Style Selector="TextBlock.section-header.tablet">
			<Setter Property="FontSize" Value="10"/>
			<Setter Property="Margin" Value="0,12,0,6"/>
		</Style>
		<Style Selector="TextBlock.section-header.mobile">
			<Setter Property="FontSize" Value="9"/>
			<Setter Property="Margin" Value="0,12,0,6"/>
		</Style>

		<!-- Card Header -->
		<Style Selector="TextBlock.card-header">
			<Setter Property="FontSize" Value="16"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
			<Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
			<Setter Property="Margin" Value="0,0,0,16"/>
		</Style>
		<Style Selector="TextBlock.card-header.tablet">
			<Setter Property="FontSize" Value="14"/>
			<Setter Property="Margin" Value="0,0,0,12"/>
		</Style>
		<Style Selector="TextBlock.card-header.mobile">
			<Setter Property="FontSize" Value="12"/>
			<Setter Property="Margin" Value="0,0,0,8"/>
		</Style>

		<!-- Form Label -->
		<Style Selector="TextBlock.form-label">
			<Setter Property="FontSize" Value="12"/>
			<Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
			<Setter Property="FontWeight" Value="Medium"/>
			<Setter Property="VerticalAlignment" Value="Center"/>
			<Setter Property="Margin" Value="0,0,0,4"/>
		</Style>
		<Style Selector="TextBlock.form-label.tablet">
			<Setter Property="FontSize" Value="11"/>
		</Style>
		<Style Selector="TextBlock.form-label.mobile">
			<Setter Property="FontSize" Value="10"/>
		</Style>

		<!-- Alert Title -->
		<Style Selector="TextBlock.alert-title">
			<Setter Property="FontSize" Value="14"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
			<Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
		</Style>
		<Style Selector="TextBlock.alert-title.tablet">
			<Setter Property="FontSize" Value="13"/>
		</Style>
		<Style Selector="TextBlock.alert-title.mobile">
			<Setter Property="FontSize" Value="12"/>
		</Style>

		<!-- Alert Message -->
		<Style Selector="TextBlock.alert-message">
			<Setter Property="FontSize" Value="12"/>
			<Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
			<Setter Property="LineHeight" Value="16"/>
		</Style>
		<Style Selector="TextBlock.alert-message.tablet">
			<Setter Property="FontSize" Value="11"/>
			<Setter Property="LineHeight" Value="15"/>
		</Style>
		<Style Selector="TextBlock.alert-message.mobile">
			<Setter Property="FontSize" Value="10"/>
			<Setter Property="LineHeight" Value="14"/>
		</Style>

		<!-- RESPONSIVE CARD STYLES -->

		<!-- Main Card Style -->
		<Style Selector="Border.card">
			<Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
			<Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="CornerRadius" Value="12"/>
			<Setter Property="Padding" Value="20"/>
			<Setter Property="BoxShadow" Value="0 2 8 0 #10000000"/>
		</Style>
		<Style Selector="Border.card.tablet">
			<Setter Property="Padding" Value="16"/>
		</Style>
		<Style Selector="Border.card.mobile">
			<Setter Property="Padding" Value="12"/>
		</Style>

		<!-- Alert Card Styles -->
		<Style Selector="Border.alert-card">
			<Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
			<Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="CornerRadius" Value="8"/>
			<Setter Property="Padding" Value="16"/>
			<Setter Property="Margin" Value="0,0,0,12"/>
			<Setter Property="Transitions">
				<Transitions>
					<BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.2"/>
				</Transitions>
			</Setter>
		</Style>
		<Style Selector="Border.alert-card.tablet">
			<Setter Property="Padding" Value="14"/>
			<Setter Property="Margin" Value="0,0,0,10"/>
		</Style>
		<Style Selector="Border.alert-card.mobile">
			<Setter Property="Padding" Value="12"/>
			<Setter Property="Margin" Value="0,0,0,8"/>
		</Style>

		<!-- RESPONSIVE BUTTON STYLES -->

		<!-- Action Button Base -->
		<Style Selector="Button.action-btn">
			<Setter Property="Padding" Value="12,8"/>
			<Setter Property="CornerRadius" Value="6"/>
			<Setter Property="FontWeight" Value="Medium"/>
			<Setter Property="FontSize" Value="12"/>
			<Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
			<Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
			<Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Transitions">
				<Transitions>
					<TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1"/>
				</Transitions>
			</Setter>
		</Style>
		<Style Selector="Button.action-btn:pointerover">
			<Setter Property="RenderTransform" Value="scale(1.02)"/>
		</Style>
		<Style Selector="Button.action-btn.tablet">
			<Setter Property="Padding" Value="10,6"/>
			<Setter Property="FontSize" Value="11"/>
		</Style>
		<Style Selector="Button.action-btn.mobile">
			<Setter Property="Padding" Value="8,5"/>
			<Setter Property="FontSize" Value="10"/>
		</Style>

		<!-- Small Action Button -->
		<Style Selector="Button.action-btn-sm">
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
			<Setter Property="Padding" Value="8,4"/>
			<Setter Property="CornerRadius" Value="4"/>
			<Setter Property="FontWeight" Value="Medium"/>
			<Setter Property="FontSize" Value="10"/>
			<Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
			<Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
			<Setter Property="Transitions">
				<Transitions>
					<TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1"/>
				</Transitions>
			</Setter>
		</Style>
		<Style Selector="Button.action-btn-sm:pointerover">
			<Setter Property="RenderTransform" Value="scale(1.02)"/>
		</Style>
		<Style Selector="Button.action-btn-sm.tablet">
			<Setter Property="Padding" Value="6,3"/>
			<Setter Property="FontSize" Value="9"/>
		</Style>
		<Style Selector="Button.action-btn-sm.mobile">
			<Setter Property="Padding" Value="6,2"/>
			<Setter Property="FontSize" Value="8"/>
		</Style>

		<!-- Primary Button -->
		<Style Selector="Button.primary">
			<Setter Property="Background" Value="{DynamicResource SuccessBrush}"/>
			<Setter Property="Foreground" Value="{DynamicResource AccentTextOnAccentBrush}"/>
		</Style>

		<!-- Secondary Button -->
		<Style Selector="Button.secondary">
			<Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
			<Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
			<Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
			<Setter Property="BorderThickness" Value="1"/>
		</Style>

		<!-- Danger Button -->
		<Style Selector="Button.danger">
			<Setter Property="Background" Value="{DynamicResource DangerBrush}"/>
			<Setter Property="Foreground" Value="{DynamicResource AccentTextOnAccentBrush}"/>
		</Style>

		<!-- Warning Button -->
		<Style Selector="Button.warning">
			<Setter Property="Background" Value="{DynamicResource WarningBrush}"/>
			<Setter Property="Foreground" Value="{DynamicResource AccentTextOnAccentBrush}"/>
		</Style>

		<!-- RESPONSIVE INPUT STYLES -->
		<Style Selector="TextBox, ComboBox, DatePicker, TimePicker">
			<Setter Property="Margin" Value="0,0,0,12"/>
			<Setter Property="Padding" Value="8"/>
			<Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="CornerRadius" Value="4"/>
			<Setter Property="FontSize" Value="12"/>
			<Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
			<Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
		</Style>
		<Style Selector="TextBox.tablet, ComboBox.tablet, DatePicker.tablet, TimePicker.tablet">
			<Setter Property="Padding" Value="6"/>
			<Setter Property="FontSize" Value="11"/>
			<Setter Property="Margin" Value="0,0,0,10"/>
		</Style>
		<Style Selector="TextBox.mobile, ComboBox.mobile, DatePicker.mobile, TimePicker.mobile">
			<Setter Property="Padding" Value="6"/>
			<Setter Property="FontSize" Value="10"/>
			<Setter Property="Margin" Value="0,0,0,8"/>
		</Style>

		<!-- RESPONSIVE LAYOUT STYLES -->
		<Style Selector="Grid.main-content">
			<Setter Property="Background" Value="{DynamicResource PageBackgroundBrush}"/>
		</Style>
		<Style Selector="Grid.main-content-tablet">
			<Setter Property="Background" Value="{DynamicResource PageBackgroundBrush}"/>
		</Style>
		<Style Selector="Grid.main-content-mobile">
			<Setter Property="Background" Value="{DynamicResource PageBackgroundBrush}"/>
		</Style>

		<!-- Tag Style -->
		<Style Selector="Border.tag">
			<Setter Property="Background" Value="{DynamicResource PageBackgroundBrush}"/>
			<Setter Property="CornerRadius" Value="4"/>
			<Setter Property="Padding" Value="6,3"/>
			<Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
			<Setter Property="BorderThickness" Value="1"/>
		</Style>
		<Style Selector="Border.tag.tablet">
			<Setter Property="Padding" Value="5,2"/>
		</Style>
		<Style Selector="Border.tag.mobile">
			<Setter Property="Padding" Value="4,2"/>
		</Style>

		<!-- Badge Style -->
		<Style Selector="Border.badge">
			<Setter Property="Background" Value="{DynamicResource PageBackgroundBrush}"/>
			<Setter Property="CornerRadius" Value="6"/>
			<Setter Property="Padding" Value="12,6"/>
			<Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
			<Setter Property="BorderThickness" Value="1"/>
		</Style>
		<Style Selector="Border.badge.tablet">
			<Setter Property="Padding" Value="10,5"/>
		</Style>
		<Style Selector="Border.badge.mobile">
			<Setter Property="Padding" Value="8,4"/>
		</Style>
	</UserControl.Styles>

    <ScrollViewer>
    <Grid x:Name="MainGrid" Classes="main-content" RowDefinitions="Auto,*" ColumnDefinitions="400,*">

		<!-- Page Header -->
		<Border x:Name="HeaderCard" Grid.Row="0" Grid.ColumnSpan="2" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="20,16">
			<StackPanel Orientation="Horizontal" Spacing="16">
				<!-- Title and Stats -->
				<StackPanel VerticalAlignment="Center">
					<TextBlock x:Name="MainHeaderText" Text="Alert Management" Classes="main-header"/>
					<TextBlock x:Name="SubtitleText" Text="Create and manage school-wide alerts and notifications" Classes="subtitle"/>
				</StackPanel>

				<!-- Stats Badge -->
				<Border Classes="badge" VerticalAlignment="Center">
					<StackPanel Orientation="Horizontal" Spacing="4">
						<Ellipse Fill="{DynamicResource SuccessBrush}" Width="8" Height="8" VerticalAlignment="Center"/>
						<TextBlock x:Name="ActiveCountText" Text="{Binding ActiveCount, StringFormat={}{0} Active}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="Medium"/>
					</StackPanel>
				</Border>

				<!-- Action Buttons -->
				<StackPanel x:Name="HeaderButtonsStack" Orientation="Horizontal" Spacing="8" Margin="20,0,0,0">
					<Button x:Name="RefreshButton" Classes="action-btn primary" Command="{Binding RefreshComputedCommand}">
						<StackPanel Orientation="Horizontal" Spacing="6">
							<ic:FluentIcon Icon="ArrowClockwise" IconSize="Size16"/>
							<TextBlock Text="Refresh"/>
						</StackPanel>
					</Button>
					<Button x:Name="PurgeButton" Classes="action-btn danger" Command="{Binding PurgeExpiredCommand}">
						<StackPanel Orientation="Horizontal" Spacing="6">
							<ic:FluentIcon Icon="Delete" IconSize="Size16"/>
							<TextBlock Text="Purge Expired"/>
						</StackPanel>
					</Button>
				</StackPanel>
			</StackPanel>
		</Border>

		<!-- Create Alert Panel -->
        <Border x:Name="CreateAlertCard" Grid.Row="1" Grid.Column="0" Classes="card" Margin="20,20,12,20">
                <StackPanel Spacing="0">
					<TextBlock x:Name="CreateHeaderText" Text="Create New Alert" Classes="card-header"/>

					<!-- Alert Type -->
					<TextBlock Text="ALERT TYPE" Classes="section-header"/>
					<ComboBox x:Name="TypeComboBox" ItemsSource="{Binding AlertTypes}" SelectedItem="{Binding NewType}" HorizontalAlignment="Stretch"/>

					<!-- Alert Content -->
					<TextBlock Text="CONTENT" Classes="section-header"/>
					<TextBlock Text="Title" Classes="form-label"/>
					<TextBox x:Name="TitleTextBox" Text="{Binding NewTitle}" Watermark="e.g., Weather Alert: Early dismissal at 2:00 PM" Height="36"/>

					<TextBlock Text="Message" Classes="form-label"/>
					<TextBox x:Name="MessageTextBox" Text="{Binding NewMessage}" AcceptsReturn="True" Height="80"
                             TextWrapping="Wrap" Watermark="Provide detailed information about the alert..."/>

					<TextBlock Text="Additional Link (Optional)" Classes="form-label"/>
					<TextBox x:Name="LinkTextBox" Text="{Binding NewExtraLink}" Watermark="https://facebook.com/southville8bnhis" Height="36"/>

					<!-- Alert Settings -->
					<TextBlock Text="SETTINGS" Classes="section-header"/>
					<StackPanel Spacing="12">
						<StackPanel>
							<TextBlock Text="Priority" Classes="form-label"/>
							<ComboBox x:Name="PriorityComboBox" ItemsSource="{Binding Priorities}" SelectedItem="{Binding NewPriority}" HorizontalAlignment="Stretch"/>
						</StackPanel>
						<StackPanel>
							<TextBlock Text="Target Scope" Classes="form-label"/>
							<ComboBox x:Name="ScopeComboBox" ItemsSource="{Binding TargetScopes}" SelectedItem="{Binding NewTargetScope}" HorizontalAlignment="Stretch"/>
						</StackPanel>
					</StackPanel>

					<!-- Target Details -->
					<StackPanel IsVisible="{Binding NewTargetScope, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" Margin="0,12,0,0">
						<TextBlock Text="Scope Details" Classes="form-label"/>
						<StackPanel Spacing="8">
							<TextBox x:Name="GradeLevelTextBox" Text="{Binding NewGradeLevel}" Watermark="Grade (e.g., 8)" Height="36"/>
							<TextBox x:Name="SectionTextBox" Text="{Binding NewSection}" Watermark="Section (e.g., 8-A)" Height="36"/>
						</StackPanel>
					</StackPanel>

					<!-- Expiration -->
					<TextBlock Text="EXPIRATION" Classes="section-header"/>
				<StackPanel Spacing="8">
						<DatePicker x:Name="ExpiresDatePicker" SelectedDate="{Binding NewExpiresDate}" HorizontalAlignment="Stretch"/>
						<TimePicker x:Name="ExpiresTimePicker" SelectedTime="{Binding NewExpiresTime}" HorizontalAlignment="Stretch"/>
					<TextBlock Text="Defaults to 24 hours if not specified by server policy." Classes="subtitle"/>
					</StackPanel>

					<!-- Action Buttons -->
					<StackPanel Orientation="Horizontal" Spacing="8" Margin="0,24,0,0">
						<Button x:Name="PublishButton" Classes="action-btn primary" Command="{Binding CreateAlertCommand}" HorizontalAlignment="Stretch" MinWidth="120">
							<StackPanel Orientation="Horizontal" Spacing="6">
								<ic:FluentIcon Icon="Send" IconSize="Size16"/>
								<TextBlock Text="Publish Alert"/>
							</StackPanel>
						</Button>
						<Button x:Name="ClearButton" Classes="action-btn secondary" Command="{Binding ClearFormCommand}" MinWidth="100">
							<StackPanel Orientation="Horizontal" Spacing="6">
								<ic:FluentIcon Icon="Dismiss" IconSize="Size16"/>
								<TextBlock Text="Clear Form"/>
							</StackPanel>
						</Button>
					</StackPanel>
                </StackPanel>
		</Border>

		<!-- Active Alerts Panel -->
        <Border x:Name="ActiveAlertsCard" Grid.Row="1" Grid.Column="1" Classes="card" Margin="12,20,20,20">
            <Grid RowDefinitions="Auto,*">
				<!-- Header -->
				<StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,16">
					<TextBlock x:Name="AlertsHeaderText" Text="Active Alerts" Classes="card-header" Margin="0"/>
					<Border Classes="badge" VerticalAlignment="Center">
						<TextBlock x:Name="ActiveCountBadgeText" Text="{Binding ActiveCount, StringFormat={}{0} alerts}" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
					</Border>
				</StackPanel>

                <!-- Content (no internal scroll; page scrolls) -->
                <StackPanel Grid.Row="1" Spacing="0">
						<!-- Active Alerts List -->
						<ItemsControl ItemsSource="{Binding ActiveAlerts}">
							<ItemsControl.ItemTemplate>
								<DataTemplate x:DataType="vm:AlertItemViewModel">
									<Border Classes="alert-card">
										<StackPanel Spacing="0">
											<!-- Header Row with Priority Accent -->
											<StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,12">
												<Border Width="4" Height="40" Background="{Binding PriorityBrush}" CornerRadius="2" VerticalAlignment="Top"/>
												<StackPanel Spacing="8" HorizontalAlignment="Stretch">
													<!-- Title Row -->
													<StackPanel Orientation="Horizontal" Spacing="8">
														<Border Background="{Binding TypeBrush}" Width="12" Height="12" CornerRadius="2" VerticalAlignment="Center"/>
														<TextBlock Text="{Binding Title}" Classes="alert-title" TextWrapping="Wrap" MaxWidth="350"/>
													</StackPanel>
													<!-- Tags Row -->
													<StackPanel Orientation="Horizontal" Spacing="6">
														<Border Classes="tag"><TextBlock Text="{Binding Type}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="Medium"/></Border>
														<Border Classes="tag"><TextBlock Text="{Binding Priority}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="Medium"/></Border>
													</StackPanel>
												</StackPanel>
												<StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Top" HorizontalAlignment="Right">
													<Button Classes="action-btn-sm warning" Content="Expire" Command="{Binding Parent.ExpireAlertCommand}" CommandParameter="{Binding}"/>
													<Button Classes="action-btn-sm danger" Content="Delete" Command="{Binding Parent.DeleteAlertCommand}" CommandParameter="{Binding}"/>
												</StackPanel>
											</StackPanel>

											<!-- Message -->
											<TextBlock Text="{Binding Message}" Classes="alert-message" TextWrapping="Wrap" Margin="16,0,0,12"/>

											<!-- Link -->
											<StackPanel Orientation="Horizontal" Spacing="6" Margin="16,0,0,12" IsVisible="{Binding ExtraLink, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
												<ic:FluentIcon Icon="Link" IconSize="Size16" Foreground="{DynamicResource SuccessBrush}" VerticalAlignment="Center"/>
												<TextBlock Text="{Binding ExtraLink}" Foreground="{DynamicResource SuccessBrush}" FontSize="11" TextDecorations="Underline"/>
											</StackPanel>

											<!-- Meta Information -->
											<StackPanel Orientation="Horizontal" Spacing="16" Margin="16,0,0,0">
												<StackPanel Orientation="Horizontal" Spacing="4"><TextBlock Text="{Binding AudienceText}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/></StackPanel>
												<StackPanel Orientation="Horizontal" Spacing="4"><TextBlock Text="{Binding TimeFrameText}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/></StackPanel>
											</StackPanel>
										</StackPanel>
									</Border>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>

						<!-- Expired Alerts Section -->
						<StackPanel Margin="0,24,0,0">
							<TextBlock Text="RECENTLY EXPIRED" Classes="section-header"/>
							<ItemsControl ItemsSource="{Binding Alerts}">
								<ItemsControl.ItemTemplate>
									<DataTemplate x:DataType="vm:AlertItemViewModel">
										<Border Background="{DynamicResource PageBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,8" IsVisible="{Binding IsExpired}">
											<StackPanel Spacing="4">
												<StackPanel Orientation="Horizontal" Spacing="8">
													<TextBlock Text="{Binding Title}" FontSize="12" FontWeight="Medium" Foreground="{DynamicResource TextMutedBrush}"/>
													<Border Background="{DynamicResource PageBackgroundBrush}" CornerRadius="3" Padding="4,2" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
														<TextBlock Text="expired" FontSize="9" Foreground="{DynamicResource TextMutedBrush}" FontWeight="Medium"/>
													</Border>
												</StackPanel>
												<TextBlock Text="{Binding TimeFrameText}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
											</StackPanel>
										</Border>
									</DataTemplate>
								</ItemsControl.ItemTemplate>
							</ItemsControl>
						</StackPanel>
                    </StackPanel>
			</Grid>
		</Border>
    </Grid>
    </ScrollViewer>
</UserControl>