<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Southville8BEdgeUI.ViewModels.Admin"
             xmlns:converters="using:Southville8BEdgeUI.Converters"
             xmlns:ic="using:FluentIcons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="800"
             x:Class="Southville8BEdgeUI.Views.Admin.ChatView"
             x:DataType="vm:ChatViewModel"
             Background="{DynamicResource PageBackgroundBrush}">

    <UserControl.Resources>
        <converters:BoolToStringConverter x:Key="OnlineStatusConverter" TrueValue="Online" FalseValue="Offline"/>
        <converters:EqualityConverter x:Key="EqualityConverter" />
        <!-- Added inverse bool converter to replace unsupported ! syntax in bindings -->
        <converters:BooleanNegationConverter x:Key="InverseBoolConverter" />
        <converters:CollectionIsEmptyConverter x:Key="CollectionIsEmptyConverter" />
    </UserControl.Resources>

    <UserControl.Styles>
        <!-- RESPONSIVE TEXT STYLES -->

        <!-- Main Header -->
        <Style Selector="TextBlock.main-header">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>
        <Style Selector="TextBlock.main-header.tablet">
            <Setter Property="FontSize" Value="16"/>
        </Style>
        <Style Selector="TextBlock.main-header.mobile">
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <!-- Subtitle Text -->
        <Style Selector="TextBlock.subtitle">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
        </Style>
        <Style Selector="TextBlock.subtitle.tablet">
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style Selector="TextBlock.subtitle.mobile">
            <Setter Property="FontSize" Value="10"/>
        </Style>

        <!-- Chat Header Name -->
        <Style Selector="TextBlock.chat-header-name">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>
        <Style Selector="TextBlock.chat-header-name.tablet">
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style Selector="TextBlock.chat-header-name.mobile">
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- Contact Name -->
        <Style Selector="TextBlock.contact-name">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>
        <Style Selector="TextBlock.contact-name.tablet">
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="TextBlock.contact-name.mobile">
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- Message Text -->
        <Style Selector="TextBlock.message-text">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>
        <Style Selector="TextBlock.message-text.tablet">
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="TextBlock.message-text.mobile">
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- Label Text -->
        <Style Selector="TextBlock.label">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
        </Style>
        <Style Selector="TextBlock.label.tablet">
            <Setter Property="FontSize" Value="10"/>
        </Style>
        <Style Selector="TextBlock.label.mobile">
            <Setter Property="FontSize" Value="9"/>
        </Style>

        <!-- Light Text -->
        <Style Selector="TextBlock.light">
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
        </Style>

        <!-- Empty State Text -->
        <Style Selector="TextBlock.empty-title">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
        </Style>
        <Style Selector="TextBlock.empty-title.tablet">
            <Setter Property="FontSize" Value="16"/>
        </Style>
        <Style Selector="TextBlock.empty-title.mobile">
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <!-- RESPONSIVE CARD STYLES -->
        <Style Selector="Border.card">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BoxShadow" Value="0 2 8 0 #10000000"/>
        </Style>
        <Style Selector="Border.card.tablet">
            <Setter Property="CornerRadius" Value="10"/>
        </Style>
        <Style Selector="Border.card.mobile">
            <Setter Property="CornerRadius" Value="8"/>
        </Style>

        <!-- RESPONSIVE BUTTON STYLES -->
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="{DynamicResource DangerBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentTextOnAccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.primary:pointerover">
            <Setter Property="RenderTransform" Value="scale(1.02)"/>
        </Style>
        <Style Selector="Button.primary.tablet">
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="Button.primary.mobile">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style Selector="Button.secondary">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.secondary:pointerover">
            <Setter Property="RenderTransform" Value="scale(1.02)"/>
            <Setter Property="Background" Value="{DynamicResource PageBackgroundBrush}"/>
        </Style>
        <Style Selector="Button.secondary.tablet">
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="Button.secondary.mobile">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- Back Button Style -->
        <Style Selector="Button.back-button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.back-button:pointerover">
            <Setter Property="Background" Value="{DynamicResource PageBackgroundBrush}"/>
        </Style>
        <Style Selector="Button.back-button.tablet">
            <Setter Property="Padding" Value="6"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style Selector="Button.back-button.mobile">
            <Setter Property="Padding" Value="4"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- Conversation Item Styles -->
        <Style Selector="Button.conversation-item">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.conversation-item:pointerover">
            <Setter Property="Background" Value="{DynamicResource PageBackgroundBrush}"/>
        </Style>
        <Style Selector="Button.conversation-item.selected">
            <Setter Property="Background" Value="{DynamicResource InfoSoftBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InfoBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,3,0"/>
        </Style>
        <Style Selector="Button.conversation-item.tablet">
            <Setter Property="Padding" Value="14"/>
        </Style>
        <Style Selector="Button.conversation-item.mobile">
            <Setter Property="Padding" Value="12"/>
        </Style>

        <!-- Message Bubble Styles -->
        <Style Selector="Border.message-bubble">
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="MaxWidth" Value="320"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
        <Style Selector="Border.message-bubble.tablet">
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="MaxWidth" Value="280"/>
        </Style>
        <Style Selector="Border.message-bubble.mobile">
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="MaxWidth" Value="240"/>
        </Style>
        <!-- Sent messages - Use navigation color (DangerBrush/red) to match AdminShellView -->
        <Style Selector="Border.message-bubble.message-sent">
            <Setter Property="Background" Value="{DynamicResource DangerBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>
        <!-- Received messages - Use CardBackground with border for contrast -->
        <Style Selector="Border.message-bubble.message-received">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>

        <!-- Chat Icon Button Styles -->
        <Style Selector="Button.chat-icon">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.chat-icon:pointerover">
            <Setter Property="Background" Value="{DynamicResource PageBackgroundBrush}"/>
        </Style>
        <Style Selector="Button.chat-icon.tablet">
            <Setter Property="Padding" Value="6"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style Selector="Button.chat-icon.mobile">
            <Setter Property="Padding" Value="4"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- RESPONSIVE INPUT STYLES -->
        <Style Selector="TextBox, ComboBox">
            <Setter Property="Padding" Value="12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>
        <Style Selector="TextBox.tablet, ComboBox.tablet">
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="TextBox.mobile, ComboBox.mobile">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style Selector="TextBox.message-input">
            <Setter Property="CornerRadius" Value="24"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>
        <Style Selector="TextBox.message-input.tablet">
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="TextBox.message-input.mobile">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style Selector="Button.send-button">
            <Setter Property="CornerRadius" Value="24"/>
            <Setter Property="Padding" Value="20,12"/>
        </Style>
        <Style Selector="Button.send-button.tablet">
            <Setter Property="Padding" Value="18,10"/>
        </Style>
        <Style Selector="Button.send-button.mobile">
            <Setter Property="Padding" Value="16,8"/>
        </Style>

        <!-- RESPONSIVE LAYOUT STYLES -->
        <Style Selector="Grid.main-content">
            <Setter Property="Background" Value="{DynamicResource PageBackgroundBrush}"/>
        </Style>
        <Style Selector="Grid.main-content-tablet">
            <Setter Property="Background" Value="{DynamicResource PageBackgroundBrush}"/>
        </Style>
        <Style Selector="Grid.main-content-mobile">
            <Setter Property="Background" Value="{DynamicResource PageBackgroundBrush}"/>
        </Style>

        <!-- Avatar Styles -->
        <Style Selector="Border.avatar">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="CornerRadius" Value="20"/>
        </Style>
        <Style Selector="Border.avatar.tablet">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="CornerRadius" Value="18"/>
        </Style>
        <Style Selector="Border.avatar.mobile">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="CornerRadius" Value="16"/>
        </Style>

        <!-- Online Indicator Styles -->
        <Style Selector="Border.online-indicator">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Height" Value="6"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Background" Value="{DynamicResource SuccessBrush}"/>
        </Style>
        <Style Selector="Border.online-indicator.tablet">
            <Setter Property="Width" Value="5"/>
            <Setter Property="Height" Value="5"/>
            <Setter Property="CornerRadius" Value="2.5"/>
        </Style>
        <Style Selector="Border.online-indicator.mobile">
            <Setter Property="Width" Value="4"/>
            <Setter Property="Height" Value="4"/>
            <Setter Property="CornerRadius" Value="2"/>
        </Style>

        <!-- SCROLLBAR STYLES -->
        <Style Selector="ScrollBar">
            <Setter Property="AllowAutoHide" Value="True"/>
            <Setter Property="Margin" Value="0"/>
        </Style>
        <Style Selector="ScrollBar:vertical">
            <Setter Property="Width" Value="12"/>
            <Setter Property="Margin" Value="2,0,0,0"/>
        </Style>
        <Style Selector="ScrollBar:horizontal">
            <Setter Property="Height" Value="12"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>
        <!-- Removed global IsDirectionReversed to keep normal scroll behavior -->
        <Style Selector="ScrollBar /template/ Thumb">
            <Setter Property="Background" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="ScrollBar /template/ Thumb:pointerover">
            <Setter Property="Background" Value="{DynamicResource TextMutedBrush}"/>
        </Style>
        <Style Selector="ScrollBar /template/ Thumb:pressed">
            <Setter Property="Background" Value="{DynamicResource TextSecondaryBrush}"/>
        </Style>
        <Style Selector="ScrollBar /template/ RepeatButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
        </Style>
        <Style Selector="ScrollBar /template/ RepeatButton:pointerover">
            <Setter Property="Background" Value="{DynamicResource PageBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        </Style>
        <Style Selector="ScrollBar /template/ RepeatButton#PART_LineUpButton">
            <Setter Property="IsVisible" Value="False"/>
        </Style>
        <Style Selector="ScrollBar /template/ RepeatButton#PART_LineDownButton">
            <Setter Property="IsVisible" Value="False"/>
        </Style>
        <Style Selector="ScrollBar /template/ RepeatButton#PART_LineLeftButton">
            <Setter Property="IsVisible" Value="False"/>
        </Style>
        <Style Selector="ScrollBar /template/ RepeatButton#PART_LineRightButton">
            <Setter Property="IsVisible" Value="False"/>
        </Style>
        <Style Selector="ScrollViewer">
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        </Style>
        <Style Selector="ScrollViewer.mobile">
            <Setter Property="HorizontalScrollBarVisibility" Value="Hidden"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        </Style>
        <Style Selector="ScrollViewer.tablet">
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        </Style>
        
        <!-- Disable hover/active visuals on ListBox items -->
        <Style Selector="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ListBoxItem:pointerover">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ListBoxItem:selected">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ListBoxItem:pressed">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <!-- Disable hover/active visuals on ContentPresenter template part (without overriding child backgrounds) -->
        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ListBoxItem:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <!-- Modal Responsive Styles -->
        <Style Selector="Border.modal-container">
            <Setter Property="MaxWidth" Value="400"/>
            <Setter Property="Padding" Value="24"/>
        </Style>
        <Style Selector="Border.modal-container.tablet">
            <Setter Property="MaxWidth" Value="360"/>
            <Setter Property="Padding" Value="20"/>
        </Style>
        <Style Selector="Border.modal-container.mobile">
            <Setter Property="MaxWidth" Value="320"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="16"/>
        </Style>
    </UserControl.Styles>

    <Grid x:Name="MainGrid" Classes="main-content" ColumnDefinitions="360,*" Margin="24">
        <!-- Conversations List -->
        <Border x:Name="ConversationsCard" Grid.Column="0" Classes="card" Margin="0,0,12,0">
            <Grid RowDefinitions="Auto,Auto,*">
                <!-- Header -->
                <Border x:Name="ConversationsHeader" Grid.Row="0" Padding="20,20,20,16" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0">
                            <TextBlock x:Name="ConversationsHeaderText" Text="Messages" Classes="main-header"/>
                            <TextBlock x:Name="ConversationsSubtitleText" Text="Admin Communication Hub" Classes="subtitle"/>
                        </StackPanel>
                        <Button x:Name="NewChatButton" Grid.Column="1" Classes="primary" Command="{Binding StartNewChatCommand}" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <ic:FluentIcon Icon="Add" IconSize="Size20"/>
                                <TextBlock Text="New"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <!-- Search and Filter -->
                <Border Grid.Row="1" Padding="16" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                    <StackPanel Spacing="12">
                        <TextBox x:Name="SearchTextBox" Watermark="Search conversations..." Text="{Binding SearchText}" CornerRadius="8"/>
                        <ComboBox x:Name="UserTypeComboBox" PlaceholderText="All Users" ItemsSource="{Binding UserTypeOptions}" SelectedItem="{Binding SelectedUserType}" HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Border>

                <!-- Conversations List and Empty State -->
                <Grid Grid.Row="2">
                    <!-- Loading Indicator for Conversations -->
                    <StackPanel Spacing="16" HorizontalAlignment="Center" VerticalAlignment="Center" IsVisible="{Binding IsLoading}">
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                            <ic:FluentIcon Icon="ArrowClockwise" IconSize="Size16" Foreground="{DynamicResource IndigoBrush}"/>
                            <TextBlock Text="Loading conversations..." Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </StackPanel>

                    <Border IsVisible="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}">
                    <ScrollViewer x:Name="ConversationsScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" IsVisible="{Binding HasConversations}" AllowAutoHide="True">
                        <ItemsControl ItemsSource="{Binding FilteredConversations}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:ChatConversationViewModel">
                                    <Button Classes="conversation-item" Classes.selected="{Binding $parent[UserControl].((vm:ChatViewModel)DataContext).SelectedConversation, Converter={StaticResource EqualityConverter}, ConverterParameter={Binding}}" Command="{Binding $parent[UserControl].((vm:ChatViewModel)DataContext).SelectConversationCommand}" CommandParameter="{Binding}">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <Border Grid.Column="0" Classes="avatar" Background="{Binding RoleBrush}" Margin="0,0,12,0">
                                                <TextBlock Text="{Binding ContactInitials}" Classes="contact-name" FontWeight="SemiBold" Foreground="{Binding RoleTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" Spacing="4">
                                                <Grid ColumnDefinitions="*,Auto">
                                                    <TextBlock Grid.Column="0" Text="{Binding ContactName}" Classes="contact-name"/>
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                                        <Border Classes="online-indicator" VerticalAlignment="Center" IsVisible="{Binding IsOnline}"/>
                                                        <TextBlock Text="{Binding ContactRole}" FontSize="10" Classes="light"/>
                                                    </StackPanel>
                                                </Grid>
                                                <TextBlock Text="{Binding LastMessage}" Classes="light" FontSize="12" TextWrapping="Wrap" MaxLines="2"/>
                                                <TextBlock Text="{Binding LastMessageTimeText}" Classes="light" FontSize="10"/>
                                            </StackPanel>
                                            <Border Grid.Column="2" Background="{DynamicResource DangerBrush}" CornerRadius="10" MinWidth="20" Height="20" IsVisible="{Binding HasUnreadMessages}" VerticalAlignment="Top">
                                                <TextBlock Text="{Binding UnreadCount}" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource AccentTextOnAccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    </Border>

                    <!-- Empty state for conversations -->
                    <StackPanel Spacing="16" HorizontalAlignment="Center" VerticalAlignment="Center" 
                                IsVisible="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}">
                        <StackPanel IsVisible="{Binding HasConversations, Converter={StaticResource InverseBoolConverter}}">
                        <ic:FluentIcon Icon="ChatMultiple" IconSize="Size32" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="NoMessagesText" Text="No conversations found" Classes="empty-title"/>
                        <TextBlock Text="Try adjusting your search criteria" Classes="subtitle"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Chat Area -->
        <Border x:Name="ChatCard" Grid.Column="1" Classes="card" Margin="12,0,0,0">
            <Grid>
                <Grid RowDefinitions="Auto,*,Auto" IsVisible="{Binding HasSelectedConversation}">
                    <Border x:Name="ChatHeader" Grid.Row="0" Padding="20" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                            <Button x:Name="BackButton" Grid.Column="0" Classes="back-button" VerticalAlignment="Center" Margin="0,0,12,0" IsVisible="False">
                                <ic:FluentIcon Icon="ArrowLeft" IconSize="Size20"/>
                            </Button>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">
                                <Border Classes="avatar" Background="{Binding SelectedConversation.RoleBrush}">
                                    <TextBlock Text="{Binding SelectedConversation.ContactInitials}" Classes="contact-name" FontWeight="SemiBold" Foreground="{Binding SelectedConversation.RoleTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock x:Name="ChatHeaderNameText" Text="{Binding SelectedConversation.ContactName}" Classes="chat-header-name"/>
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Border Classes="online-indicator" VerticalAlignment="Center" IsVisible="{Binding SelectedConversation.IsOnline, FallbackValue=False}"/>
                                        <TextBlock x:Name="ChatHeaderRoleText" Text="{Binding SelectedConversation.ContactRole}" FontSize="12" Classes="light"/>
                                        <TextBlock Text="{Binding SelectedConversation.IsOnline, Converter={StaticResource OnlineStatusConverter}}" FontSize="12" Classes="light"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel x:Name="ChatHeaderButtons" Grid.Column="3" Orientation="Horizontal" Spacing="8">
                                <Button x:Name="CallButton" Classes="chat-icon">
                                    <ic:FluentIcon Icon="Call" IconSize="Size20"/>
                                </Button>
                                <Button x:Name="VideoButton" Classes="chat-icon">
                                    <ic:FluentIcon Icon="Video" IconSize="Size20"/>
                                </Button>
                                <Button x:Name="InfoButton" Classes="chat-icon" Command="{Binding ShowContactInfoCommand}">
                                    <ic:FluentIcon Icon="Info" IconSize="Size20"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1">
                        <!-- Loading Indicator for Messages -->
                        <StackPanel Spacing="16" HorizontalAlignment="Center" VerticalAlignment="Center" 
                                    IsVisible="{Binding IsLoadingMessages}">
                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                <ic:FluentIcon Icon="ArrowClockwise" IconSize="Size16" Foreground="{DynamicResource IndigoBrush}"/>
                                <TextBlock Text="Loading messages..." Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Messages List -->
                    <ListBox x:Name="MessagesListBox"
                             ItemsSource="{Binding SelectedConversation.Messages}"
                             Background="Transparent"
                             BorderThickness="0"
                             SelectionMode="Single"
                                 Margin="20"
                                 IsVisible="{Binding IsLoadingMessages, Converter={StaticResource InverseBoolConverter}}">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="vm:ChatMessageViewModel">
                                <StackPanel Margin="0,8">
                                        <Border Classes="message-bubble" 
                                                Classes.message-sent="{Binding IsFromCurrentUser}" 
                                                Classes.message-received="{Binding IsFromCurrentUser, Converter={StaticResource InverseBoolConverter}}">
                                            <TextBlock Text="{Binding Content}" 
                                                       Foreground="{Binding MessageTextBrush}" 
                                                       TextWrapping="Wrap" 
                                                       Classes="message-text"/>
                                    </Border>
                                        <StackPanel Orientation="Horizontal" 
                                                   HorizontalAlignment="{Binding MessageAlignment}" 
                                                   Spacing="4"
                                                   Margin="12,2,12,0"
                                                   IsVisible="{Binding IsFromCurrentUser}">
                                            <TextBlock Text="{Binding TimestampText}" 
                                                       FontSize="10" 
                                                       Classes="light"/>
                                            <!-- Status indicator for sent messages -->
                                            <ic:FluentIcon Icon="ArrowClockwise" 
                                                          IconSize="Size12" 
                                                          Foreground="{DynamicResource TextMutedBrush}"
                                                          IsVisible="{Binding IsSending}"/>
                                            <ic:FluentIcon Icon="Checkmark" 
                                                          IconSize="Size12" 
                                                          Foreground="{DynamicResource TextMutedBrush}"
                                                          IsVisible="{Binding IsSentStatus}"/>
                                        </StackPanel>
                                        <!-- Timestamp for received messages (no status indicator) -->
                                        <TextBlock Text="{Binding TimestampText}" 
                                                   FontSize="10" 
                                                   Classes="light" 
                                                   HorizontalAlignment="{Binding MessageAlignment}" 
                                                   Margin="12,2,12,0"
                                                   IsVisible="{Binding IsFromCurrentUser, Converter={StaticResource InverseBoolConverter}}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                    </ListBox>
                    </Grid>

                    <Border Grid.Row="2" Padding="20" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
                        <Grid x:Name="MessageInputGrid" ColumnDefinitions="*,Auto">
                            <TextBox x:Name="MessageTextBox" Grid.Column="0" Text="{Binding NewMessage}" Watermark="Type a message..." Classes="message-input" Margin="0,0,12,0" AcceptsReturn="False"/>
                            <Button x:Name="SendButton" Grid.Column="1" Classes="primary send-button" Command="{Binding SendMessageCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                    <ic:FluentIcon Icon="Send" IconSize="Size20"/>
                                    <TextBlock Text="Send"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Empty chat area state -->
                <StackPanel Spacing="16" HorizontalAlignment="Center" VerticalAlignment="Center" IsVisible="{Binding HasSelectedConversation, Converter={StaticResource InverseBoolConverter}}">
                    <ic:FluentIcon Icon="ChatMultiple" IconSize="Size32" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="NoConversationTitleText" Text="Select a conversation" Classes="empty-title"/>
                    <TextBlock x:Name="NoConversationSubtitleText" Text="Choose a conversation from the list to start messaging" Classes="subtitle"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Contact Info Modal Overlay -->
        <Border IsVisible="{Binding IsContactInfoModalVisible}" 
                Background="#80000000" 
                ZIndex="1000"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
            <Border Background="{DynamicResource CardBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="24"
                    MaxWidth="400"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    BoxShadow="0 8 32 0 #40000000"
                    Classes="modal-container">
                <Grid RowDefinitions="Auto,*,Auto">
                    <!-- Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,20" ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0"
                                   Text="Contact Information" 
                                   FontSize="18" 
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="1"
                                HorizontalAlignment="Right"
                                Background="Transparent"
                                BorderThickness="0"
                                Command="{Binding CloseContactInfoModalCommand}"
                                Padding="4"
                                VerticalAlignment="Center">
                            <ic:FluentIcon Icon="Dismiss" IconSize="Size20" Foreground="{DynamicResource TextMutedBrush}"/>
                        </Button>
                    </Grid>

                    <!-- Contact Info Content -->
                    <StackPanel Grid.Row="1" Spacing="16">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border Width="64" 
                                    Height="64" 
                                    Background="{Binding SelectedConversation.RoleBrush}" 
                                    CornerRadius="32"
                                    HorizontalAlignment="Left">
                                <TextBlock Text="{Binding SelectedConversation.ContactInitials}" 
                                           FontSize="24" 
                                           FontWeight="Bold"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding SelectedConversation.ContactName}" 
                                           FontSize="16" 
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding SelectedConversation.ContactRole}" 
                                           FontSize="12"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           Margin="0,4,0,0"/>
                                <TextBlock Text="{Binding SelectedConversation.IsOnline, Converter={StaticResource OnlineStatusConverter}}" 
                                           FontSize="12"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <!-- Actions -->
                    <StackPanel Grid.Row="2" Spacing="12" Margin="0,20,0,0">
                        <Button Content="Delete Conversation" 
                                Classes="danger"
                                Command="{Binding DeleteConversationCommand}"
                                HorizontalAlignment="Stretch"
                                Padding="16,12">
                            <Button.Styles>
                                <Style Selector="Button.danger">
                                    <Setter Property="Background" Value="{DynamicResource DangerBrush}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                                <Style Selector="Button.danger:pointerover">
                                    <Setter Property="Background" Value="#B91C1C"/>
                                </Style>
                            </Button.Styles>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>