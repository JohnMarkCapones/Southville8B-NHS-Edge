<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Southville8BEdgeUI.ViewModels.Admin"
             xmlns:ic="using:FluentIcons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="Southville8BEdgeUI.Views.Admin.ChangePasswordView"
             x:DataType="vm:ChangePasswordViewModel"
             Background="{DynamicResource PageBackgroundBrush}">

    <UserControl.Styles>
        <!-- Form Styles -->
        <Style Selector="TextBlock.form-title">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,24"/>
        </Style>

        <Style Selector="TextBlock.form-subtitle">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
        </Style>

        <Style Selector="TextBlock.field-label">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style Selector="TextBlock.required">
            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
        </Style>

        <Style Selector="TextBox.form-input">
            <Setter Property="Padding" Value="12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style Selector="Button.primary">
            <Setter Property="Background" Value="{DynamicResource IndigoBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentTextOnAccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>

        <Style Selector="Button.secondary">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style Selector="Border.error-message">
            <Setter Property="Background" Value="{DynamicResource DangerSoftBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style Selector="Border.loading-overlay">
            <Setter Property="Background" Value="#80000000"/>
            <Setter Property="IsVisible" Value="{Binding IsLoading}"/>
        </Style>
    </UserControl.Styles>

    <Grid>
        <ScrollViewer>
            <Border Classes="card" Margin="40" MaxWidth="600" HorizontalAlignment="Center">
                <StackPanel Spacing="0">
                    <!-- Header -->
                    <StackPanel Margin="0,0,0,32">
                        <TextBlock Text="Change Password" Classes="form-title"/>
                        <TextBlock Text="Update your password to keep your account secure. All fields are required." Classes="form-subtitle"/>
                    </StackPanel>

                    <!-- Error Message -->
                    <Border Classes="error-message" IsVisible="{Binding HasError}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <ic:FluentIcon Icon="Warning" IconSize="Size20" Foreground="{DynamicResource DangerBrush}"/>
                            <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource DangerBrush}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Password Form Fields -->
                    <StackPanel Spacing="0">
                        <!-- Current Password -->
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="Current Password" Classes="field-label"/>
                            <TextBlock Text="*" Classes="required"/>
                            <TextBox Text="{Binding CurrentPassword, Mode=TwoWay}" 
                                     Classes="form-input" 
                                     PasswordChar="●"
                                     Watermark="Enter your current password"
                                     IsEnabled="{Binding !IsLoading}"/>
                        </StackPanel>

                        <!-- New Password -->
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="New Password" Classes="field-label"/>
                            <TextBlock Text="*" Classes="required"/>
                            <TextBox Text="{Binding NewPassword, Mode=TwoWay}" 
                                     Classes="form-input" 
                                     PasswordChar="●"
                                     Watermark="Enter your new password (min. 8 characters)"
                                     IsEnabled="{Binding !IsLoading}"/>
                        </StackPanel>

                        <!-- Confirm Password -->
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="Confirm New Password" Classes="field-label"/>
                            <TextBlock Text="*" Classes="required"/>
                            <TextBox Text="{Binding ConfirmPassword, Mode=TwoWay}" 
                                     Classes="form-input" 
                                     PasswordChar="●"
                                     Watermark="Confirm your new password"
                                     IsEnabled="{Binding !IsLoading}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Action Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,32,0,0">
                        <Button Content="Cancel" Classes="secondary" Command="{Binding CancelCommand}" IsEnabled="{Binding !IsLoading}"/>
                        <Button Content="Change Password" Classes="primary" Command="{Binding ChangePasswordCommand}" IsEnabled="{Binding !IsLoading}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Border Classes="loading-overlay">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ic:FluentIcon Icon="ArrowSync" IconSize="Size32" Foreground="{DynamicResource AccentTextOnAccentBrush}"/>
                <TextBlock Text="Changing password..." 
                           Foreground="{DynamicResource AccentTextOnAccentBrush}" 
                           FontSize="16" 
                           Margin="0,12,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

