<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Southville8BEdgeUI.ViewModels.Admin"
             mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="800"
             x:Class="Southville8BEdgeUI.Views.Admin.EventDashboardView"
             x:DataType="vm:EventDashboardViewModel"
             Background="#F9FAFB">

	<UserControl.Styles>
		<!-- RESPONSIVE TEXT STYLES -->

		<!-- Main Header -->
		<Style Selector="TextBlock.main-header">
			<Setter Property="FontSize" Value="28"/>
			<Setter Property="FontWeight" Value="Bold"/>
			<Setter Property="Foreground" Value="#111827"/>
		</Style>
		<Style Selector="TextBlock.main-header.tablet">
			<Setter Property="FontSize" Value="24"/>
		</Style>
		<Style Selector="TextBlock.main-header.mobile">
			<Setter Property="FontSize" Value="20"/>
		</Style>

		<!-- Subtitle Text -->
		<Style Selector="TextBlock.subtitle">
			<Setter Property="FontSize" Value="14"/>
			<Setter Property="Foreground" Value="#6B7280"/>
		</Style>
		<Style Selector="TextBlock.subtitle.tablet">
			<Setter Property="FontSize" Value="13"/>
		</Style>
		<Style Selector="TextBlock.subtitle.mobile">
			<Setter Property="FontSize" Value="12"/>
		</Style>

		<!-- Base TextBlock Style -->
		<Style Selector="TextBlock">
			<Setter Property="Foreground" Value="#111827"/>
		</Style>
		<Style Selector="TextBlock.light">
			<Setter Property="Foreground" Value="#6B7280"/>
		</Style>

		<!-- Label Text -->
		<Style Selector="TextBlock.label">
			<Setter Property="FontSize" Value="11"/>
			<Setter Property="FontWeight" Value="Medium"/>
			<Setter Property="Foreground" Value="#6B7280"/>
		</Style>
		<Style Selector="TextBlock.label.tablet">
			<Setter Property="FontSize" Value="10"/>
		</Style>
		<Style Selector="TextBlock.label.mobile">
			<Setter Property="FontSize" Value="9"/>
		</Style>

		<!-- Stat Values -->
		<Style Selector="TextBlock.stat-value">
			<Setter Property="FontSize" Value="28"/>
			<Setter Property="FontWeight" Value="Bold"/>
			<Setter Property="Foreground" Value="#111827"/>
		</Style>
		<Style Selector="TextBlock.stat-value.tablet">
			<Setter Property="FontSize" Value="24"/>
		</Style>
		<Style Selector="TextBlock.stat-value.mobile">
			<Setter Property="FontSize" Value="20"/>
		</Style>

		<!-- Event Title Text -->
		<Style Selector="TextBlock.event-title">
			<Setter Property="FontSize" Value="18"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
		</Style>
		<Style Selector="TextBlock.event-title.tablet">
			<Setter Property="FontSize" Value="16"/>
		</Style>
		<Style Selector="TextBlock.event-title.mobile">
			<Setter Property="FontSize" Value="14"/>
		</Style>

		<!-- Event Detail Text -->
		<Style Selector="TextBlock.event-detail">
			<Setter Property="FontSize" Value="14"/>
			<Setter Property="FontWeight" Value="Medium"/>
		</Style>
		<Style Selector="TextBlock.event-detail.tablet">
			<Setter Property="FontSize" Value="13"/>
		</Style>
		<Style Selector="TextBlock.event-detail.mobile">
			<Setter Property="FontSize" Value="12"/>
		</Style>

		<!-- Empty State Text -->
		<Style Selector="TextBlock.empty-title">
			<Setter Property="FontSize" Value="18"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
		</Style>
		<Style Selector="TextBlock.empty-title.tablet">
			<Setter Property="FontSize" Value="16"/>
		</Style>
		<Style Selector="TextBlock.empty-title.mobile">
			<Setter Property="FontSize" Value="14"/>
		</Style>

		<!-- RESPONSIVE CARD STYLES -->

		<!-- Main Card Style -->
		<Style Selector="Border.card">
			<Setter Property="Background" Value="White"/>
			<Setter Property="BorderBrush" Value="#E5E7EB"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="CornerRadius" Value="12"/>
			<Setter Property="Padding" Value="20"/>
			<Setter Property="BoxShadow" Value="0 2 8 0 #10000000"/>
		</Style>
		<Style Selector="Border.card.tablet">
			<Setter Property="Padding" Value="16"/>
		</Style>
		<Style Selector="Border.card.mobile">
			<Setter Property="Padding" Value="12"/>
		</Style>

		<!-- Event Card Styles -->
		<Style Selector="Border.event-card">
			<Setter Property="Background" Value="White"/>
			<Setter Property="BorderBrush" Value="#E5E7EB"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="CornerRadius" Value="12"/>
			<Setter Property="Padding" Value="20"/>
			<Setter Property="BoxShadow" Value="0 1 3 0 #1000000F"/>
			<Setter Property="Width" Value="380"/>
			<Setter Property="Margin" Value="0,0,20,20"/>
			<Setter Property="Transitions">
				<Transitions>
					<BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.2"/>
					<TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1"/>
				</Transitions>
			</Setter>
		</Style>
		<Style Selector="Border.event-card:pointerover">
			<Setter Property="BoxShadow" Value="0 4 12 0 #20000000"/>
			<Setter Property="RenderTransform" Value="translate(-2px)"/>
		</Style>
		<Style Selector="Border.event-card.tablet">
			<Setter Property="Padding" Value="16"/>
			<Setter Property="Width" Value="330"/>
			<Setter Property="Margin" Value="0,0,16,16"/>
		</Style>
		<Style Selector="Border.event-card.mobile">
			<Setter Property="Padding" Value="12"/>
			<Setter Property="Width" Value="100"/>
			<Setter Property="Margin" Value="0,0,0,12"/>
		</Style>

		<!-- RESPONSIVE BUTTON STYLES -->

		<!-- Primary Button -->
		<Style Selector="Button.primary">
			<Setter Property="Background" Value="#4F46E5"/>
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="CornerRadius" Value="8"/>
			<Setter Property="Padding" Value="16,10"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
			<Setter Property="FontSize" Value="14"/>
			<Setter Property="Transitions">
				<Transitions>
					<TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1"/>
				</Transitions>
			</Setter>
		</Style>
		<Style Selector="Button.primary:pointerover">
			<Setter Property="RenderTransform" Value="scale(1.02)"/>
		</Style>
		<Style Selector="Button.primary.tablet">
			<Setter Property="Padding" Value="14,8"/>
			<Setter Property="FontSize" Value="13"/>
		</Style>
		<Style Selector="Button.primary.mobile">
			<Setter Property="Padding" Value="12,6"/>
			<Setter Property="FontSize" Value="12"/>
		</Style>

		<!-- Secondary Button -->
		<Style Selector="Button.secondary">
			<Setter Property="Background" Value="White"/>
			<Setter Property="Foreground" Value="#374151"/>
			<Setter Property="BorderBrush" Value="#D1D5DB"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="CornerRadius" Value="8"/>
			<Setter Property="Padding" Value="16,10"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
			<Setter Property="FontSize" Value="14"/>
			<Setter Property="Transitions">
				<Transitions>
					<TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1"/>
				</Transitions>
			</Setter>
		</Style>
		<Style Selector="Button.secondary:pointerover">
			<Setter Property="RenderTransform" Value="scale(1.02)"/>
			<Setter Property="Background" Value="#F9FAFB"/>
		</Style>
		<Style Selector="Button.secondary.tablet">
			<Setter Property="Padding" Value="14,8"/>
			<Setter Property="FontSize" Value="13"/>
		</Style>
		<Style Selector="Button.secondary.mobile">
			<Setter Property="Padding" Value="12,6"/>
			<Setter Property="FontSize" Value="12"/>
		</Style>

		<!-- Danger Button -->
		<Style Selector="Button.danger">
			<Setter Property="Background" Value="#EF4444"/>
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="CornerRadius" Value="8"/>
			<Setter Property="Padding" Value="12,8"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
			<Setter Property="FontSize" Value="12"/>
		</Style>
		<Style Selector="Button.danger:pointerover">
			<Setter Property="Background" Value="#DC2626"/>
		</Style>
		<Style Selector="Button.danger.tablet">
			<Setter Property="Padding" Value="10,6"/>
			<Setter Property="FontSize" Value="11"/>
		</Style>
		<Style Selector="Button.danger.mobile">
			<Setter Property="Padding" Value="8,4"/>
			<Setter Property="FontSize" Value="10"/>
		</Style>

		<!-- RESPONSIVE INPUT STYLES -->

		<Style Selector="TextBox.search-input">
			<Setter Property="Padding" Value="12"/>
			<Setter Property="FontSize" Value="14"/>
			<Setter Property="CornerRadius" Value="8"/>
			<Setter Property="BorderBrush" Value="#D1D5DB"/>
			<Setter Property="BorderThickness" Value="1"/>
		</Style>
		<Style Selector="TextBox.search-input.tablet">
			<Setter Property="Padding" Value="10"/>
			<Setter Property="FontSize" Value="13"/>
		</Style>
		<Style Selector="TextBox.search-input.mobile">
			<Setter Property="Padding" Value="8"/>
			<Setter Property="FontSize" Value="12"/>
		</Style>

		<Style Selector="ComboBox.filter-combo">
			<Setter Property="Padding" Value="12"/>
			<Setter Property="FontSize" Value="14"/>
			<Setter Property="CornerRadius" Value="8"/>
			<Setter Property="BorderBrush" Value="#D1D5DB"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="MinWidth" Value="120"/>
		</Style>
		<Style Selector="ComboBox.filter-combo.tablet">
			<Setter Property="Padding" Value="10"/>
			<Setter Property="FontSize" Value="13"/>
			<Setter Property="MinWidth" Value="100"/>
		</Style>
		<Style Selector="ComboBox.filter-combo.mobile">
			<Setter Property="Padding" Value="8"/>
			<Setter Property="FontSize" Value="12"/>
			<Setter Property="MinWidth" Value="80"/>
		</Style>

		<!-- RESPONSIVE LAYOUT STYLES -->

		<Style Selector="StackPanel.main-content">
			<Setter Property="Margin" Value="40"/>
			<Setter Property="Spacing" Value="24"/>
		</Style>
		<Style Selector="StackPanel.main-content-tablet">
			<Setter Property="Margin" Value="20"/>
			<Setter Property="Spacing" Value="16"/>
		</Style>
		<Style Selector="StackPanel.main-content-mobile">
			<Setter Property="Margin" Value="12"/>
			<Setter Property="Spacing" Value="12"/>
		</Style>

		<!-- Status Indicator Styles -->
		<Style Selector="Border.status-indicator">
			<Setter Property="Width" Value="8"/>
			<Setter Property="Height" Value="8"/>
			<Setter Property="CornerRadius" Value="4"/>
		</Style>
		<Style Selector="Border.status-indicator.tablet">
			<Setter Property="Width" Value="6"/>
			<Setter Property="Height" Value="6"/>
			<Setter Property="CornerRadius" Value="3"/>
		</Style>
		<Style Selector="Border.status-indicator.mobile">
			<Setter Property="Width" Value="4"/>
			<Setter Property="Height" Value="4"/>
			<Setter Property="CornerRadius" Value="2"/>
		</Style>
	</UserControl.Styles>

	<ScrollViewer>
		<StackPanel x:Name="MainStackPanel" Classes="main-content">

			<!-- Header -->
			<Grid x:Name="HeaderGrid" ColumnDefinitions="*,Auto">
				<StackPanel Grid.Column="0">
					<TextBlock x:Name="MainHeaderText" Text="Event Management" Classes="main-header"/>
					<TextBlock x:Name="SubtitleText" Text="Create and manage school events, activities, and announcements" Classes="subtitle"/>
				</StackPanel>

				<StackPanel x:Name="HeaderButtons" Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
					<Button x:Name="FilterButton" Content="🔍 Filter" Classes="secondary" Command="{Binding FilterEventsCommand}"/>
					<Button x:Name="CreateButton" Content="➕ Create Event" Classes="primary" Command="{Binding CreateEventCommand}"/>
				</StackPanel>
			</Grid>

			<!-- Stat Cards -->
			<Grid x:Name="StatsGrid" ColumnDefinitions="*,*,*,*">
				<!-- Total Events -->
				<Border Grid.Column="0" x:Name="StatsCard1" Classes="card" Margin="0,0,12,0">
					<Grid ColumnDefinitions="*,Auto">
						<StackPanel Grid.Column="0" Spacing="4">
							<TextBlock Text="Total Events" Classes="label"/>
							<TextBlock x:Name="TotalEventsValue" Text="{Binding TotalEvents}" Classes="stat-value"/>
							<TextBlock Text="All time events" Classes="light" FontSize="12"/>
						</StackPanel>
						<Border Grid.Column="1" Width="40" Height="40" Background="#EBF8FF" CornerRadius="8">
							<Path Data="M19 3h-1V1h-2v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11zM7 10h5v5H7z" Fill="#3B82F6" Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
						</Border>
					</Grid>
				</Border>
				<!-- This Week -->
				<Border Grid.Column="1" x:Name="StatsCard2" Classes="card" Margin="12,0">
					<Grid ColumnDefinitions="*,Auto">
						<StackPanel Grid.Column="0" Spacing="4">
							<TextBlock Text="This Week" Classes="label"/>
							<TextBlock x:Name="ThisWeekEventsValue" Text="{Binding ThisWeekEvents}" Classes="stat-value"/>
							<TextBlock Text="Current week events" Classes="light" FontSize="12"/>
						</StackPanel>
						<Border Grid.Column="1" Width="40" Height="40" Background="#DBEAFE" CornerRadius="8">
							<Path Data="M9 11H7v6h2v-6zm4 0h-2v6h2v-6zm4 0h-2v6h2v-6zm2.5-5H18V4c0-.55-.45-1-1-1s-1 .45-1 1v2H8V4c0-.55-.45-1-1-1s-1 .45-1 1v2H4.5C3.67 6 3 6.67 3 7.5v11C3 19.33 3.67 20 4.5 20h15c.83 0 1.5-.67 1.5-1.5v-11C21 6.67 20.33 6 19.5 6z" Fill="#2563EB" Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
						</Border>
					</Grid>
				</Border>
				<!-- Upcoming -->
				<Border Grid.Column="2" x:Name="StatsCard3" Classes="card" Margin="12,0">
					<Grid ColumnDefinitions="*,Auto">
						<StackPanel Grid.Column="0" Spacing="4">
							<TextBlock Text="Upcoming" Classes="label"/>
							<TextBlock x:Name="UpcomingEventsValue" Text="{Binding UpcomingEvents}" Classes="stat-value"/>
							<TextBlock Text="Future events" Classes="light" FontSize="12"/>
						</StackPanel>
						<Border Grid.Column="1" Width="40" Height="40" Background="#D1FAE5" CornerRadius="8">
							<Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm3.5 6L12 10.5 8.5 8 11 5.5 13 7.5 15.5 8z" Fill="#059669" Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
						</Border>
					</Grid>
				</Border>
				<!-- Past Events -->
				<Border Grid.Column="3" x:Name="StatsCard4" Classes="card" Margin="12,0,0,0">
					<Grid ColumnDefinitions="*,Auto">
						<StackPanel Grid.Column="0" Spacing="4">
							<TextBlock Text="Past Events" Classes="label"/>
							<TextBlock x:Name="PastEventsValue" Text="{Binding PastEvents}" Classes="stat-value"/>
							<TextBlock Text="Completed events" Classes="light" FontSize="12"/>
						</StackPanel>
						<Border Grid.Column="1" Width="40" Height="40" Background="#F3F4F6" CornerRadius="8">
							<Path Data="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" Fill="#6B7280" Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
						</Border>
					</Grid>
				</Border>
			</Grid>

			<!-- Filter and Search Bar -->
			<Border x:Name="FilterCard" Classes="card">
				<Grid x:Name="FilterGrid" ColumnDefinitions="*,Auto,Auto,Auto,Auto">
					<TextBox x:Name="SearchInput" Grid.Column="0"
                             Classes="search-input"
                             Watermark="Search events..."
                             VerticalAlignment="Center"
                             Text="{Binding SearchText}"/>
					<Border Grid.Column="1" Background="#E5E7EB" Width="1" Margin="12,0"/>
					<ComboBox x:Name="StatusFilter" Grid.Column="2"
                              Classes="filter-combo"
                              PlaceholderText="All Status"
                              Margin="12,0"
                              ItemsSource="{Binding StatusOptions}"
                              SelectedItem="{Binding SelectedStatus}"/>
					<ComboBox x:Name="TypeFilter" Grid.Column="3"
                              Classes="filter-combo"
                              PlaceholderText="All Types"
                              Margin="12,0"
                              ItemsSource="{Binding TypeOptions}"
                              SelectedItem="{Binding SelectedType}"/>
					<ComboBox x:Name="LocationFilter" Grid.Column="4"
                              Classes="filter-combo"
                              PlaceholderText="All Locations"
                              Margin="12,0"
                              ItemsSource="{Binding LocationOptions}"
                              SelectedItem="{Binding SelectedLocation}"/>
				</Grid>
			</Border>

			<!-- Events Grid -->
			<ItemsControl x:Name="EventsGrid" ItemsSource="{Binding FilteredEvents}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<WrapPanel Orientation="Horizontal"/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemTemplate>
					<DataTemplate DataType="vm:EventViewModel">
						<Border x:Name="EventCard" Classes="event-card">
							<StackPanel Spacing="16">
								<Grid ColumnDefinitions="*,Auto">
									<StackPanel Grid.Column="0">
										<TextBlock x:Name="EventTitleText" Text="{Binding Title}" Classes="event-title"/>
										<TextBlock x:Name="EventTypeText" Text="{Binding Type}" Classes="light" FontSize="12"/>
									</StackPanel>
									<Border Grid.Column="1"
                                            x:Name="StatusIndicator"
                                            Classes="status-indicator"
                                            Background="{Binding StatusColor}"/>
								</Grid>

								<Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto">
									<StackPanel Grid.Column="0" Grid.Row="0" Spacing="4">
										<TextBlock Text="Status" Classes="label"/>
										<TextBlock x:Name="StatusText" Text="{Binding Status}" Classes="event-detail"/>
									</StackPanel>
									<StackPanel Grid.Column="1" Grid.Row="0" Spacing="4">
										<TextBlock Text="Date" Classes="label"/>
										<TextBlock x:Name="DateText" Text="{Binding DateRange}" Classes="event-detail"/>
									</StackPanel>
									<StackPanel Grid.Column="0" Grid.Row="1" Spacing="4">
										<TextBlock Text="Time" Classes="label"/>
										<TextBlock x:Name="TimeText" Text="{Binding TimeRange}" Classes="event-detail"/>
									</StackPanel>
									<StackPanel Grid.Column="1" Grid.Row="1" Spacing="4">
										<TextBlock Text="Location" Classes="label"/>
										<TextBlock x:Name="LocationText" Text="{Binding Location}" Classes="event-detail"/>
									</StackPanel>
									<StackPanel Grid.Column="0" Grid.Row="2" Spacing="4">
										<TextBlock Text="Organizer" Classes="label"/>
										<TextBlock x:Name="OrganizerText" Text="{Binding Organizer}" Classes="event-detail"/>
									</StackPanel>
									<StackPanel Grid.Column="1" Grid.Row="2" Spacing="4">
										<TextBlock Text="Attendees" Classes="label"/>
										<TextBlock x:Name="AttendeesText" Text="{Binding AttendeeInfo}" Classes="event-detail"/>
									</StackPanel>
								</Grid>

								<StackPanel Spacing="4">
									<TextBlock Text="Description" Classes="label"/>
									<TextBlock x:Name="DescriptionText" Text="{Binding Description}"
                                               Classes="event-detail"
                                               TextWrapping="Wrap"
                                               MaxLines="2"/>
								</StackPanel>

								<!-- Progress bar for attendance if applicable -->
								<StackPanel Spacing="4" IsVisible="{Binding MaxAttendees}">
									<TextBlock Text="Attendance" Classes="label"/>
									<ProgressBar Value="{Binding AttendancePercentage}"
                                               Minimum="0"
                                               Maximum="100"
                                               Height="6"
                                               CornerRadius="3"
                                               Foreground="#10B981"/>
								</StackPanel>

								<Grid ColumnDefinitions="*,Auto,Auto">
									<Button Grid.Column="0"
                                            x:Name="ViewDetailsButton"
                                            Content="View Details"
                                            Classes="secondary"
                                            Command="{Binding $parent[UserControl].((vm:EventDashboardViewModel)DataContext).ViewEventDetailsCommand}"
                                            CommandParameter="{Binding}"/>
									<Button Grid.Column="1"
                                            x:Name="EditButton"
                                            Content="Edit"
                                            Classes="secondary"
                                            Command="{Binding $parent[UserControl].((vm:EventDashboardViewModel)DataContext).EditEventCommand}"
                                            CommandParameter="{Binding}"
                                            IsEnabled="{Binding CanEdit}"
                                            Margin="8,0,0,0"/>
									<Button Grid.Column="2"
                                            x:Name="DeleteButton"
                                            Content="Delete"
                                            Classes="danger"
                                            Command="{Binding $parent[UserControl].((vm:EventDashboardViewModel)DataContext).DeleteEventCommand}"
                                            CommandParameter="{Binding}"
                                            Margin="8,0,0,0"/>
								</Grid>
							</StackPanel>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>

			<!-- Empty State -->
			<Border x:Name="EmptyStateCard" Classes="card"
                    IsVisible="{Binding !HasFilteredEvents}"
                    HorizontalAlignment="Center"
                    Padding="40">
				<StackPanel Spacing="16" HorizontalAlignment="Center">
					<Path Data="M19 3h-1V1h-2v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11zM7 10h5v5H7z"
                          Fill="#9CA3AF"
                          Width="48"
                          Height="48"
                          HorizontalAlignment="Center"/>
					<TextBlock x:Name="EmptyTitleText" Text="No events found" Classes="empty-title" HorizontalAlignment="Center"/>
					<TextBlock x:Name="EmptySubtitleText" Text="Try adjusting your search criteria or create a new event" Classes="light" HorizontalAlignment="Center"/>
				</StackPanel>
			</Border>

		</StackPanel>
	</ScrollViewer>
</UserControl>