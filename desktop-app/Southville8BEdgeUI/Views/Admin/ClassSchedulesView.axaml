<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Southville8BEdgeUI.ViewModels.Admin"
             xmlns:converters="using:Southville8BEdgeUI.Converters"
             x:Class="Southville8BEdgeUI.Views.Admin.ClassSchedulesView"
             x:DataType="vm:ClassSchedulesViewModel"
             Background="{DynamicResource PageBackgroundBrush}">

    <UserControl.Resources>
        <converters:BooleanNegationConverter x:Key="BooleanNegationConverter"/>
        <converters:CountToVisibilityConverter x:Key="CountToVisibilityConverter"/>
    </UserControl.Resources>

    <UserControl.Styles>
        <!-- RESPONSIVE TEXT STYLES -->
        <Style Selector="TextBlock.main-header">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>
        <Style Selector="TextBlock.main-header.tablet">
            <Setter Property="FontSize" Value="24"/>
        </Style>
        <Style Selector="TextBlock.main-header.mobile">
            <Setter Property="FontSize" Value="20"/>
        </Style>

        <Style Selector="TextBlock.subtitle">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
        </Style>
        <Style Selector="TextBlock.subtitle.tablet">
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="TextBlock.subtitle.mobile">
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>
        <Style Selector="TextBlock.light">
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
        </Style>

        <!-- CARD STYLES -->
        <Style Selector="Border.card">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>
        <Style Selector="Border.card.mobile">
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style Selector="Border.card.tablet">
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>

        <!-- BUTTON STYLES -->
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryForegroundBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.secondary">
            <Setter Property="Background" Value="{DynamicResource SecondaryBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="16,8"/>
        </Style>
        <Style Selector="Button.tertiary">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
        </Style>

        <!-- STATS CARD STYLES -->
        <Style Selector="Border.stat-card">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
        </Style>
        <Style Selector="Border.stat-card.mobile">
            <Setter Property="Padding" Value="16"/>
        </Style>
        <Style Selector="Border.stat-card.tablet">
            <Setter Property="Padding" Value="18"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer x:Name="MainScrollViewer" 
                  HorizontalScrollBarVisibility="Disabled" 
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="24" Margin="24">
            
            <!-- HEADER SECTION -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Class Schedules" 
                               Classes="main-header"/>
                    <TextBlock Text="Manage class schedules, view conflicts, and assign students" 
                               Classes="subtitle"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" 
                            Orientation="Horizontal" 
                            Spacing="12" 
                            VerticalAlignment="Center">
                    <Button Classes="secondary" 
                            Command="{Binding RefreshDataCommand}"
                            ToolTip.Tip="Refresh schedule data">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="🔄" FontSize="16"/>
                            <TextBlock Text="Refresh" FontSize="14"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- STATISTICS CARDS -->
            <Grid x:Name="StatsGrid" Classes="stats-section">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Border Grid.Column="0" Classes="stat-card">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Total Schedules" 
                                   FontSize="12" 
                                   Classes="light"/>
                        <TextBlock Text="{Binding TotalSchedules}" 
                                   FontSize="24" 
                                   FontWeight="Bold"/>
                    </StackPanel>
                </Border>
                
                <Border Grid.Column="1" Classes="stat-card">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Active Schedules" 
                                   FontSize="12" 
                                   Classes="light"/>
                        <TextBlock Text="{Binding ActiveSchedules}" 
                                   FontSize="24" 
                                   FontWeight="Bold"/>
                    </StackPanel>
                </Border>
                
                <Border Grid.Column="2" Classes="stat-card">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Conflicts" 
                                   FontSize="12" 
                                   Classes="light"/>
                        <TextBlock Text="{Binding ConflictCount}" 
                                   FontSize="24" 
                                   FontWeight="Bold"/>
                    </StackPanel>
                </Border>
                
                <Border Grid.Column="3" Classes="stat-card">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Teachers" 
                                   FontSize="12" 
                                   Classes="light"/>
                        <TextBlock Text="{Binding TeacherCount}" 
                                   FontSize="24" 
                                   FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- FILTERS SECTION -->
            <Border x:Name="FilterGrid" Classes="card filters-section">
                <StackPanel Spacing="16">
                    <TextBlock Text="Filters" 
                               FontSize="16" 
                               FontWeight="SemiBold"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBox Grid.Column="0" 
                                 Text="{Binding SearchText}" 
                                 Watermark="Search schedules..."
                                 Classes="search-input"/>
                        
                        <ComboBox Grid.Column="1" 
                                  ItemsSource="{Binding Sections}"
                                  SelectedItem="{Binding SelectedSection}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        
                        <ComboBox Grid.Column="2" 
                                  ItemsSource="{Binding Teachers}"
                                  SelectedItem="{Binding SelectedTeacher}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding FullName}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        
                        <ComboBox Grid.Column="3" 
                                  ItemsSource="{Binding DayOptions}"
                                  SelectedItem="{Binding SelectedDay}"/>
                        
                        <ComboBox Grid.Column="4" 
                                  ItemsSource="{Binding SchoolYears}"
                                  SelectedItem="{Binding SelectedSchoolYear}"/>
                        
                        <Button Grid.Column="5" 
                                Classes="tertiary" 
                                Command="{Binding ClearFiltersCommand}">
                            <TextBlock Text="Clear"/>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- SCHEDULES TABLE -->
            <Border Classes="card">
                <Grid>
                    <!-- Loading Indicator -->
                    <Border IsVisible="{Binding IsLoading}" 
                            Background="{DynamicResource CardBackgroundBrush}"
                            Opacity="0.9"
                            ZIndex="10">
                        <StackPanel HorizontalAlignment="Center" 
                                    VerticalAlignment="Center" 
                                    Spacing="16">
                            <TextBlock Text="⏳" FontSize="32" HorizontalAlignment="Center"/>
                            <TextBlock Text="Loading schedules..." 
                                       FontSize="16" 
                                       HorizontalAlignment="Center"
                                       Foreground="{DynamicResource TextMutedBrush}"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Empty State -->
                    <Border IsVisible="{Binding IsEmptyStateVisible}">
                        <StackPanel HorizontalAlignment="Center" 
                                    VerticalAlignment="Center" 
                                    Spacing="16">
                            <TextBlock Text="📅" FontSize="48" HorizontalAlignment="Center" Opacity="0.5"/>
                            <TextBlock Text="No schedules found" 
                                       FontSize="18" 
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       Foreground="{DynamicResource TextMutedBrush}"/>
                            <TextBlock Text="Click 'Refresh' to reload data" 
                                       FontSize="14" 
                                       HorizontalAlignment="Center"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       MaxWidth="300"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Schedule Cards -->
                    <ScrollViewer IsVisible="{Binding IsDataGridVisible}">
                        <ItemsControl ItemsSource="{Binding FilteredSchedules}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Spacing="12"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Classes="card" Padding="16" Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <!-- Subject Color Indicator -->
                                            <Border Grid.Column="0" 
                                                    Width="4" 
                                                    Height="60" 
                                                    Background="{Binding SubjectColor}"
                                                    CornerRadius="2"
                                                    Margin="0,0,12,0"/>
                                            
                                            <!-- Schedule Details -->
                                            <StackPanel Grid.Column="1" Spacing="4">
                                                <TextBlock Text="{Binding SubjectName}" 
                                                           FontSize="16" 
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <TextBlock Text="{Binding TeacherName}" 
                                                           FontSize="14"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                <TextBlock Text="{Binding SectionName}" 
                                                           FontSize="12"
                                                           Foreground="{DynamicResource TextMutedBrush}"/>
                                                <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,8,0,0">
                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <TextBlock Text="📍" FontSize="12"/>
                                                        <TextBlock Text="{Binding RoomNumber}" 
                                                                   FontSize="12"
                                                                   Foreground="{DynamicResource TextMutedBrush}"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <TextBlock Text="🏢" FontSize="12"/>
                                                        <TextBlock Text="{Binding BuildingName}" 
                                                                   FontSize="12"
                                                                   Foreground="{DynamicResource TextMutedBrush}"/>
                                                    </StackPanel>
                                                </StackPanel>
                                                
                                                <!-- School Year and Semester -->
                                                <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,4,0,0">
                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <TextBlock Text="📅" FontSize="12"/>
                                                        <TextBlock Text="{Binding SchoolYear}" 
                                                                   FontSize="12"
                                                                   Foreground="{DynamicResource TextMutedBrush}"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <TextBlock Text="📚" FontSize="12"/>
                                                        <TextBlock Text="{Binding Semester}" 
                                                                   FontSize="12"
                                                                   Foreground="{DynamicResource TextMutedBrush}"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </StackPanel>
                                            
                                            <!-- Time and Day -->
                                            <StackPanel Grid.Column="2" Spacing="8" HorizontalAlignment="Right">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <Border Background="{DynamicResource AccentBrush}" 
                                                            CornerRadius="12" 
                                                            Padding="8,4">
                                                        <TextBlock Text="{Binding DisplayDay}" 
                                                                   FontSize="14" 
                                                                   FontWeight="Bold"
                                                                   Foreground="White"
                                                                   HorizontalAlignment="Center"/>
                                                    </Border>
                                                    <Border Background="#FF5733"  
                                                            CornerRadius="12" 
                                                            Padding="8,4"
                                                            MinWidth="100">
                                                        <TextBlock Text="{Binding TimeRange, FallbackValue='NO TIME'}" 
                                                                   FontSize="14" 
                                                                   FontWeight="Bold"
                                                                   Foreground="White"
                                                                   HorizontalAlignment="Center"/>
                                                    </Border>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>