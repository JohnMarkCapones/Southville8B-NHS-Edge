<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Southville8BEdgeUI.ViewModels.Admin"
             xmlns:ic="using:FluentIcons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="Southville8BEdgeUI.Views.Admin.UserDetailView"
             x:DataType="vm:UserDetailViewModel"
             Background="{DynamicResource ProfileBackgroundBrush}">

    <UserControl.Styles>
        <!-- Profile Card -->
        <Style Selector="Border.profile-card">
            <Setter Property="Background" Value="{DynamicResource ProfileCardBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="40"/>
            <Setter Property="BoxShadow" Value="0 1 3 0 #00000008"/>
        </Style>
        
        <!-- Info Card -->
        <Style Selector="Border.info-card">
            <Setter Property="Background" Value="{DynamicResource ProfileCardBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="32"/>
            <Setter Property="BoxShadow" Value="0 1 2 0 #00000004"/>
        </Style>
        
        <!-- Section Headers -->
        <Style Selector="TextBlock.section-header">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,24"/>
        </Style>
        
        <!-- Field Labels -->
        <Style Selector="TextBlock.field-label">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="LetterSpacing" Value="0.5"/>
        </Style>
        
        <!-- Field Values -->
        <Style Selector="TextBlock.field-value">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="FontWeight" Value="Medium"/>
        </Style>
        
        <!-- Back Button -->
        <Style Selector="Button.back-button">
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Background" Value="{DynamicResource ProfileCardBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style Selector="Button.back-button:pointerover">
            <Setter Property="Background" Value="{DynamicResource MinimalAccentSoftBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource MinimalAccentBrush}"/>
        </Style>
        
        <!-- Status Badge -->
        <Style Selector="Border.status-badge">
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="16,8"/>
        </Style>
        
        <!-- Avatar -->
        <Style Selector="Border.avatar">
            <Setter Property="Background" Value="{DynamicResource AvatarPlaceholderBrush}"/>
            <Setter Property="CornerRadius" Value="50"/>
            <Setter Property="ClipToBounds" Value="True"/>
        </Style>
        
        <!-- Section Divider -->
        <Style Selector="Border.section-divider">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource SectionDividerBrush}"/>
            <Setter Property="Margin" Value="0,16"/>
        </Style>
        
        <!-- Minimal Title -->
        <Style Selector="TextBlock.minimal-title">
            <Setter Property="FontSize" Value="32"/>
            <Setter Property="FontWeight" Value="Light"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="LetterSpacing" Value="-0.5"/>
        </Style>
        
        <!-- Profile Name -->
        <Style Selector="TextBlock.profile-name">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Light"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="LetterSpacing" Value="-0.3"/>
        </Style>
        
        <!-- Profile Role -->
        <Style Selector="TextBlock.profile-role">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="FontWeight" Value="Normal"/>
        </Style>
    </UserControl.Styles>
    
    <ScrollViewer>
        <StackPanel Spacing="40" Margin="60">
            <!-- Header with Back Button -->
            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto">
                <Button Grid.Column="0" 
                        Content="← Back" 
                        Command="{Binding GoBackCommand}" 
                        Classes="back-button"/>
                <TextBlock Grid.Column="1" 
                           Text="Profile" 
                           Classes="minimal-title"
                           VerticalAlignment="Center" 
                           Margin="24,0,0,0"/>
            </Grid>
            
            <!-- Loading State -->
            <ProgressBar IsIndeterminate="True" 
                         IsVisible="{Binding IsLoading}"
                         Height="2"
                         Margin="0,20"
                         Background="{DynamicResource SectionDividerBrush}"
                         Foreground="{DynamicResource MinimalAccentBrush}"/>
            
            <!-- Error State -->
            <Border Background="#FEF2F2" 
                    BorderBrush="#FECACA" 
                    BorderThickness="1" 
                    CornerRadius="12" 
                    Padding="20"
                    IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <ic:FluentIcon Icon="Warning" 
                                    IconSize="Size20" 
                                    Foreground="#DC2626"/>
                    <TextBlock Text="{Binding ErrorMessage}" 
                               Foreground="#DC2626" 
                               FontWeight="Medium"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
            
            <!-- Profile Header Card -->
            <Border Classes="profile-card" 
                    IsVisible="{Binding !IsLoading}"
                    HorizontalAlignment="Center"
                    MaxWidth="500">
                <StackPanel Spacing="32" HorizontalAlignment="Center">
                    <!-- Avatar -->
                    <Border Width="100" Height="100" Classes="avatar">
                        <ic:FluentIcon Icon="Person" 
                                        IconSize="Size32" 
                                        Foreground="{DynamicResource TextMutedBrush}"
                                        HorizontalAlignment="Center" 
                                        VerticalAlignment="Center"/>
                    </Border>
                    
                    <!-- Name and Role -->
                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding FullName}" 
                                   Classes="profile-name"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding Role}" 
                                   Classes="profile-role"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                    
                    <!-- Status Badge -->
                    <Border Classes="status-badge" 
                            HorizontalAlignment="Center"
                            Background="{DynamicResource StatusActiveSoftBrush}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Ellipse Width="6" Height="6" 
                                     Fill="{DynamicResource StatusActiveBrush}"/>
                            <TextBlock Text="{Binding Status}" 
                                       FontSize="12" 
                                       FontWeight="Medium"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
            
            <!-- Two Column Content -->
            <Grid ColumnDefinitions="1*,1*" IsVisible="{Binding !IsLoading}">
                
                <!-- Left Column - Role Specific Information -->
                <Border Grid.Column="0" Classes="info-card" Margin="0,0,16,0">
                    <StackPanel Spacing="32">
                        <!-- Student Information -->
                        <StackPanel Spacing="24" IsVisible="{Binding IsStudent}">
                            <TextBlock Text="Student Information" Classes="section-header"/>
                            
                            <StackPanel Spacing="16">
                                <Grid ColumnDefinitions="120,*">
                                    <TextBlock Grid.Column="0" Text="STUDENT ID" Classes="field-label"/>
                                    <TextBlock Grid.Column="1" Text="{Binding StudentId}" Classes="field-value"/>
                                </Grid>
                                <Border Classes="section-divider"/>
                                
                                <Grid ColumnDefinitions="120,*">
                                    <TextBlock Grid.Column="0" Text="LRN ID" Classes="field-label"/>
                                    <TextBlock Grid.Column="1" Text="{Binding LrnId}" Classes="field-value"/>
                                </Grid>
                                <Border Classes="section-divider"/>
                                
                                <Grid ColumnDefinitions="120,*">
                                    <TextBlock Grid.Column="0" Text="GRADE LEVEL" Classes="field-label"/>
                                    <TextBlock Grid.Column="1" Text="{Binding GradeLevel}" Classes="field-value"/>
                                </Grid>
                                <Border Classes="section-divider"/>
                                
                                <Grid ColumnDefinitions="120,*">
                                    <TextBlock Grid.Column="0" Text="SECTION" Classes="field-label"/>
                                    <TextBlock Grid.Column="1" Text="{Binding SectionName}" Classes="field-value"/>
                                </Grid>
                                <Border Classes="section-divider"/>
                                
                                <Grid ColumnDefinitions="120,*">
                                    <TextBlock Grid.Column="0" Text="AGE" Classes="field-label"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Age}" Classes="field-value"/>
                                </Grid>
                                <Border Classes="section-divider"/>
                                
                                <Grid ColumnDefinitions="120,*">
                                    <TextBlock Grid.Column="0" Text="BIRTHDAY" Classes="field-label"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Birthday}" Classes="field-value"/>
                                </Grid>
                                <Border Classes="section-divider"/>
                                
                                <Grid ColumnDefinitions="120,*">
                                    <TextBlock Grid.Column="0" Text="ENROLLMENT YEAR" Classes="field-label"/>
                                    <TextBlock Grid.Column="1" Text="{Binding EnrollmentYear}" Classes="field-value"/>
                                </Grid>
                                <Border Classes="section-divider"/>
                                
                                <Grid ColumnDefinitions="120,*">
                                    <TextBlock Grid.Column="0" Text="HONOR STATUS" Classes="field-label"/>
                                    <TextBlock Grid.Column="1" Text="{Binding HonorStatus}" Classes="field-value"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                        
                        <!-- Teacher Information -->
                        <StackPanel Spacing="24" IsVisible="{Binding IsTeacher}">
                            <TextBlock Text="Teacher Information" Classes="section-header"/>
                            
                            <StackPanel Spacing="16">
                                <Grid ColumnDefinitions="120,*">
                                    <TextBlock Grid.Column="0" Text="PHONE NUMBER" Classes="field-label"/>
                                    <TextBlock Grid.Column="1" Text="{Binding PhoneNumber}" Classes="field-value"/>
                                </Grid>
                                <Border Classes="section-divider"/>
                                
                                <Grid ColumnDefinitions="120,*">
                                    <TextBlock Grid.Column="0" Text="DEPARTMENT" Classes="field-label"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Department}" Classes="field-value"/>
                                </Grid>
                                <Border Classes="section-divider"/>
                                
                                <Grid ColumnDefinitions="120,*">
                                    <TextBlock Grid.Column="0" Text="SUBJECT SPECIALIZATION" Classes="field-label"/>
                                    <TextBlock Grid.Column="1" Text="{Binding SubjectSpecialization}" Classes="field-value"/>
                                </Grid>
                                <Border Classes="section-divider"/>
                                
                                <Grid ColumnDefinitions="120,*">
                                    <TextBlock Grid.Column="0" Text="ADVISORY SECTION" Classes="field-label"/>
                                    <TextBlock Grid.Column="1" Text="{Binding AdvisorySection}" Classes="field-value"/>
                                </Grid>
                                <Border Classes="section-divider"/>
                                
                                <Grid ColumnDefinitions="120,*">
                                    <TextBlock Grid.Column="0" Text="AGE" Classes="field-label"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Age}" Classes="field-value"/>
                                </Grid>
                                <Border Classes="section-divider"/>
                                
                                <Grid ColumnDefinitions="120,*">
                                    <TextBlock Grid.Column="0" Text="BIRTHDAY" Classes="field-label"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Birthday}" Classes="field-value"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                        
                        <!-- Admin Information -->
                        <StackPanel Spacing="24" IsVisible="{Binding IsAdmin}">
                            <TextBlock Text="Admin Information" Classes="section-header"/>
                            
                            <StackPanel Spacing="16">
                                <Grid ColumnDefinitions="120,*">
                                    <TextBlock Grid.Column="0" Text="PHONE NUMBER" Classes="field-label"/>
                                    <TextBlock Grid.Column="1" Text="{Binding PhoneNumber}" Classes="field-value"/>
                                </Grid>
                                <Border Classes="section-divider"/>
                                
                                <Grid ColumnDefinitions="120,*">
                                    <TextBlock Grid.Column="0" Text="ROLE DESCRIPTION" Classes="field-label"/>
                                    <TextBlock Grid.Column="1" Text="{Binding RoleDescription}" 
                                               Classes="field-value" TextWrapping="Wrap"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
                
                <!-- Right Column - Basic Information -->
                <Border Grid.Column="1" Classes="info-card" Margin="16,0,0,0">
                    <StackPanel Spacing="32">
                        <TextBlock Text="Account Information" Classes="section-header"/>
                        
                        <StackPanel Spacing="16">
                            <Grid ColumnDefinitions="120,*">
                                <TextBlock Grid.Column="0" Text="FULL NAME" Classes="field-label"/>
                                <TextBlock Grid.Column="1" Text="{Binding FullName}" Classes="field-value"/>
                            </Grid>
                            <Border Classes="section-divider"/>
                            
                            <Grid ColumnDefinitions="120,*">
                                <TextBlock Grid.Column="0" Text="EMAIL" Classes="field-label"/>
                                <TextBlock Grid.Column="1" Text="{Binding Email}" Classes="field-value"/>
                            </Grid>
                            <Border Classes="section-divider"/>
                            
                            <Grid ColumnDefinitions="120,*">
                                <TextBlock Grid.Column="0" Text="ROLE" Classes="field-label"/>
                                <TextBlock Grid.Column="1" Text="{Binding Role}" Classes="field-value"/>
                            </Grid>
                            <Border Classes="section-divider"/>
                            
                            <Grid ColumnDefinitions="120,*">
                                <TextBlock Grid.Column="0" Text="STATUS" Classes="field-label"/>
                                <TextBlock Grid.Column="1" Text="{Binding Status}" Classes="field-value"/>
                            </Grid>
                            <Border Classes="section-divider"/>
                            
                            <Grid ColumnDefinitions="120,*">
                                <TextBlock Grid.Column="0" Text="CREATED AT" Classes="field-label"/>
                                <TextBlock Grid.Column="1" Text="{Binding CreatedAt}" Classes="field-value"/>
                            </Grid>
                            <Border Classes="section-divider"/>
                            
                            <Grid ColumnDefinitions="120,*">
                                <TextBlock Grid.Column="0" Text="LAST UPDATED" Classes="field-label"/>
                                <TextBlock Grid.Column="1" Text="{Binding UpdatedAt}" Classes="field-value"/>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
