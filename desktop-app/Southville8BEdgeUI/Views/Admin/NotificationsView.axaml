<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Southville8BEdgeUI.ViewModels.Admin"
             xmlns:converters="using:Southville8BEdgeUI.Converters"
             xmlns:ic="using:FluentIcons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="Southville8BEdgeUI.Views.Admin.NotificationsView"
             x:Name="NotificationsRoot"
             x:DataType="vm:NotificationsViewModel"
             Background="{DynamicResource PageBackgroundBrush}">

    <UserControl.Styles>
        <!-- Typography -->
        <Style Selector="TextBlock.page-title">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>
        <Style Selector="TextBlock.inline">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
        </Style>
        <Style Selector="TextBlock.inline-accent">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
        </Style>
        <Style Selector="TextBlock.item-title">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>
        <Style Selector="TextBlock.item-message">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style Selector="TextBlock.item-time">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        </Style>
        <Style Selector="TextBlock.empty-text">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <!-- Buttons -->
        <Style Selector="Button.action-secondary">
            <Setter Property="Background" Value="{DynamicResource TextMutedBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentTextOnAccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.action-danger">
            <Setter Property="Background" Value="{DynamicResource DangerBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentTextOnAccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.icon-success">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
        </Style>
        <Style Selector="Button.icon-danger">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
        </Style>
        <!-- Icon foreground inheritance -->
        <Style Selector="Button.action-secondary ic|FluentIcon, Button.action-danger ic|FluentIcon">
            <Setter Property="Foreground" Value="{DynamicResource AccentTextOnAccentBrush}"/>
        </Style>
        <Style Selector="Button.icon-success ic|FluentIcon">
            <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
        </Style>
        <Style Selector="Button.icon-danger ic|FluentIcon">
            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
        </Style>

        <!-- Cards / Containers -->
        <Style Selector="Border.root-card">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="Border.notification-item">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style Selector="Border.type-indicator">
            <Setter Property="Width" Value="12"/>
            <Setter Property="Height" Value="12"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Background" Value="{DynamicResource DangerBrush}"/>
            <Setter Property="Margin" Value="0,4,12,0"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>
        <Style Selector="Border.empty-card">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="40"/>
        </Style>
    </UserControl.Styles>

    <Border Classes="root-card">
        <StackPanel Spacing="24">
            <!-- Header -->
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <ic:FluentIcon Icon="Alert" IconSize="Size20" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="Notifications" Classes="page-title"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="You have" Classes="inline"/>
                        <TextBlock Text="{Binding UnreadCount}" Classes="inline-accent"/>
                        <TextBlock Text="unread notifications" Classes="inline"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button Classes="action-secondary" Command="{Binding #NotificationsRoot.MarkAllAsReadCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <ic:FluentIcon Icon="Checkmark" IconSize="Size16"/>
                            <TextBlock Text="Mark All Read"/>
                        </StackPanel>
                    </Button>
                    <Button Classes="action-danger" Command="{Binding #NotificationsRoot.ClearAllCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <ic:FluentIcon Icon="Delete" IconSize="Size16"/>
                            <TextBlock Text="Clear All"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Notifications List -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="500" IsVisible="{Binding Notifications.Count, Converter={x:Static converters:CollectionHasItemsConverter.Instance}}">
                <ItemsControl ItemsSource="{Binding Notifications}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Classes="notification-item">
                                <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                                    <!-- Notification Type Indicator -->
                                    <Border Grid.Column="0" Classes="type-indicator"/>

                                    <!-- Content -->
                                    <StackPanel Grid.Column="1" Spacing="4">
                                        <TextBlock Text="{Binding Title}" Classes="item-title"/>
                                        <TextBlock Text="{Binding Message}" Classes="item-message"/>
                                        <TextBlock Text="{Binding TimeAgo}" Classes="item-time"/>
                                    </StackPanel>

                                    <!-- Mark as Read Button -->
                                    <Button Grid.Column="2"
                                            Classes="icon-success"
                                            IsVisible="{Binding IsRead, Converter={x:Static converters:BooleanNegationConverter.Instance}}"
                                            Command="{Binding #NotificationsRoot.MarkAsReadCommand}"
                                            CommandParameter="{Binding}">
                                        <ic:FluentIcon Icon="Checkmark" IconSize="Size16"/>
                                    </Button>

                                    <!-- Delete Button -->
                                    <Button Grid.Column="3"
                                            Classes="icon-danger"
                                            Command="{Binding #NotificationsRoot.DeleteNotificationCommand}"
                                            CommandParameter="{Binding}">
                                        <ic:FluentIcon Icon="Delete" IconSize="Size16"/>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Empty State -->
            <StackPanel VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Spacing="16"
                       IsVisible="{Binding Notifications.Count, Converter={x:Static converters:CollectionIsEmptyConverter.Instance}}">
                <ic:FluentIcon Icon="Alert" IconSize="Size48" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                <TextBlock Text="No notifications" Classes="empty-text"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
