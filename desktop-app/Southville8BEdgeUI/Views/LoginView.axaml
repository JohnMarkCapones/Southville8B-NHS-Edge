<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Southville8BEdgeUI.ViewModels"
             xmlns:c="using:Southville8BEdgeUI.Converters"
             mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="720"
             x:Class="Southville8BEdgeUI.Views.LoginView"
             x:DataType="vm:LoginViewModel"
             Background="{StaticResource LoginPanelGradientBrush}">

	<UserControl.Resources>
		<!-- View-specific brand palette (unique keys to avoid shadowing global theme tokens) -->
		<SolidColorBrush x:Key="LoginBrandPrimaryBrush" Color="#6366F1"/>
		<SolidColorBrush x:Key="LoginBrandPrimaryBrushHover" Color="#5B5AF0"/>
		<SolidColorBrush x:Key="LoginBrandPrimaryBrushPressed" Color="#4F46E5"/>
		<SolidColorBrush x:Key="LoginBrandSecondaryBrush" Color="#EC4899"/>
		<SolidColorBrush x:Key="LoginBrandAccentBrush" Color="#10B981"/>

		<!-- Additional login-only text accents (do not redefine global Text* brushes) -->
		<SolidColorBrush x:Key="LoginTextMainBrush" Color="#F37071" />
		<SolidColorBrush x:Key="LoginTextMainSecondaryBrush" Color="#F27071"/>
		<SolidColorBrush x:Key="LoginTextGrayBrush" Color="#8D8D8C"/>

		<!-- Login specific surfaces / accents (avoid redefining global CardBackgroundBrush / BorderBrush / SurfaceBrush) -->
		<SolidColorBrush x:Key="LoginButtonPeachBrush" Color="#F37071" />
		<SolidColorBrush x:Key="LoginInputFocusBrush" Color="#FFFFFF"/>
		<SolidColorBrush x:Key="LoginBorderFocusBrush" Color="#6366F1"/>
		<SolidColorBrush x:Key="LoginInputHoverBgBrush" Color="#F1F5F9"/>

		<!-- Primary button (gradient) brushes (scoped to login) -->
		<LinearGradientBrush x:Key="LoginPrimaryButtonBrush" StartPoint="0,0" EndPoint="1,1">
			<GradientStop Color="#2563EB" Offset="0"/>
			<GradientStop Color="#4F46E5" Offset="1"/>
		</LinearGradientBrush>
		<LinearGradientBrush x:Key="LoginPrimaryButtonBrushHover" StartPoint="0,0" EndPoint="1,1">
			<GradientStop Color="#1D4ED8" Offset="0"/>
			<GradientStop Color="#4338CA" Offset="1"/>
		</LinearGradientBrush>
		<LinearGradientBrush x:Key="LoginPrimaryButtonBrushPressed" StartPoint="0,0" EndPoint="1,1">
			<GradientStop Color="#1E40AF" Offset="0"/>
			<GradientStop Color="#3730A3" Offset="1"/>
		</LinearGradientBrush>

		<!-- Background gradient for login view -->
		<LinearGradientBrush x:Key="LoginPanelGradientBrush" StartPoint="0,0" EndPoint="1,1">
			<GradientStop Color="#FFFFFF" Offset="0"/>
			<GradientStop Color="#F8FAFC" Offset="0.7"/>
			<GradientStop Color="#F1F5F9" Offset="1"/>
		</LinearGradientBrush>

		<!-- Decorative gradient -->
		<LinearGradientBrush x:Key="LoginBrandGradientBrush" StartPoint="0,0" EndPoint="1,1">
			<GradientStop Color="#6366F1" Offset="0"/>
			<GradientStop Color="#5B5AF0" Offset="0.5"/>
			<GradientStop Color="#4F46E5" Offset="1"/>
		</LinearGradientBrush>

		<!-- Glassmorphism Effect -->
		<SolidColorBrush x:Key="LoginGlassBrush" Color="#F0FFFFFF"/>
		<!-- Converters -->
		<c:BoolToPasswordCharConverter x:Key="ShowPasswordToChar" MaskChar="●"/>
		<c:BoolToLoadingTextConverter x:Key="BoolToLoadingTextConverter"/>
		<c:BoolInverterConverter x:Key="BoolInverterConverter"/>
	</UserControl.Resources>

	<UserControl.Styles>
		<!-- Underline input (reuse global BorderBrush) -->
		<Style Selector="Border.input-underline">
			<Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
			<Setter Property="BorderThickness" Value="0,0,0,2"/>
			<Setter Property="Padding" Value="0,8"/>
			<Setter Property="Transitions">
				<Transitions>
					<BrushTransition Property="BorderBrush" Duration="0:0:0.2"/>
				</Transitions>
			</Setter>
		</Style>
		<Style Selector="Border.input-underline:focus-within">
			<Setter Property="BorderBrush" Value="{StaticResource LoginBorderFocusBrush}"/>
		</Style>

		<!-- Primary Buttons -->
		<Style Selector="UserControl Button">
			<Setter Property="CornerRadius" Value="12"/>
			<Setter Property="Padding" Value="24,16"/>
			<Setter Property="Background" Value="{StaticResource LoginPrimaryButtonBrush}"/>
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="TextElement.Foreground" Value="White"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
			<Setter Property="FontSize" Value="15"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="HorizontalAlignment" Value="Stretch"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="MinHeight" Value="48"/>
			<Setter Property="HorizontalContentAlignment" Value="Center"/>
			<Setter Property="VerticalContentAlignment" Value="Center"/>
			<Setter Property="Transitions">
				<Transitions>
					<TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2"/>
					<DoubleTransition Property="Opacity" Duration="0:0:0.15"/>
					<BrushTransition Property="Background" Duration="0:0:0.15"/>
				</Transitions>
			</Setter>
		</Style>
		<Style Selector="UserControl Button:pointerover">
			<Setter Property="RenderTransform" Value="translateY(-1px)"/>
			<Setter Property="Background" Value="{StaticResource LoginPrimaryButtonBrushHover}"/>
		</Style>
		<Style Selector="UserControl Button:pressed">
			<Setter Property="RenderTransform" Value="translateY(1px)"/>
			<Setter Property="Background" Value="{StaticResource LoginPrimaryButtonBrushPressed}"/>
		</Style>
		<Style Selector="UserControl Button:disabled">
			<Setter Property="Opacity" Value="0.5"/>
			<Setter Property="Background" Value="#94A3B8"/>
		</Style>

		<!-- Link Button Style -->
		<Style Selector="UserControl Button.link">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Foreground" Value="{StaticResource LoginBrandPrimaryBrush}"/>
			<Setter Property="TextElement.Foreground" Value="{StaticResource LoginBrandPrimaryBrush}"/>
			<Setter Property="Padding" Value="8,6"/>
			<Setter Property="CornerRadius" Value="8"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="FontWeight" Value="Medium"/>
			<Setter Property="HorizontalAlignment" Value="Right"/>
			<Setter Property="MinHeight" Value="36"/>
			<Setter Property="Transitions">
				<Transitions>
					<BrushTransition Property="Foreground" Duration="0:0:0.15"/>
					<BrushTransition Property="Background" Duration="0:0:0.15"/>
					<DoubleTransition Property="Opacity" Duration="0:0:0.15"/>
				</Transitions>
			</Setter>
		</Style>
		<Style Selector="UserControl Button.link:pointerover">
			<Setter Property="Foreground" Value="{StaticResource LoginBrandPrimaryBrushHover}"/>
			<Setter Property="RenderTransform" Value=""/>
			<Setter Property="Opacity" Value="0.9"/>
			<Setter Property="Background" Value="{StaticResource LoginInputHoverBgBrush}"/>
		</Style>
		<Style Selector="UserControl Button.link:pressed">
			<Setter Property="Background" Value="{DynamicResource BorderBrush}"/>
			<Setter Property="Opacity" Value="0.95"/>
		</Style>

		<!-- Secondary Button Style -->
		<Style Selector="UserControl Button.secondary">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="BorderThickness" Value="2"/>
			<Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
			<Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
			<Setter Property="TextElement.Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
			<Setter Property="MinHeight" Value="44"/>
		</Style>
		<Style Selector="UserControl Button.secondary:pointerover">
			<Setter Property="Background" Value="{DynamicResource PageBackgroundBrush}"/>
			<Setter Property="BorderBrush" Value="{StaticResource LoginBrandPrimaryBrush}"/>
		</Style>

		<!-- Loading spinner animation -->
		<Style Selector="PathIcon.loading-spinner">
			<Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
			<Setter Property="RenderTransform">
				<RotateTransform Angle="0"/>
			</Setter>
		</Style>
	</UserControl.Styles>

	<Grid ColumnDefinitions="*, 420" Margin="80,0,80,0">
		<!-- Left Panel: Welcome Message and Illustration -->
		<StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Left" Spacing="40">
			<!-- Modern Welcome Text with Gradient -->
			<StackPanel Spacing="8">
				<StackPanel Orientation="Horizontal" Spacing="8">
					<TextBlock Text="Welco" FontSize="56" FontWeight="ExtraBold"
                               Foreground="{StaticResource LoginTextMainBrush}"
					   Margin="0,0,-10,0"/>
					<TextBlock Text="me" FontSize="56" FontWeight="ExtraBold"
					   Foreground="{StaticResource LoginTextGrayBrush}"/>
					<TextBlock Text="to" FontSize="56" FontWeight="Light"
                               Foreground="{StaticResource LoginTextGrayBrush}"/>
				</StackPanel>
				<StackPanel Orientation="Horizontal" Spacing="8">
					<TextBlock Text="SV8B NHS" FontSize="36" FontWeight="Bold"
                               Foreground="{StaticResource LoginTextMainSecondaryBrush}"/>
					<TextBlock Text="School Portal" FontSize="36" FontWeight="Medium"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
				</StackPanel>
				<!-- Subtitle -->
				<TextBlock Text="Your gateway to academic excellence and digital learning"
                           FontSize="16" FontWeight="Regular"
                           Foreground="{DynamicResource TextMutedBrush}"
                           Margin="0,8,0,0"/>
			</StackPanel>

			<!-- Modern Image Carousel with Glassmorphism -->
			<Border Height="320" Width="480"
                    Background="{StaticResource LoginPanelGradientBrush}"
                    CornerRadius="20"
                    Margin="0,20,0,0"
                    BoxShadow="0 20 40 -12 #0000001A, 0 8 32 -8 #0000000F"
                    ClipToBounds="True">
				<!-- Glass overlay for modern effect -->
				<Border
                        BorderBrush="#22FFFFFF">
					<Carousel x:Name="LoginCarousel">
						<Carousel.PageTransition>
							<CompositePageTransition>
								<PageSlide Duration="0:0:0.45"/>
								<CrossFade Duration="0:0:0.35"/>
							</CompositePageTransition>
						</Carousel.PageTransition>
					</Carousel>
				</Border>
			</Border>

			<!-- Modern Carousel Dots -->
			<StackPanel x:Name="CarouselDots"
                        Orientation="Horizontal"
                        Spacing="12"
                        HorizontalAlignment="Center"
                        Margin="0,20,0,0"/>
		</StackPanel>

		<!-- Right Panel: Modern Login Form -->
		<Border Grid.Column="1"
				Background="{DynamicResource CardBackgroundBrush}"
				BorderBrush="{DynamicResource BorderBrush}"
				CornerRadius="20"
				Padding="32"
				VerticalAlignment="Center"
				BorderThickness="1"
				HorizontalAlignment="Stretch"
				BoxShadow="0 20 40 -12 #0000001A, 0 8 32 -8 #0000000F"
				Margin="0,0,0,0">
			<Grid>
				<Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,*,Auto,Auto,Auto">
				<!-- Header row: Title + Logo aligned -->
				<Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,24">
					<StackPanel Grid.Column="0" Spacing="8" VerticalAlignment="Top">
						<TextBlock Text="Welcome Back!"
							   Foreground="{DynamicResource TextPrimaryBrush}"
							   FontSize="32"
							   FontWeight="ExtraBold"/>
						<TextBlock Text="Sign in to your account to continue"
							   Foreground="{DynamicResource TextSecondaryBrush}"
							   FontSize="16"
							   FontWeight="Regular"/>
					</StackPanel>
					<!-- Logo Image -->
						<Image Grid.Column="1" 
						   Source="avares://Southville8BEdgeUI/Assets/Images/southville-8b-logo.png"
						   Width="80"
						   Height="80"
						   HorizontalAlignment="Left"
						   VerticalAlignment="Top"
						   Margin="16,0,0,0"/>
				</Grid>
				<!-- Email Input (Row 1) -->
				<StackPanel Grid.Row="1" Spacing="8" Margin="0,0,0,20">
					<Border Classes="input-underline" x:Name="EmailBorder">
						<Grid ColumnDefinitions="Auto,*" VerticalAlignment="Center">
							<PathIcon Grid.Column="0"
								  Data="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"
								  Width="18" Height="18"
								  Foreground="{DynamicResource TextMutedBrush}"
								  Margin="0,0,12,0"
								  VerticalAlignment="Center"/>
							<TextBox Grid.Column="1"
								 BorderThickness="0"
								 Background="Transparent"
								 VerticalContentAlignment="Center"
								 Text="{Binding Email}"
								 Watermark="Enter your email address"
								 Classes="modern-input"
								 FontSize="15"
								 IsEnabled="{Binding IsLoading, Converter={StaticResource BoolInverterConverter}}"/>
						</Grid>
					</Border>
				</StackPanel>

				<!-- Password Input (Row 2) -->
				<StackPanel Grid.Row="2" Spacing="8" Margin="0,0,0,20">
					<Border Classes="input-underline" x:Name="PasswordBorder">
						<Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
							<PathIcon Grid.Column="0"
								  Data="M18,8h-1V6A5,5 0 0,0 12,1A5,5 0 0,0 7,6V8H6A2,2 0 0,0 4,10V20A2,2 0 0,0 6,22H18A2,2 0 0 0 20,20V10A2,2 0 0 0 18,8M9,6A3,3 0 0,1 12,3A3,3 0 0,1 15,6V8H9V6Z"
								  Width="18" Height="18"
								  Foreground="{DynamicResource TextMutedBrush}"
								  Margin="0,0,12,0"
								  VerticalAlignment="Center"/>
							<TextBox Grid.Column="1"
								 BorderThickness="0"
								 Background="Transparent"
								 VerticalContentAlignment="Center"
								 Text="{Binding Password, Mode=TwoWay}"
								 Watermark="Enter your password"
								 Classes="modern-input"
								 FontSize="15"
								 PasswordChar="{Binding ShowPassword, Converter={StaticResource ShowPasswordToChar}}"
								 IsEnabled="{Binding IsLoading, Converter={StaticResource BoolInverterConverter}}" />
							<ToggleButton Grid.Column="2"
								 Background="Transparent"
								 BorderThickness="0"
								 Padding="8"
								 Cursor="Hand"
								 IsChecked="{Binding ShowPassword, Mode=TwoWay}"
								 IsEnabled="{Binding IsLoading, Converter={StaticResource BoolInverterConverter}}">
								<PathIcon Data="M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9M12,17A5,5 0 0,1 7,12A5,5 0 0,1 12,7A5,5 0 0,1 17,12A5,5 0 0,1 12,17M12,4.5C7,4.5 2.73,7.61 1,12C2.73,16.39 7,19.5 12,19.5C17,19.5 21.27,16.39 23,12C21.27,7.61 17,4.5 12,4.5Z"
									Width="18" Height="18"
									Foreground="{DynamicResource TextMutedBrush}"/>
							</ToggleButton>
						</Grid>
					</Border>
				</StackPanel>

				<!-- Remember me/Forgot password (Row 3) -->
				<Grid Grid.Row="3" ColumnDefinitions="*, Auto" Margin="0,0,0,24" VerticalAlignment="Center">
					<CheckBox Grid.Column="0"
							  Content="Keep me signed in"
							  IsChecked="{Binding RememberMe}"
							  Foreground="{DynamicResource TextSecondaryBrush}"
							  FontSize="14"
							  IsEnabled="{Binding IsLoading, Converter={StaticResource BoolInverterConverter}}"/>
					<Button Grid.Column="1"
							Content="Forgot Password?"
							Command="{Binding ForgotPasswordCommand}"
							FontSize="14"
							Background="Transparent"
							Classes="link"
							Padding="0,2"
							IsEnabled="{Binding IsLoading, Converter={StaticResource BoolInverterConverter}}">
					</Button>
				</Grid>

				<!-- Error Message (Row 4) -->
				<Border Grid.Row="4" 
						Background="#FEF2F2" 
						BorderBrush="#FECACA" 
						BorderThickness="1" 
						CornerRadius="8" 
						Padding="12,8" 
						Margin="0,0,0,16"
						MaxWidth="400"
						HorizontalAlignment="Stretch"
						IsVisible="{Binding HasError}">
					<Grid ColumnDefinitions="Auto,*">
						<PathIcon Grid.Column="0"
								  Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"
								  Width="16" Height="16"
								  Foreground="#DC2626"
								  VerticalAlignment="Top"
								  Margin="0,2,8,0"/>
						<TextBlock Grid.Column="1"
								   Text="{Binding ErrorMessage}" 
								   Foreground="#DC2626" 
								   FontSize="14" 
								   FontWeight="Medium"
								   TextWrapping="Wrap"
								   VerticalAlignment="Top"/>
					</Grid>
				</Border>

				<!-- Login Button (Row 5) -->
				<Button Grid.Row="5"
						Command="{Binding LoginCommand}"
						HorizontalAlignment="Stretch"
						CornerRadius="12"
						FontWeight="SemiBold"
						Background="{StaticResource LoginButtonPeachBrush}"
						FontSize="16"
						Foreground="White"
						HorizontalContentAlignment="Center"
						VerticalContentAlignment="Center"
						BorderThickness="0"
						Height="52"
						Margin="0,0,0,16"
						IsEnabled="{Binding IsLoading, Converter={StaticResource BoolInverterConverter}}"
						Classes="primary-button">
					<Button.Content>
						<StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
							<!-- Loading spinner using Fluent Design System -->
							<PathIcon IsVisible="{Binding IsLoading}"
									  Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8z"
									  Width="16" Height="16"
									  Foreground="White"
									  VerticalAlignment="Center"
									  Classes="loading-spinner"/>
							<!-- Button text -->
							<TextBlock Text="{Binding IsLoading, Converter={StaticResource BoolToLoadingTextConverter}}"
									   VerticalAlignment="Center"/>
						</StackPanel>
					</Button.Content>
					<Button.Styles>
						<Style Selector="Button.primary-button">
							<Setter Property="Background" Value="{StaticResource LoginPrimaryButtonBrush}"/>
							<Setter Property="Cursor" Value="Hand"/>
						</Style>
						<Style Selector="Button.primary-button:pointerover">
							<Setter Property="Background" Value="{StaticResource LoginPrimaryButtonBrushHover}"/>
							<Setter Property="RenderTransform" Value="scale(1.01)"/>
						</Style>
						<Style Selector="Button.primary-button:pressed">
							<Setter Property="Background" Value="{StaticResource LoginPrimaryButtonBrushPressed}"/>
							<Setter Property="RenderTransform" Value="scale(0.99)"/>
						</Style>
					</Button.Styles>
				</Button>

				<!-- Divider with "or" text (Row 6) -->
				<Grid Grid.Row="6" VerticalAlignment="Center" Margin="0,0,0,24">
					<Border Height="1" Background="{DynamicResource BorderBrush}" VerticalAlignment="Center"/>
				</Grid>


				<!-- Terms and Conditions (Row 8) -->
				<Button Grid.Row="8"
						Content="Terms and Conditions"
						HorizontalAlignment="Center"
						Background="Transparent"
						FontSize="13"
						Margin="0,0,0,0"
						Classes="link"
						Foreground="#DC2626"
						FontWeight="SemiBold">
					</Button>

				<!-- Footer note (Row 9) -->
				<TextBlock Grid.Row="9"
						   Text="Secure portal access for students and faculty"
						   HorizontalAlignment="Center"
						   FontSize="12"
						   Foreground="{DynamicResource TextMutedBrush}"
						   Margin="0,40,0,0"/>
				</Grid>

				<!-- Quick Dev Login Badge (Remove in Production) -->
				<StackPanel HorizontalAlignment="Right" 
							VerticalAlignment="Bottom" 
							Margin="0,0,-12,-12"
							Spacing="4">
					<Border Background="#3B82F6" 
							CornerRadius="8,0,0,0" 
							Padding="8,6"
							BoxShadow="0 4 8 0 #00000020">
						<StackPanel Spacing="6">
							<TextBlock Text="DEV" 
									   FontSize="10" 
									   FontWeight="Bold" 
									   Foreground="White" 
									   HorizontalAlignment="Center"/>
							<Button Content="Admin" 
									Command="{Binding FillAdminCredentialsCommand}"
									FontSize="11"
									Padding="12,4"
									Background="#10B981"
									Foreground="White"
									CornerRadius="4"
									BorderThickness="0"
									HorizontalAlignment="Stretch"
									MinHeight="28"
									Cursor="Hand"/>
							<Button Content="Teacher" 
									Command="{Binding FillTeacherCredentialsCommand}"
									FontSize="11"
									Padding="12,4"
									Background="#F59E0B"
									Foreground="White"
									CornerRadius="4"
									BorderThickness="0"
									HorizontalAlignment="Stretch"
									MinHeight="28"
									Cursor="Hand"/>
						</StackPanel>
					</Border>
				</StackPanel>
			</Grid>
		</Border>
	</Grid>
</UserControl>

