<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <ResourceDictionary.ThemeDictionaries>
    <!-- Light -->
    <ResourceDictionary x:Key="Light">
      <!-- surfaces -->
      <SolidColorBrush x:Key="PageBackgroundBrush">#F9FAFB</SolidColorBrush>
      <SolidColorBrush x:Key="CardBackgroundBrush">#FFFFFFFF</SolidColorBrush>
      <SolidColorBrush x:Key="SidebarBackgroundBrush">#FFFFFFFF</SolidColorBrush>
      <SolidColorBrush x:Key="BorderBrush">#E5E7EB</SolidColorBrush>

      <!-- text -->
      <SolidColorBrush x:Key="TextPrimaryBrush">#111827</SolidColorBrush>
      <SolidColorBrush x:Key="TextSecondaryBrush">#374151</SolidColorBrush>
      <SolidColorBrush x:Key="TextMutedBrush">#6B7280</SolidColorBrush>

      <!-- brand/accent (teacher shell) -->
      <SolidColorBrush x:Key="AccentBrush">#4F6D8C</SolidColorBrush>
      <SolidColorBrush x:Key="AccentHoverBrush">#3C5C7A</SolidColorBrush>
      <SolidColorBrush x:Key="AccentTextOnAccentBrush">#FFFFFFFF</SolidColorBrush>

      <!-- status -->
      <SolidColorBrush x:Key="SuccessBrush">#10B981</SolidColorBrush>
      <SolidColorBrush x:Key="InfoBrush">#3B82F6</SolidColorBrush>
      <SolidColorBrush x:Key="WarningBrush">#F59E0B</SolidColorBrush>
      <SolidColorBrush x:Key="DangerBrush">#EF4444</SolidColorBrush>
      <SolidColorBrush x:Key="DangerHoverBrush">#DC2626</SolidColorBrush>

      <!-- additional vibrant palettes -->
      <SolidColorBrush x:Key="IndigoBrush">#4F46E5</SolidColorBrush>
      <SolidColorBrush x:Key="PurpleBrush">#8B5CF6</SolidColorBrush>
      <SolidColorBrush x:Key="PinkBrush">#EC4899</SolidColorBrush>
      <SolidColorBrush x:Key="TealBrush">#0D9488</SolidColorBrush>
      <SolidColorBrush x:Key="GrayButtonBrush">#6B7280</SolidColorBrush>

      <!-- soft / subtle background tints (used for icon backgrounds, kpi backgrounds, chips) -->
      <SolidColorBrush x:Key="SuccessSoftBrush">#D1FAE5</SolidColorBrush>
      <SolidColorBrush x:Key="InfoSoftBrush">#DBEAFE</SolidColorBrush>
      <SolidColorBrush x:Key="WarningSoftBrush">#FEF3C7</SolidColorBrush>
      <SolidColorBrush x:Key="DangerSoftBrush">#FEE2E2</SolidColorBrush>
      <SolidColorBrush x:Key="IndigoSoftBrush">#E0E7FF</SolidColorBrush>
      <SolidColorBrush x:Key="PurpleSoftBrush">#EDE9FE</SolidColorBrush>
      <SolidColorBrush x:Key="PinkSoftBrush">#FCE7F3</SolidColorBrush>
      <SolidColorBrush x:Key="TealSoftBrush">#E0F2F1</SolidColorBrush>
      <SolidColorBrush x:Key="GraySoftBrush">#F3F4F6</SolidColorBrush>
    </ResourceDictionary>

    <!-- Dark -->
    <ResourceDictionary x:Key="Dark">
      <!-- surfaces -->
      <SolidColorBrush x:Key="PageBackgroundBrush">#121417</SolidColorBrush>
      <SolidColorBrush x:Key="CardBackgroundBrush">#1B1F24</SolidColorBrush>
      <SolidColorBrush x:Key="SidebarBackgroundBrush">#1B1F24</SolidColorBrush>
      <SolidColorBrush x:Key="BorderBrush">#29313A</SolidColorBrush>

      <!-- text -->
      <SolidColorBrush x:Key="TextPrimaryBrush">#F3F4F6</SolidColorBrush>
      <SolidColorBrush x:Key="TextSecondaryBrush">#E5E7EB</SolidColorBrush>
      <SolidColorBrush x:Key="TextMutedBrush">#9CA3AF</SolidColorBrush>

      <!-- brand/accent -->
      <SolidColorBrush x:Key="AccentBrush">#4F6D8C</SolidColorBrush>
      <SolidColorBrush x:Key="AccentHoverBrush">#3C5C7A</SolidColorBrush>
      <SolidColorBrush x:Key="AccentTextOnAccentBrush">#FFFFFFFF</SolidColorBrush>

      <!-- status -->
      <SolidColorBrush x:Key="SuccessBrush">#10B981</SolidColorBrush>
      <SolidColorBrush x:Key="InfoBrush">#60A5FA</SolidColorBrush>
      <SolidColorBrush x:Key="WarningBrush">#FBBF24</SolidColorBrush>
      <SolidColorBrush x:Key="DangerBrush">#F87171</SolidColorBrush>
      <SolidColorBrush x:Key="DangerHoverBrush">#DC2626</SolidColorBrush>

      <!-- additional vibrant palettes (dark variants) -->
      <SolidColorBrush x:Key="IndigoBrush">#4338CA</SolidColorBrush>
      <SolidColorBrush x:Key="PurpleBrush">#7E22CE</SolidColorBrush>
      <SolidColorBrush x:Key="PinkBrush">#DB2777</SolidColorBrush>
      <SolidColorBrush x:Key="TealBrush">#115E59</SolidColorBrush>
      <SolidColorBrush x:Key="GrayButtonBrush">#4B5563</SolidColorBrush>

      <!-- soft / subtle background tints (dark friendly) -->
      <SolidColorBrush x:Key="SuccessSoftBrush">#064E3B</SolidColorBrush>
      <SolidColorBrush x:Key="InfoSoftBrush">#1E3A8A</SolidColorBrush>
      <SolidColorBrush x:Key="WarningSoftBrush">#78350F</SolidColorBrush>
      <SolidColorBrush x:Key="DangerSoftBrush">#7F1D1D</SolidColorBrush>
      <SolidColorBrush x:Key="IndigoSoftBrush">#312E81</SolidColorBrush>
      <SolidColorBrush x:Key="PurpleSoftBrush">#3B0764</SolidColorBrush>
      <SolidColorBrush x:Key="PinkSoftBrush">#831843</SolidColorBrush>
      <SolidColorBrush x:Key="TealSoftBrush">#134E4A</SolidColorBrush>
      <SolidColorBrush x:Key="GraySoftBrush">#374151</SolidColorBrush>
    </ResourceDictionary>
  </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>