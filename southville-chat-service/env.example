# Supabase Configuration
# Required: Your Supabase project credentials
SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_JWT_SECRET=your-jwt-secret-here

# Application Configuration
# PORT: Server port (Render will set this automatically, but you can override)
PORT=3001
NODE_ENV=production

# CORS Configuration
# CORS_ORIGIN: Comma-separated list of allowed origins (e.g., "https://yourdomain.com,https://www.yourdomain.com")
# FRONTEND_URL: Alternative to CORS_ORIGIN (single URL or comma-separated)
# ALLOWED_ORIGINS: Alternative to CORS_ORIGIN (comma-separated)
# Note: When credentials: true, origin cannot be '*'
CORS_ORIGIN=https://yourdomain.com
# Or use:
# FRONTEND_URL=https://yourdomain.com
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

