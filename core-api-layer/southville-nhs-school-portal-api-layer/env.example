# ============================================
# Southville NHS School Portal API - Environment Variables
# ============================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control

# ============================================
# APPLICATION CONFIGURATION
# ============================================
# Port the application will listen on (default: 3004)
PORT=3004

# Node environment (development, production, test)
NODE_ENV=production

# Frontend URL for CORS configuration
# Can be a single URL or comma-separated list of URLs
# Example: https://yourdomain.com
# Example (multiple): https://yourdomain.com,https://www.yourdomain.com
FRONTEND_URL=https://yourdomain.com

# Alternative: Use ALLOWED_ORIGINS for multiple origins
# Takes precedence over FRONTEND_URL if both are set
# Example: https://yourdomain.com,https://www.yourdomain.com,https://admin.yourdomain.com
ALLOWED_ORIGINS=

# ============================================
# SUPABASE CONFIGURATION (REQUIRED)
# ============================================
# Your Supabase project URL
# Example: https://xxxxxxxxxxxxx.supabase.co
SUPABASE_URL=

# Supabase anonymous/public key (safe for client-side)
SUPABASE_ANON_KEY=

# Supabase service role key (server-side only, keep secret!)
SUPABASE_SERVICE_ROLE_KEY=

# Supabase JWT secret (optional, used for token verification)
SUPABASE_JWT_SECRET=

# ============================================
# CLOUDFLARE R2 STORAGE (OPTIONAL)
# ============================================
# Cloudflare R2 Account ID
R2_ACCOUNT_ID=

# Cloudflare R2 Access Key ID
R2_ACCESS_KEY_ID=

# Cloudflare R2 Secret Access Key (keep secret!)
R2_SECRET_ACCESS_KEY=

# R2 Bucket Name
R2_BUCKET_NAME=

# R2 Public URL (if bucket is public)
# Example: https://pub-xxxxx.r2.dev
R2_PUBLIC_URL=

# R2 Region (default: auto)
R2_REGION=auto

# R2 Configuration (optional, with defaults)
# R2_MAX_FILE_SIZE=10485760 (10MB default)
# R2_ALLOWED_MIME_TYPES=image/jpeg,image/jpg,image/png,image/webp,image/gif,application/pdf
# R2_ENABLE_VIRUS_SCANNING=false
# R2_ENABLE_CONTENT_VALIDATION=true
# R2_MULTIPART_THRESHOLD=10485760
# R2_MULTIPART_CHUNKSIZE=5242880
# R2_MAX_CONCURRENCY=3
# R2_CACHE_CONTROL=public, max-age=31536000
# R2_ENABLE_CDN=true
# R2_PRESIGNED_URL_EXPIRATION=3600
# R2_CONNECTION_TIMEOUT=30000
# R2_REQUEST_TIMEOUT=60000
# R2_MAX_RETRIES=3
# R2_ENABLE_REQUEST_LOGGING=false
# R2_LOG_LEVEL=info

# ============================================
# CLOUDFLARE IMAGES (OPTIONAL)
# ============================================
# Cloudflare Account ID
CLOUDFLARE_ACCOUNT_ID=

# Cloudflare Images API Token
CLOUDFLARE_IMAGES_API_TOKEN=

# Cloudflare Account Hash
CLOUDFLARE_ACCOUNT_HASH=

# Cloudflare Images Base URL (default: https://imagedelivery.net)
CLOUDFLARE_IMAGES_BASE_URL=https://imagedelivery.net

# Cloudflare Images Default Variant (default: public)
CLOUDFLARE_IMAGES_DEFAULT_VARIANT=public

# Cloudflare Images Configuration (optional, with defaults)
# ENABLE_CLOUDFLARE_IMAGES=false
# ENABLE_CLOUDFLARE_IMAGES_FALLBACK=true
# CLOUDFLARE_IMAGES_TIMEOUT=30000
# CLOUDFLARE_IMAGES_MAX_FILE_SIZE=10485760
# CLOUDFLARE_IMAGES_ALLOWED_MIME_TYPES=image/jpeg,image/jpg,image/png,image/gif,image/webp,image/avif
# CLOUDFLARE_IMAGES_ENABLE_REQUEST_LOGGING=false
# CLOUDFLARE_IMAGES_ENABLE_ERROR_LOGGING=true

