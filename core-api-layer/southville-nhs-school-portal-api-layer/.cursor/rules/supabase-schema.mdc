  CONSTRAINT clubs_secretary_id_fkey FOREIGN KEY (secretary_id) REFERENCES public.users(id),
  CONSTRAINT clubs_advisor_id_fkey FOREIGN KEY (advisor_id) REFERENCES public.users(id),
