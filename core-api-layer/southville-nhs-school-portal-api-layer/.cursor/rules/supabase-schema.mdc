-- Schedules Module RLS Policies
ALTER TABLE public.schedules ENABLE ROW LEVEL SECURITY;
ALTER TABLE public.student_schedule ENABLE ROW LEVEL SECURITY;

-- Admin can manage all schedules
CREATE POLICY "Admin can manage all schedules" ON public.schedules
FOR ALL USING (
EXISTS (
SELECT 1 FROM public.users u
JOIN public.roles r ON u.role_id = r.id
WHERE u.id = auth.uid() AND r.name = 'Admin'
)
);

-- Teachers can manage their own schedules
CREATE POLICY "Teachers can manage their own schedules" ON public.schedules
FOR ALL USING (
EXISTS (
SELECT 1 FROM public.users u
JOIN public.roles r ON u.role_id = r.id
JOIN public.teachers t ON u.id = t.user_id
WHERE u.id = auth.uid() AND r.name = 'Teacher' AND t.id = teacher_id
)
);

-- Teachers can read schedules for their sections
CREATE POLICY "Teachers can read section schedules" ON public.schedules
FOR SELECT USING (
EXISTS (
SELECT 1 FROM public.users u
JOIN public.roles r ON u.role_id = r.id
JOIN public.teachers t ON u.id = t.user_id
JOIN public.sections s ON t.id = s.teacher_id
WHERE u.id = auth.uid() AND r.name = 'Teacher' AND s.id = section_id
)
);

-- Students can read schedules for their sections
CREATE POLICY "Students can read their section schedules" ON public.schedules
FOR SELECT USING (
EXISTS (
SELECT 1 FROM public.users u
JOIN public.roles r ON u.role_id = r.id
JOIN public.students s ON u.id = s.user_id
WHERE u.id = auth.uid() AND r.name = 'Student' AND s.section_id = section_id
)
);

-- Admin can manage all student schedules
CREATE POLICY "Admin can manage all student schedules" ON public.student_schedule
FOR ALL USING (
EXISTS (
SELECT 1 FROM public.users u
JOIN public.roles r ON u.role_id = r.id
WHERE u.id = auth.uid() AND r.name = 'Admin'
)
);

-- Teachers can manage student schedules for their sections
CREATE POLICY "Teachers can manage student schedules for their sections" ON public.student_schedule
FOR ALL USING (
EXISTS (
SELECT 1 FROM public.users u
JOIN public.roles r ON u.role_id = r.id
JOIN public.teachers t ON u.id = t.user_id
JOIN public.sections s ON t.id = s.teacher_id
JOIN public.schedules sch ON s.id = sch.section_id
WHERE u.id = auth.uid() AND r.name = 'Teacher' AND sch.id = schedule_id
)
);

-- Students can read their own schedules
CREATE POLICY "Students can read their own schedules" ON public.student_schedule
FOR SELECT USING (
EXISTS (
SELECT 1 FROM public.users u
JOIN public.roles r ON u.role_id = r.id
JOIN public.students s ON u.id = s.user_id
WHERE u.id = auth.uid() AND r.name = 'Student' AND s.id = student_id
)
